---
interface Props {
  label: string
  name: string
  type?: string
  required?: boolean
  error?: string
  success?: string
  hint?: string
  value?: string
}

const { label, name, type = 'text', required = false, error, success, hint, value } = Astro.props
---

<div class="space-y-2">
  <label for={name} class="block text-sm font-medium text-gray-300">
    {label}
    {required && <span class="text-red-400">*</span>}
  </label>
  
  <input
    type={type}
    id={name}
    name={name}
    value={value}
    required={required}
    class={`w-full px-4 py-3 bg-black/40 backdrop-blur-xl border rounded-lg text-white placeholder-gray-400 focus:outline-none transition-colors ${
      error ? 'border-red-500/50 focus:border-red-500' : 
      success ? 'border-emerald-500/50 focus:border-emerald-500' : 
      'border-white/10 focus:border-emerald-500/50'
    }`}
  />
  
  {hint && !error && !success && (
    <p class="text-xs text-gray-400">{hint}</p>
  )}
  
  {error && (
    <p class="text-xs text-red-400 flex items-center gap-1">
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
      </svg>
      {error}
    </p>
  )}
  
  {success && (
    <p class="text-xs text-emerald-400 flex items-center gap-1">
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
      </svg>
      {success}
    </p>
  )}
</div>
