---
export const prerender = true

import { getCollection } from 'astro:content'
import Layout from '@/layouts/Layout.astro'
import PageHero from '@/components/ui/PageHero.astro'
import ContentSection from '@/components/ui/ContentSection.astro'

type DocPage = {
  data: {
    draft: boolean
    pubDate: Date
    category?: string
    title: string
    description: string
    order?: number
  }
  id: string
  slug: string
}

const docs = await getCollection('docs', ({ data }: DocPage) => {
  return import.meta.env.PROD ? !data.draft : true
})

const sortedDocs = docs.sort((a: DocPage, b: DocPage) => {
  if (a.data.order !== undefined && b.data.order !== undefined) {
    return a.data.order - b.data.order
  }
  return b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
})

const docsByCategory = sortedDocs.reduce((acc: Record<string, DocPage[]>, doc: DocPage) => {
  const category = doc.data.category || 'General'
  if (!acc[category]) acc[category] = []
  acc[category].push(doc)
  return acc
}, {})

const categoryOrder = ['Getting Started', 'API', 'Guides', 'General']
const categories = Object.keys(docsByCategory).sort((a, b) => {
  const aIndex = categoryOrder.indexOf(a)
  const bIndex = categoryOrder.indexOf(b)
  if (aIndex === -1 && bIndex === -1) return a.localeCompare(b)
  if (aIndex === -1) return 1
  if (bIndex === -1) return -1
  return aIndex - bIndex
})
---

<Layout title="Documentation - Pixelated Empathy" description="Comprehensive platform documentation">
  <PageHero
    badge="Documentation"
    title="Platform Documentation"
    subtitle="Everything you need to know about using Pixelated Empathy"
    gradient={true}
  />

  <ContentSection>
    <div class="max-w-5xl mx-auto">
      <div class="grid md:grid-cols-4 gap-8">
        <!-- Sidebar -->
        <div class="md:col-span-1">
          <div class="sticky top-8 space-y-6">
            <div class="bg-black/40 backdrop-blur-xl border border-white/10 rounded-xl p-6">
              <h3 class="text-lg font-bold text-white mb-4">Categories</h3>
              <nav class="space-y-2">
                {categories.map((category) => (
                  <a href={`#${category.toLowerCase().replace(/\s+/g, '-')}`} class="block text-gray-400 hover:text-emerald-400 transition-colors">
                    {category}
                  </a>
                ))}
              </nav>
            </div>
            
            <div class="bg-black/40 backdrop-blur-xl border border-white/10 rounded-xl p-6">
              <h3 class="text-lg font-bold text-white mb-2">Need Help?</h3>
              <p class="text-sm text-gray-400 mb-4">Can't find what you're looking for?</p>
              <a href="/support" class="text-emerald-400 hover:text-emerald-300 text-sm font-medium">
                Contact Support →
              </a>
            </div>
          </div>
        </div>

        <!-- Content -->
        <div class="md:col-span-3 space-y-12">
          {categories.map((category) => (
            <div id={category.toLowerCase().replace(/\s+/g, '-')}>
              <h2 class="text-3xl font-bold text-white mb-6">{category}</h2>
              <div class="space-y-4">
                {docsByCategory[category].map((doc) => (
                  <a href={`/docs/${doc.slug}`} class="block bg-black/40 backdrop-blur-xl border border-white/10 rounded-xl p-6 hover:border-emerald-500/30 transition-all duration-300">
                    <h3 class="text-xl font-bold text-white mb-2">{doc.data.title}</h3>
                    <p class="text-gray-400">{doc.data.description}</p>
                  </a>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </ContentSection>
</Layout>
