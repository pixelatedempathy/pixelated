---
import "@/styles/modern-enterprise-theme.css";
import ModernHeader from "@/components/layout/ModernHeader.astro";
import ModernFooter from "@/components/layout/ModernFooter.astro";

interface Props {
  title: string
  description?: string
}

const {
  title,
  description = 'Pixelated Empathy - AI-powered Mental Health Training',
} = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Pixelated Empathy</title>
    
    <!-- Open Graph meta tags -->
    <meta property="og:title" content={`${title} | Pixelated Empathy`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    
    <!-- Twitter Card meta tags -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | Pixelated Empathy`} />
    <meta name="twitter:description" content={description} />
    
    <!-- Preload critical fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen bg-gray-950 text-white">
    <!-- Skip to content link for accessibility -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 rounded-md focus:shadow-lg transition-transform bg-emerald-600 text-white"
    >
      Skip to content
    </a>

    <ModernHeader />
    
    <main id="main-content" class="pt-16">
      <slot />
    </main>
    
    <ModernFooter />
  </body>
</html>