---
/**
 * Features Section - Redesigned
 * Flabbergasted: Offset cards, asymmetric layouts, bold colors
 * Mizu: Generous spacing, smooth animations
 * AstroMaxx: Glassmorphism, polished interactions
 * Antfu: Minimal design, clean typography
 */
import AnimatedCounter from './AnimatedCounter.astro'
---

<!-- Mizu: Generous Section Spacing -->
<section class="relative py-32 overflow-hidden">
  
  <!-- Antfu: Subtle Background Pattern -->
  <div class="absolute inset-0" style="background-image: radial-gradient(circle, rgba(255,255,255,0.08) 1px, transparent 1px); background-size: 40px 40px;"></div>
  
  <div class="container mx-auto px-6 relative z-10">
    
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-20">
      <div class="inline-flex items-center gap-2 px-4 py-2 bg-emerald-500/10 border border-emerald-500/20 rounded-full mb-6">
        <svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20">
          <path d="M11 3a1 1 0 10-2 0v1a1 1 0 102 0V3zM15.657 5.757a1 1 0 00-1.414-1.414l-.707.707a1 1 0 001.414 1.414l.707-.707zM18 10a1 1 0 01-1 1h-1a1 1 0 110-2h1a1 1 0 011 1zM5.05 6.464A1 1 0 106.464 5.05l-.707-.707a1 1 0 00-1.414 1.414l.707.707zM5 10a1 1 0 01-1 1H3a1 1 0 110-2h1a1 1 0 011 1zM8 16v-1h4v1a2 2 0 11-4 0zM12 14c.015-.34.208-.646.477-.859a4 4 0 10-4.954 0c.27.213.462.519.476.859h4.002z"></path>
        </svg>
        <span class="text-sm font-medium text-emerald-400">Platform Features</span>
      </div>
      
      <!-- Mizu: Fluid Typography -->
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6">
        Advanced AI Training
      </h2>
      
      <!-- Antfu: Clean Description -->
      <p class="text-lg text-gray-400 max-w-2xl mx-auto">
        Cutting-edge technology meets evidence-based therapeutic training in our comprehensive platform.
      </p>
    </div>

    <!-- Flabbergasted: Asymmetric Feature Grid -->
    <div class="grid lg:grid-cols-2 gap-8 mb-16">
      
      <!-- Feature 1 - Offset Up -->
      <div class="-translate-y-16 fade-in-up">
        <div class="group bg-black/40 backdrop-blur-xl border border-white/10 rounded-2xl p-8 hover:border-red-500/50 hover:-translate-y-2 transition-all duration-300 relative overflow-hidden">
          <!-- Flabbergasted: Color Accent Bar -->
          <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-red-500 to-pink-500"></div>
          
          <div class="w-14 h-14 bg-gradient-to-br from-red-500 to-pink-500 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
            </svg>
          </div>
          
          <div class="flex items-start justify-between mb-4">
            <h3 class="text-2xl font-bold text-white">HIPAA Compliant</h3>
            <span class="px-3 py-1 bg-red-500/20 border border-red-500/30 rounded-full text-xs font-semibold text-red-400">100% Secure</span>
          </div>
          
          <p class="text-gray-400 leading-relaxed mb-6">
            Enterprise-grade security ensuring all training data and interactions meet healthcare privacy standards. <span class="text-gray-500 italic">Because your patients' trust matters.</span>
          </p>
          
          <!-- Antfu: Minimal Feature List -->
          <ul class="space-y-2 text-sm text-gray-500">
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-red-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              End-to-end encryption
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-red-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              Audit logging & compliance
            </li>
          </ul>
        </div>
      </div>

      <!-- Feature 2 - Offset Down -->
      <div class="translate-y-16 fade-in-up" style="animation-delay: 100ms;">
        <div class="group bg-black/40 backdrop-blur-xl border border-white/10 rounded-2xl p-8 hover:border-emerald-500/50 hover:-translate-y-2 transition-all duration-300 relative overflow-hidden">
          <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-emerald-500 to-cyan-500"></div>
          
          <div class="w-14 h-14 bg-gradient-to-br from-emerald-500 to-cyan-500 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 20 20">
              <path d="M2 5a2 2 0 012-2h7a2 2 0 012 2v4a2 2 0 01-2 2H9l-3 3v-3H4a2 2 0 01-2-2V5z"></path>
              <path d="M15 7v2a4 4 0 01-4 4H9.828l-1.766 1.767c.28.149.599.233.938.233h2l3 3v-3h2a2 2 0 002-2V9a2 2 0 00-2-2h-1z"></path>
            </svg>
          </div>
          
          <div class="flex items-start justify-between mb-4">
            <h3 class="text-2xl font-bold text-white">Instant Feedback</h3>
            <span class="px-3 py-1 bg-emerald-500/20 border border-emerald-500/30 rounded-full text-xs font-semibold text-emerald-400">< 100ms</span>
          </div>
          
          <p class="text-gray-400 leading-relaxed mb-6">
            Receive immediate, actionable feedback on your therapeutic responses and communication style. <span class="text-gray-500 italic">No waiting. No guessing. Just growth.</span>
          </p>
          
          <ul class="space-y-2 text-sm text-gray-500">
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              Real-time empathy scoring
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              Technique recommendations
            </li>
          </ul>
        </div>
      </div>

      <!-- Feature 3 - Offset Up -->
      <div class="-translate-y-16 fade-in-up" style="animation-delay: 200ms;">
        <div class="group bg-black/40 backdrop-blur-xl border border-white/10 rounded-2xl p-8 hover:border-blue-500/50 hover:-translate-y-2 transition-all duration-300 relative overflow-hidden">
          <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-blue-500 to-indigo-500"></div>
          
          <div class="w-14 h-14 bg-gradient-to-br from-blue-500 to-indigo-500 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z"></path>
            </svg>
          </div>
          
          <div class="flex items-start justify-between mb-4">
            <h3 class="text-2xl font-bold text-white">AI-Powered Scenarios</h3>
            <span class="px-3 py-1 bg-blue-500/20 border border-blue-500/30 rounded-full text-xs font-semibold text-blue-400">1000+ Scenarios</span>
          </div>
          
          <p class="text-gray-400 leading-relaxed mb-6">
            Practice with realistic AI-generated patient scenarios covering diverse mental health conditions. <span class="text-gray-500 italic">From anxiety to PTSD—we've got you covered.</span>
          </p>
          
          <ul class="space-y-2 text-sm text-gray-500">
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-blue-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              Dynamic difficulty scaling
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-blue-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              Evidence-based responses
            </li>
          </ul>
        </div>
      </div>

      <!-- Feature 4 - Offset Down -->
      <div class="translate-y-16 fade-in-up" style="animation-delay: 300ms;">
        <div class="group bg-black/40 backdrop-blur-xl border border-white/10 rounded-2xl p-8 hover:border-purple-500/50 hover:-translate-y-2 transition-all duration-300 relative overflow-hidden">
          <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-purple-500 to-pink-500"></div>
          
          <div class="w-14 h-14 bg-gradient-to-br from-purple-500 to-pink-500 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 20 20">
              <path d="M2 11a1 1 0 011-1h2a1 1 0 011 1v5a1 1 0 01-1 1H3a1 1 0 01-1-1v-5zM8 7a1 1 0 011-1h2a1 1 0 011 1v9a1 1 0 01-1 1H9a1 1 0 01-1-1V7zM14 4a1 1 0 011-1h2a1 1 0 011 1v12a1 1 0 01-1 1h-2a1 1 0 01-1-1V4z"></path>
            </svg>
          </div>
          
          <div class="flex items-start justify-between mb-4">
            <h3 class="text-2xl font-bold text-white">Progress Tracking</h3>
            <span class="px-3 py-1 bg-purple-500/20 border border-purple-500/30 rounded-full text-xs font-semibold text-purple-400">Real-time</span>
          </div>
          
          <p class="text-gray-400 leading-relaxed mb-6">
            Comprehensive analytics and insights to monitor your skill development over time.
          </p>
          
          <ul class="space-y-2 text-sm text-gray-500">
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-purple-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              Detailed performance metrics
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-purple-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              Personalized learning paths
            </li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Flabbergasted: Bold Stats Section with Diagonal Background -->
    <div class="relative mt-32">
      <!-- Diagonal Background -->
      <div class="absolute inset-0 bg-gradient-to-r from-emerald-500/10 to-cyan-500/10 transform -skew-y-6"></div>
      
      <div class="relative py-16">
        <div class="text-center mb-12">
          <div class="inline-flex items-center gap-2 px-4 py-2 bg-cyan-500/10 border border-cyan-500/20 rounded-full mb-4">
            <svg class="w-4 h-4 text-cyan-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z"></path>
            </svg>
            <span class="text-sm font-medium text-cyan-400">Trusted by Professionals</span>
          </div>
          <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">
            Leading Healthcare Institutions
          </h2>
          <p class="text-gray-400 max-w-2xl mx-auto">
            Join thousands of mental health professionals who trust our platform
          </p>
        </div>

        <!-- Flabbergasted: Colorful Stats Grid -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
          <div class="text-center fade-in-up">
            <div class="w-16 h-16 bg-gradient-to-br from-cyan-500 to-blue-500 rounded-2xl flex items-center justify-center mx-auto mb-4 hover:scale-110 transition-transform">
              <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path d="M10.394 2.08a1 1 0 00-.788 0l-7 3a1 1 0 000 1.84L5.25 8.051a.999.999 0 01.356-.257l4-1.714a1 1 0 11.788 1.838L7.667 9.088l1.94.831a1 1 0 00.787 0l7-3a1 1 0 000-1.838l-7-3zM3.31 9.397L5 10.12v4.102a8.969 8.969 0 00-1.05-.174 1 1 0 01-.89-.89 11.115 11.115 0 01.25-3.762zM9.3 16.573A9.026 9.026 0 007 14.935v-3.957l1.818.78a3 3 0 002.364 0l5.508-2.361a11.026 11.026 0 01.25 3.762 1 1 0 01-.89.89 8.968 8.968 0 00-5.35 2.524 1 1 0 01-1.4 0zM6 18a1 1 0 001-1v-2.065a8.935 8.935 0 00-2-.712V17a1 1 0 001 1z"></path>
              </svg>
            </div>
            <div class="text-4xl font-bold text-white mb-2">
              <AnimatedCounter value={500} suffix="+" className="text-4xl font-bold text-white" />
            </div>
            <div class="text-sm text-gray-400">Healthcare Institutions</div>
          </div>

          <div class="text-center fade-in-up" style="animation-delay: 100ms;">
            <div class="w-16 h-16 bg-gradient-to-br from-purple-500 to-pink-500 rounded-2xl flex items-center justify-center mx-auto mb-4 hover:scale-110 transition-transform">
              <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z"></path>
              </svg>
            </div>
            <div class="text-4xl font-bold text-white mb-2">
              <AnimatedCounter value={135000} suffix="+" className="text-4xl font-bold text-white" />
            </div>
            <div class="text-sm text-gray-400">Trained Professionals</div>
          </div>

          <div class="text-center fade-in-up" style="animation-delay: 200ms;">
            <div class="w-16 h-16 bg-gradient-to-br from-amber-500 to-orange-500 rounded-2xl flex items-center justify-center mx-auto mb-4 hover:scale-110 transition-transform">
              <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
              </svg>
            </div>
            <div class="text-4xl font-bold text-white mb-2">
              <AnimatedCounter value={98} suffix="%" className="text-4xl font-bold text-white" />
            </div>
            <div class="text-sm text-gray-400">Satisfaction Rate</div>
          </div>

          <div class="text-center fade-in-up" style="animation-delay: 300ms;">
            <div class="w-16 h-16 bg-gradient-to-br from-pink-500 to-rose-500 rounded-2xl flex items-center justify-center mx-auto mb-4 hover:scale-110 transition-transform">
              <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"></path>
              </svg>
            </div>
            <div class="text-4xl font-bold text-white mb-2">24/7</div>
            <div class="text-sm text-gray-400">Platform Availability</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .fade-in-up {
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
  }
</style>
