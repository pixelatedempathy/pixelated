---
import Layout from '../layouts/Layout.astro'
---

<Layout title="Psychology Frameworks Demo - Pixelated Empathy">
  <main class="min-h-screen bg-black text-white pt-24 pb-16">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-12">
        <h1 class="text-4xl font-bold mb-4">
          <span class="bg-gradient-to-r from-emerald-400 to-teal-400 bg-clip-text text-transparent">
            Psychology Frameworks Demo
          </span>
        </h1>
        <p class="text-xl text-gray-300">
          Adolescent therapy and psychological framework training
        </p>
      </div>
      
      <div id="psychology-demo-container"></div>
    </div>
  </main>
</Layout>

<script>
  import PsychologyFrameworksDemo from '../components/demo/PsychologyFrameworksDemo'
  import { createRoot } from 'react-dom/client'
  import { createElement } from 'react'

  const container = document.getElementById('psychology-demo-container')
  if (container) {
    const root = createRoot(container)
    root.render(createElement(PsychologyFrameworksDemo))
  }
</script>
