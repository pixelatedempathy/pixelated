---
/**
 * CTA Section - Redesigned
 * Flabbergasted: Bold, personality-driven design
 * Mizu: Smooth animations and generous spacing
 * AstroMaxx: Glassmorphism and polished effects
 */
---

<section class="relative py-32 overflow-hidden">
  
  <!-- Flabbergasted: Bold Gradient Background -->
  <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/10 via-cyan-500/10 to-purple-500/10"></div>
  <div class="absolute inset-0" style="background-image: radial-gradient(circle, rgba(255,255,255,0.08) 1px, transparent 1px); background-size: 32px 32px;"></div>
  
  <!-- Flabbergasted: Playful Floating Shapes -->
  <div class="absolute top-10 left-10 w-72 h-72 bg-gradient-to-br from-emerald-500/20 to-cyan-500/20 rounded-full blur-3xl animate-pulse"></div>
  <div class="absolute bottom-10 right-10 w-96 h-96 bg-gradient-to-br from-purple-500/20 to-pink-500/20 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>
  
  <div class="container mx-auto px-6 relative z-10">
    <div class="max-w-4xl mx-auto text-center">
      
      <!-- Mizu: Fluid Typography -->
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight">
        Ready to Transform<br/>
        <span class="bg-gradient-to-r from-emerald-400 via-cyan-400 to-purple-400 bg-clip-text text-transparent">
          Mental Health Training?
        </span>
      </h2>
      
      <!-- Antfu: Clean Description -->
      <p class="text-lg md:text-xl text-gray-300 mb-12 max-w-2xl mx-auto leading-relaxed">
        Join thousands of mental health professionals who are already using our AI-powered platform to enhance their skills and improve patient outcomes.
      </p>

      <!-- Flabbergasted: Bold CTA Buttons -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-8">
        <a href="/get-started" class="group w-full sm:w-auto px-10 py-5 bg-gradient-to-r from-emerald-500 to-cyan-500 text-white text-lg font-bold rounded-xl hover:shadow-2xl hover:shadow-emerald-500/50 hover:-translate-y-2 hover:scale-105 transition-all duration-300 flex items-center justify-center gap-3">
          Start Free Trial
          <svg class="w-5 h-5 group-hover:translate-x-2 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
          </svg>
        </a>
        <a href="/demo" class="w-full sm:w-auto px-10 py-5 bg-white/5 backdrop-blur-sm border-2 border-white/20 text-white text-lg font-bold rounded-xl hover:bg-white/10 hover:border-white/30 hover:-translate-y-2 transition-all duration-300">
          Schedule Demo
        </a>
      </div>

      <!-- Flabbergasted: Witty Microcopy -->
      <p class="text-sm text-gray-500">
        No credit card required • 14-day free trial • Cancel anytime
      </p>
    </div>
  </div>
</section>
