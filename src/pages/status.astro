---
export const prerender = true

import Layout from '@/layouts/Layout.astro'
import PageHero from '@/components/ui/PageHero.astro'
import ContentSection from '@/components/ui/ContentSection.astro'
import StatsGrid from '@/components/ui/StatsGrid.astro'
import FormInput from '@/components/ui/FormInput.astro'

const services = [
  {
    name: "API Gateway",
    status: "operational",
    description: "Core API endpoints and authentication"
  },
  {
    name: "Training Engine",
    status: "operational", 
    description: "AI simulation and training modules"
  },
  {
    name: "Database",
    status: "operational",
    description: "User data and session storage"
  },
  {
    name: "File Storage",
    status: "operational",
    description: "Training materials and media files"
  },
  {
    name: "Analytics",
    status: "operational",
    description: "Performance tracking and reporting"
  }
]

const statusMetrics = [
  { label: "30-day Uptime", value: "--", color: "emerald" },
  { label: "Avg Response Time", value: "--", color: "white" },
  { label: "Active Incidents", value: "0", color: "white" }
]
---

<Layout title="System Status - Pixelated Empathy">
  <PageHero
    badge="All Systems Operational"
    title="System Status"
    subtitle="Real-time status of our platform services and infrastructure."
    gradient={true}
  />

  <!-- Overall Status -->
  <ContentSection>
    <div class="bg-black/40 backdrop-blur-xl border border-white/10 rounded-2xl p-8 mb-12">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-white">Platform Status</h2>
        <div class="flex items-center gap-2 px-4 py-2 bg-green-500/20 border border-green-500/30 rounded-full">
          <div class="w-3 h-3 bg-green-500 rounded-full"></div>
          <span class="text-green-400 font-medium">Operational</span>
        </div>
      </div>
      <StatsGrid stats={statusMetrics} columns={3} />
    </div>

    <!-- Service Status -->
    <h2 class="text-3xl font-bold text-center mb-12">
      <span class="bg-gradient-to-r from-emerald-400 to-cyan-400 bg-clip-text text-transparent">
        Service Status
      </span>
    </h2>
    
    <div class="space-y-4 max-w-4xl mx-auto">
      {services.map((service) => (
        <div class="bg-black/40 backdrop-blur-xl border border-white/10 rounded-xl p-6 hover:border-emerald-500/30 transition-all duration-300">
          <div class="flex items-center justify-between">
            <div>
              <h3 class="text-xl font-bold text-white mb-1">{service.name}</h3>
              <p class="text-gray-400 text-sm">{service.description}</p>
            </div>
            <div class="flex items-center gap-2 px-4 py-2 bg-green-500/20 border border-green-500/30 rounded-full">
              <div class="w-2 h-2 bg-green-500 rounded-full"></div>
              <span class="text-green-400 text-sm font-medium">Operational</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </ContentSection>

  <!-- Incident History -->
  <ContentSection diagonal={true}>
    <h2 class="text-3xl font-bold text-center mb-12">
      <span class="bg-gradient-to-r from-purple-400 to-pink-400 bg-clip-text text-transparent">
        Incident History
      </span>
    </h2>
    
    <div class="max-w-4xl mx-auto text-center">
      <div class="bg-black/40 backdrop-blur-xl border border-white/10 rounded-xl p-12">
        <div class="text-6xl mb-4">✅</div>
        <h3 class="text-2xl font-bold text-white mb-2">No Recent Incidents</h3>
        <p class="text-gray-300">
          All systems have been running smoothly. We'll post updates here if any issues arise.
        </p>
      </div>
    </div>
  </ContentSection>

  <!-- Subscribe to Updates -->
  <ContentSection>
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-4xl font-bold mb-6">
        <span class="bg-gradient-to-r from-emerald-400 to-cyan-400 bg-clip-text text-transparent">
          Subscribe to Updates
        </span>
      </h2>
      <p class="text-xl text-gray-300 mb-8">
        Get notified about system status changes and scheduled maintenance.
      </p>
      
      <div class="bg-black/40 backdrop-blur-xl border border-white/10 rounded-2xl p-8">
        <form class="flex flex-col sm:flex-row gap-4">
          <div class="flex-1">
            <FormInput
              name="email"
              type="email"
              placeholder="your@email.com"
              required={true}
            />
          </div>
          <button 
            type="submit"
            class="px-8 py-3 bg-gradient-to-r from-emerald-500 to-cyan-500 hover:from-emerald-600 hover:to-cyan-600 text-black font-bold rounded-lg transition-all duration-200 transform hover:scale-105 whitespace-nowrap"
          >
            Subscribe
          </button>
        </form>
      </div>
    </div>
  </ContentSection>
</Layout>
