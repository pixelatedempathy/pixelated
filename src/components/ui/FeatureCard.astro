---
/**
 * Reusable Feature Card Component
 * Applies glassmorphism and hover effects
 */
interface Props {
  title: string
  description: string
  icon?: string
  color?: 'red' | 'cyan' | 'blue' | 'purple' | 'emerald' | 'orange' | 'pink'
  offset?: 'up' | 'down' | 'none'
}

const { title, description, icon, color = 'emerald', offset = 'none' } = Astro.props

const colorClasses = {
  red: 'from-red-500 to-pink-500 border-red-500/50',
  cyan: 'from-emerald-500 to-cyan-500 border-cyan-500/50',
  blue: 'from-blue-500 to-indigo-500 border-blue-500/50',
  purple: 'from-purple-500 to-pink-500 border-purple-500/50',
  emerald: 'from-emerald-500 to-cyan-500 border-emerald-500/50',
  orange: 'from-amber-500 to-orange-500 border-orange-500/50',
  pink: 'from-pink-500 to-rose-500 border-pink-500/50',
}

const offsetClasses = {
  up: '-translate-y-16',
  down: 'translate-y-16',
  none: '',
}
---

<div class={`${offsetClasses[offset]} fade-in-up`}>
  <div class="group bg-black/40 backdrop-blur-xl border border-white/10 rounded-2xl p-8 hover:border-white/20 hover:-translate-y-2 transition-all duration-300 relative overflow-hidden h-full">
    <!-- Flabbergasted: Color Accent Bar -->
    <div class={`absolute top-0 left-0 right-0 h-1 bg-gradient-to-r ${colorClasses[color]}`}></div>
    
    {icon && (
      <div class={`w-16 h-16 bg-gradient-to-br ${colorClasses[color]} rounded-xl flex items-center justify-center mb-6 group-hover:scale-105 group-hover:rotate-3 transition-all duration-300 relative`}>
        <div class={`absolute inset-0 bg-gradient-to-br ${colorClasses[color]} rounded-xl blur-lg opacity-0 group-hover:opacity-50 transition-opacity duration-300`}></div>
        <div class="relative" set:html={icon} />
      </div>
    )}
    
    <h3 class="text-2xl font-bold text-white mb-4">{title}</h3>
    <p class="text-gray-400 leading-relaxed">{description}</p>
    
    <slot />
  </div>
</div>
