---
export interface Props {
  value: string
  label: string
  duration?: number
  suffix?: string
}

const { value, label, duration = 2000, suffix = '' } = Astro.props

// Handle placeholder values that shouldn't animate
const isPlaceholder = value === '--' || !value.match(/\d/)
const displayValue = isPlaceholder ? value : value
const numericValue = isPlaceholder ? 0 : parseInt(value.replace(/[^\d]/g, ''))
const hasPlus = value.includes('+')
const hasPercent = value.includes('%')
---

<div class="animated-counter" data-target={numericValue} data-duration={duration} data-suffix={suffix} data-has-plus={hasPlus} data-has-percent={hasPercent} data-is-placeholder={isPlaceholder} data-display-value={displayValue}>
  <div class="text-3xl font-bold text-white counter-value">{displayValue}</div>
  <div class="text-sm text-gray-400">{label}</div>
</div>

<script>
  class AnimatedCounter {
    private element: HTMLElement
    private target: number
    private duration: number
    private suffix: string
    private hasPlus: boolean
    private hasPercent: boolean
    private isPlaceholder: boolean
    private displayValue: string
    private observer: IntersectionObserver
    private hasAnimated: boolean = false

    constructor(element: HTMLElement) {
      this.element = element
      this.target = parseInt(element.dataset.target || '0')
      this.duration = parseInt(element.dataset.duration || '2000')
      this.suffix = element.dataset.suffix || ''
      this.hasPlus = element.dataset.hasPlus === 'true'
      this.hasPercent = element.dataset.hasPercent === 'true'
      this.isPlaceholder = element.dataset.isPlaceholder === 'true'
      this.displayValue = element.dataset.displayValue || ''

      // Skip animation for placeholders
      if (!this.isPlaceholder) {
        this.setupIntersectionObserver()
      }
    }

    private setupIntersectionObserver() {
      this.observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting && !this.hasAnimated) {
              this.animate()
              this.hasAnimated = true
            }
          })
        },
        {
          threshold: 0.5,
          rootMargin: '0px 0px -100px 0px'
        }
      )

      this.observer.observe(this.element)
    }

    private animate() {
      const counterElement = this.element.querySelector('.counter-value') as HTMLElement
      if (!counterElement) return

      const startTime = performance.now()
      const startValue = 0

      const updateCounter = (currentTime: number) => {
        const elapsed = currentTime - startTime
        const progress = Math.min(elapsed / this.duration, 1)
        
        // Easing function (ease-out cubic)
        const easeOut = 1 - Math.pow(1 - progress, 3)
        const currentValue = Math.floor(startValue + (this.target - startValue) * easeOut)

        let displayValue = currentValue.toString()
        if (this.hasPlus) displayValue += '+'
        if (this.hasPercent) displayValue += '%'
        if (this.suffix) displayValue += this.suffix

        counterElement.textContent = displayValue

        if (progress < 1) {
          requestAnimationFrame(updateCounter)
        }
      }

      requestAnimationFrame(updateCounter)
    }

    public destroy() {
      if (this.observer) {
        this.observer.disconnect()
      }
    }
  }

  // Initialize counters when page loads
  document.addEventListener('astro:page-load', () => {
    const counters = document.querySelectorAll('.animated-counter')
    counters.forEach((counter) => {
      new AnimatedCounter(counter as HTMLElement)
    })
  })
</script>

<style>
  .animated-counter {
    transition: transform 0.3s ease;
  }

  .animated-counter:hover {
    transform: translateY(-2px);
  }

  .counter-value {
    font-variant-numeric: tabular-nums;
    font-feature-settings: 'tnum';
  }
</style>
