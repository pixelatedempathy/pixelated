---
// Hybrid Hero - Streamline minimalism + Mizu elegance
interface Props {
  title?: string;
  subtitle?: string;
  description?: string;
  primaryCTA?: {
    text: string;
    href: string;
  };
  secondaryCTA?: {
    text: string;
    href: string;
  };
}

const {
  title = "Enterprise Mental Health AI",
  subtitle = "Clinical-grade platform designed for healthcare organizations",
  description = "Deploy evidence-based AI-powered mental health solutions with enterprise security, seamless EHR integration, and comprehensive compliance frameworks.",
  primaryCTA = { text: "Request Demo", href: "/demo" },
  secondaryCTA = { text: "View Documentation", href: "/docs" }
} = Astro.props;
---

<section class="hybrid-hero">
  <div class="container-lg">
    <div class="hero-grid">
      <!-- Enhanced content with Mizu spacing -->
      <div class="hero-content">
        <!-- Elegant status indicator -->
        <div class="status-card">
          <div class="status-indicator">
            <div class="pulse-dot"></div>
            <span>Production Ready</span>
          </div>
          <div class="compliance-badges">
            <span class="badge">SOC 2</span>
            <span class="badge">HIPAA</span>
            <span class="badge">GDPR</span>
          </div>
        </div>

        <!-- Enhanced typography hierarchy -->
        <div class="hero-text">
          <h1 class="hero-title">
            <span class="title-main">{title}</span>
            <span class="title-accent text-gradient">{subtitle}</span>
          </h1>
          
          <p class="hero-description">{description}</p>
        </div>

        <!-- Refined CTA layout -->
        <div class="hero-actions">
          <a href={primaryCTA.href} class="btn btn-primary btn-lg">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
              <line x1="16" y1="2" x2="16" y2="6"/>
              <line x1="8" y1="2" x2="8" y2="6"/>
              <line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
            {primaryCTA.text}
          </a>
          <a href={secondaryCTA.href} class="btn btn-secondary btn-lg">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14,2 14,8 20,8"/>
              <line x1="16" y1="13" x2="8" y2="13"/>
              <line x1="16" y1="17" x2="8" y2="17"/>
              <polyline points="10,9 9,9 8,9"/>
            </svg>
            {secondaryCTA.text}
          </a>
        </div>

        <!-- Enhanced metrics with elegant cards -->
        <div class="metrics-grid">
          <div class="metric-card">
            <div class="metric-value">500K+</div>
            <div class="metric-label">Clinical Sessions</div>
            <div class="metric-trend">↗ 23% this quarter</div>
          </div>
          <div class="metric-card">
            <div class="metric-value">99.9%</div>
            <div class="metric-label">Platform Uptime</div>
            <div class="metric-trend">SLA Guaranteed</div>
          </div>
          <div class="metric-card">
            <div class="metric-value">&lt;150ms</div>
            <div class="metric-label">API Response</div>
            <div class="metric-trend">Global Average</div>
          </div>
        </div>
      </div>

      <!-- Enhanced terminal visual with Mizu elegance -->
      <div class="hero-visual">
        <div class="visual-container">
          <!-- Floating elements for depth -->
          <div class="floating-elements">
            <div class="float-card float-1"></div>
            <div class="float-card float-2"></div>
            <div class="float-card float-3"></div>
          </div>

          <!-- Enhanced terminal window -->
          <div class="terminal-elegant">
            <div class="terminal-header">
              <div class="terminal-controls">
                <div class="control control-close"></div>
                <div class="control control-minimize"></div>
                <div class="control control-maximize"></div>
              </div>
              <div class="terminal-title">pixelated-empathy-cli</div>
              <div class="terminal-status">
                <div class="status-dot"></div>
                <span>Connected</span>
              </div>
            </div>
            
            <div class="terminal-content">
              <div class="terminal-line">
                <span class="prompt">$</span>
                <span class="command">pe analyze --input="Patient session data" --model=clinical-v2</span>
              </div>
              <div class="terminal-line response">
                <span class="json-key">"status"</span>: <span class="json-string">"success"</span>,
              </div>
              <div class="terminal-line response">
                <span class="json-key">"confidence"</span>: <span class="json-number">0.94</span>,
              </div>
              <div class="terminal-line response">
                <span class="json-key">"risk_assessment"</span>: <span class="json-string">"low"</span>,
              </div>
              <div class="terminal-line response">
                <span class="json-key">"recommendations"</span>: [
              </div>
              <div class="terminal-line response indent">
                <span class="json-string">"cognitive_behavioral_therapy"</span>,
              </div>
              <div class="terminal-line response indent">
                <span class="json-string">"mindfulness_techniques"</span>
              </div>
              <div class="terminal-line response">
                ]
              </div>
              <div class="terminal-line">
                <span class="prompt">$</span>
                <span class="cursor">_</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Subtle background enhancement -->
  <div class="hero-background">
    <div class="gradient-blur gradient-1"></div>
    <div class="gradient-blur gradient-2"></div>
  </div>
</section>

<style>
  .hybrid-hero {
    position: relative;
    padding: var(--space-32) 0 var(--space-40);
    background: var(--bg-primary);
    overflow: hidden;
    min-height: 100vh;
    display: flex;
    align-items: center;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-20);
    align-items: center;
    position: relative;
    z-index: 10;
  }

  /* Enhanced content styling */
  .hero-content {
    max-width: 600px;
  }

  .status-card {
    background: var(--bg-card);
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-2xl);
    padding: var(--space-4) var(--space-6);
    margin-bottom: var(--space-10);
    display: flex;
    align-items: center;
    justify-content: space-between;
    backdrop-filter: blur(16px);
  }

  .status-indicator {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--text-secondary);
    font-weight: 500;
  }

  .pulse-dot {
    width: 8px;
    height: 8px;
    background: #10b981;
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.7; transform: scale(1.1); }
  }

  .compliance-badges {
    display: flex;
    gap: var(--space-2);
  }

  .badge {
    padding: var(--space-1) var(--space-2);
    background: var(--accent-muted);
    color: var(--accent);
    font-size: var(--text-xs);
    font-weight: 600;
    border-radius: var(--radius-md);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .hero-text {
    margin-bottom: var(--space-12);
  }

  .hero-title {
    margin-bottom: var(--space-8);
    line-height: var(--leading-none);
  }

  .title-main {
    display: block;
    font-size: var(--text-7xl);
    font-weight: 800;
    margin-bottom: var(--space-2);
  }

  .title-accent {
    display: block;
    font-size: var(--text-5xl);
    font-weight: 600;
    opacity: 0.9;
  }

  .hero-description {
    font-size: var(--text-xl);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    max-width: 520px;
  }

  .hero-actions {
    display: flex;
    gap: var(--space-4);
    margin-bottom: var(--space-16);
  }

  /* Enhanced metrics */
  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
    padding-top: var(--space-8);
    border-top: 1px solid var(--border-primary);
  }

  .metric-card {
    text-align: center;
    padding: var(--space-4);
    background: var(--bg-card);
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-xl);
    transition: all var(--transition-normal);
    backdrop-filter: blur(16px);
  }

  .metric-card:hover {
    border-color: var(--border-secondary);
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }

  .metric-value {
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--text-primary);
    font-family: var(--font-mono);
    line-height: var(--leading-none);
    margin-bottom: var(--space-1);
  }

  .metric-label {
    font-size: var(--text-xs);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-1);
  }

  .metric-trend {
    font-size: var(--text-xs);
    color: var(--accent);
    font-weight: 500;
  }

  /* Enhanced visual section */
  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
  }

  .visual-container {
    position: relative;
    width: 100%;
    max-width: 520px;
  }

  .floating-elements {
    position: absolute;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .float-card {
    position: absolute;
    background: var(--bg-card);
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-xl);
    backdrop-filter: blur(16px);
    opacity: 0.6;
  }

  .float-1 {
    width: 80px;
    height: 60px;
    top: 10%;
    right: -10%;
    animation: float 6s ease-in-out infinite;
  }

  .float-2 {
    width: 60px;
    height: 40px;
    top: 60%;
    left: -15%;
    animation: float 8s ease-in-out infinite reverse;
  }

  .float-3 {
    width: 100px;
    height: 80px;
    bottom: 20%;
    right: 10%;
    animation: float 7s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    50% { transform: translateY(-15px) rotate(3deg); }
  }

  .terminal-elegant {
    background: var(--bg-elevated);
    border: 1px solid var(--border-secondary);
    border-radius: var(--radius-3xl);
    box-shadow: var(--shadow-2xl);
    overflow: hidden;
    backdrop-filter: blur(16px);
  }

  .terminal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-4) var(--space-6);
    background: var(--bg-tertiary);
    border-bottom: 1px solid var(--border-primary);
  }

  .terminal-controls {
    display: flex;
    gap: var(--space-2);
  }

  .control {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .control-close { background: #ff5f57; }
  .control-minimize { background: #ffbd2e; }
  .control-maximize { background: #28ca42; }

  .terminal-title {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-weight: 500;
  }

  .terminal-status {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .status-dot {
    width: 6px;
    height: 6px;
    background: #10b981;
    border-radius: 50%;
  }

  .terminal-content {
    padding: var(--space-6);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
  }

  .terminal-line {
    margin-bottom: var(--space-2);
  }

  .prompt {
    color: var(--accent);
    margin-right: var(--space-2);
  }

  .command {
    color: var(--text-primary);
  }

  .response {
    color: var(--text-secondary);
    padding-left: var(--space-6);
  }

  .indent {
    padding-left: var(--space-12);
  }

  .json-key { color: #7dd3fc; }
  .json-string { color: #86efac; }
  .json-number { color: #fbbf24; }

  .cursor {
    color: var(--accent);
    animation: blink 1s infinite;
  }

  @keyframes blink {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0; }
  }

  /* Subtle background */
  .hero-background {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
  }

  .gradient-blur {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
    opacity: 0.1;
  }

  .gradient-1 {
    width: 600px;
    height: 600px;
    top: -300px;
    right: -300px;
    background: linear-gradient(135deg, var(--accent), #8b5cf6);
  }

  .gradient-2 {
    width: 400px;
    height: 400px;
    bottom: -200px;
    left: -200px;
    background: linear-gradient(135deg, #10b981, var(--accent));
  }

  /* Responsive design */
  @media (max-width: 1024px) {
    .hybrid-hero {
      padding: var(--space-20) 0 var(--space-24);
    }

    .hero-grid {
      grid-template-columns: 1fr;
      gap: var(--space-16);
      text-align: center;
    }

    .hero-content {
      max-width: 700px;
      margin: 0 auto;
    }

    .metrics-grid {
      justify-content: center;
    }
  }

  @media (max-width: 768px) {
    .hybrid-hero {
      padding: var(--space-16) 0 var(--space-20);
    }

    .title-main {
      font-size: var(--text-5xl);
    }

    .title-accent {
      font-size: var(--text-4xl);
    }

    .hero-description {
      font-size: var(--text-lg);
    }

    .hero-actions {
      flex-direction: column;
      align-items: center;
    }

    .hero-actions .btn {
      width: 100%;
      max-width: 280px;
    }

    .metrics-grid {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }

    .status-card {
      flex-direction: column;
      gap: var(--space-3);
      text-align: center;
    }

    .terminal-content {
      font-size: var(--text-xs);
      padding: var(--space-4);
    }

    .floating-elements {
      display: none; /* Hide on mobile for performance */
    }
  }
</style>