---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Container from '@/components/tailus/Container.astro'
---

<BaseLayout
  title="Technical Specifications - Pixelated Empathy"
  description="Detailed technical specifications, performance benchmarks, and system requirements for enterprise deployment"
  bgType="dark"
>
  <!-- Technical Specs Hero -->
  <section class="py-20">
    <Container>
      <div class="text-center">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-blue-500/10 text-blue-500 rounded-full text-sm font-medium mb-8">
          Technical Documentation
        </div>

        <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold text-gray-900 dark:text-white mb-6">
          Enterprise Technical
          <span class="text-blue-500">Specifications</span>
        </h1>

        <p class="text-xl text-gray-600 dark:text-gray-300 max-w-3xl mx-auto mb-8">
          Comprehensive technical documentation including system requirements, performance benchmarks,
          integration APIs, and deployment configurations for enterprise environments.
        </p>
      </div>
    </Container>
  </section>

  <!-- System Requirements -->
  <section class="py-20 bg-gray-50 dark:bg-gray-900">
    <Container>
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-12 text-center">System Requirements</h2>

      <div class="grid lg:grid-cols-2 gap-12">
        <!-- Frontend Requirements -->
        <div class="bg-white dark:bg-gray-800 p-8 rounded-2xl border border-gray-200 dark:border-gray-700">
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-6 flex items-center gap-3">
            <div class="w-8 h-8 bg-blue-500/10 rounded-lg flex items-center justify-center">
              <svg class="w-4 h-4 text-blue-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M3 4a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1V4zM3 10a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H4a1 1 0 01-1-1v-6zM14 9a1 1 0 00-1 1v5a1 1 0 001 1h2a1 1 0 001-1v-5a1 1 0 00-1-1h-2z" clip-rule="evenodd" />
              </svg>
            </div>
            Frontend Requirements
          </h3>

          <div class="space-y-4">
            <div>
              <h4 class="font-medium text-gray-900 dark:text-white mb-2">Browser Support</h4>
              <ul class="text-sm text-gray-600 dark:text-gray-300 space-y-1">
                <li>• Chrome 90+ (Recommended)</li>
                <li>• Firefox 88+</li>
                <li>• Safari 14+</li>
                <li>• Edge 90+</li>
              </ul>
            </div>

            <div>
              <h4 class="font-medium text-gray-900 dark:text-white mb-2">Performance Requirements</h4>
              <ul class="text-sm text-gray-600 dark:text-gray-300 space-y-1">
                <li>• First Contentful Paint: &lt;1.5s</li>
                <li>• Largest Contentful Paint: &lt;2.5s</li>
                <li>• Time to Interactive: &lt;3.5s</li>
                <li>• Cumulative Layout Shift: &lt;0.1</li>
              </ul>
            </div>

            <div>
              <h4 class="font-medium text-gray-900 dark:text-white mb-2">Network Requirements</h4>
              <ul class="text-sm text-gray-600 dark:text-gray-300 space-y-1">
                <li>• HTTPS/TLS 1.3 minimum</li>
                <li>• WebSocket support for real-time features</li>
                <li>• Service Worker support for offline functionality</li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Backend Requirements -->
        <div class="bg-white dark:bg-gray-800 p-8 rounded-2xl border border-gray-200 dark:border-gray-700">
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-6 flex items-center gap-3">
            <div class="w-8 h-8 bg-purple-500/10 rounded-lg flex items-center justify-center">
              <svg class="w-4 h-4 text-purple-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M2 5a2 2 0 012-2h12a2 2 0 012 2v10a2 2 0 01-2 2H4a2 2 0 01-2-2V5zm14 2H4v6h12V7z" clip-rule="evenodd" />
              </svg>
            </div>
            Backend Requirements
          </h3>

          <div class="space-y-4">
            <div>
              <h4 class="font-medium text-gray-900 dark:text-white mb-2">Runtime Environment</h4>
              <ul class="text-sm text-gray-600 dark:text-gray-300 space-y-1">
                <li>• Node.js 24+ (LTS)</li>
                <li>• Cloudflare Workers (Serverless)</li>
                <li>• TypeScript 5.0+</li>
                <li>• ES2022+ JavaScript features</li>
              </ul>
            </div>

            <div>
              <h4 class="font-medium text-gray-900 dark:text-white mb-2">Database Requirements</h4>
              <ul class="text-sm text-gray-600 dark:text-gray-300 space-y-1">
                <li>• MongoDB 6.0+ (Primary)</li>
                <li>• PostgreSQL 14+ (Analytics)</li>
                <li>• Redis 7.0+ (Caching/Sessions)</li>
                <li>• Backup and replication support</li>
              </ul>
            </div>

            <div>
              <h4 class="font-medium text-gray-900 dark:text-white mb-2">Memory & Storage</h4>
              <ul class="text-sm text-gray-600 dark:text-gray-300 space-y-1">
                <li>• Minimum 512MB RAM per instance</li>
                <li>• SSD storage for optimal performance</li>
                <li>• CDN integration for static assets</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- Performance Benchmarks -->
  <section class="py-20">
    <Container>
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-12 text-center">Performance Benchmarks</h2>

      <div class="grid lg:grid-cols-3 gap-8 mb-12">
        <div class="bg-white dark:bg-gray-800 p-6 rounded-2xl border border-gray-200 dark:border-gray-700">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Response Times</h3>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-300">API Endpoints</span>
              <span class="font-semibold text-emerald-500">&lt;50ms</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-300">Database Queries</span>
              <span class="font-semibold text-emerald-500">&lt;100ms</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-300">Page Rendering</span>
              <span class="font-semibold text-emerald-500">&lt;200ms</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-300">AI Processing</span>
              <span class="font-semibold text-emerald-500">&lt;500ms</span>
            </div>
          </div>
        </div>

        <div class="bg-white dark:bg-gray-800 p-6 rounded-2xl border border-gray-200 dark:border-gray-700">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Scalability Metrics</h3>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-300">Concurrent Users</span>
              <span class="font-semibold text-blue-500">100K+</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-300">Requests/Second</span>
              <span class="font-semibold text-blue-500">10K+</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-300">Data Storage</span>
              <span class="font-semibold text-blue-500">100TB+</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-300">Global Regions</span>
              <span class="font-semibold text-blue-500">300+</span>
            </div>
          </div>
        </div>

        <div class="bg-white dark:bg-gray-800 p-6 rounded-2xl border border-gray-200 dark:border-gray-700">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Reliability Metrics</h3>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-300">Uptime SLA</span>
              <span class="font-semibold text-purple-500">99.9%</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-300">Error Rate</span>
              <span class="font-semibold text-purple-500">&lt;0.1%</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-300">Recovery Time</span>
              <span class="font-semibold text-purple-500">&lt;5min</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-600 dark:text-gray-300">MTBF</span>
              <span class="font-semibold text-purple-500">&gt;30 days</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Load Testing Results -->
      <div class="bg-white dark:bg-gray-800 p-8 rounded-2xl border border-gray-200 dark:border-gray-700">
        <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-6">Load Testing Results</h3>

        <div class="grid md:grid-cols-2 gap-8">
          <div>
            <h4 class="font-medium text-gray-900 dark:text-white mb-4">Concurrent User Testing</h4>
            <div class="space-y-3">
              <div class="flex items-center gap-3">
                <div class="w-4 h-4 bg-emerald-500 rounded-full"></div>
                <span class="text-sm text-gray-600 dark:text-gray-300">1,000 users: 95ms avg response</span>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-4 h-4 bg-emerald-500 rounded-full"></div>
                <span class="text-sm text-gray-600 dark:text-gray-300">10,000 users: 120ms avg response</span>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-4 h-4 bg-emerald-500 rounded-full"></div>
                <span class="text-sm text-gray-600 dark:text-gray-300">50,000 users: 180ms avg response</span>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-4 h-4 bg-yellow-500 rounded-full"></div>
                <span class="text-sm text-gray-600 dark:text-gray-300">100,000 users: 250ms avg response</span>
              </div>
            </div>
          </div>

          <div>
            <h4 class="font-medium text-gray-900 dark:text-white mb-4">Stress Testing Results</h4>
            <div class="space-y-3">
              <div class="flex items-center gap-3">
                <div class="w-4 h-4 bg-emerald-500 rounded-full"></div>
                <span class="text-sm text-gray-600 dark:text-gray-300">Peak RPS: 15,000 requests/second</span>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-4 h-4 bg-emerald-500 rounded-full"></div>
                <span class="text-sm text-gray-600 dark:text-gray-300">Memory usage: &lt;2GB under load</span>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-4 h-4 bg-emerald-500 rounded-full"></div>
                <span class="text-sm text-gray-600 dark:text-gray-300">CPU utilization: &lt;80%</span>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-4 h-4 bg-emerald-500 rounded-full"></div>
                <span class="text-sm text-gray-600 dark:text-gray-300">Zero downtime during scaling</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- API Specifications -->
  <section class="py-20 bg-gray-50 dark:bg-gray-900">
    <Container>
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-12 text-center">API Specifications</h2>

      <div class="grid lg:grid-cols-2 gap-12">
        <div class="bg-white dark:bg-gray-800 p-8 rounded-2xl border border-gray-200 dark:border-gray-700">
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-6">REST API Endpoints</h3>

          <div class="space-y-4">
            <div class="p-4 bg-gray-50 dark:bg-gray-700 rounded-lg">
              <div class="flex items-center gap-2 mb-2">
                <span class="px-2 py-1 bg-emerald-500 text-white text-xs rounded">GET</span>
                <code class="text-sm text-gray-800 dark:text-gray-200">/api/v1/users</code>
              </div>
              <p class="text-sm text-gray-600 dark:text-gray-300">Retrieve user information with pagination</p>
            </div>

            <div class="p-4 bg-gray-50 dark:bg-gray-700 rounded-lg">
              <div class="flex items-center gap-2 mb-2">
                <span class="px-2 py-1 bg-blue-500 text-white text-xs rounded">POST</span>
                <code class="text-sm text-gray-800 dark:text-gray-200">/api/v1/sessions</code>
              </div>
              <p class="text-sm text-gray-600 dark:text-gray-300">Create new therapy training session</p>
            </div>

            <div class="p-4 bg-gray-50 dark:bg-gray-700 rounded-lg">
              <div class="flex items-center gap-2 mb-2">
                <span class="px-2 py-1 bg-purple-500 text-white text-xs rounded">POST</span>
                <code class="text-sm text-gray-800 dark:text-gray-200">/api/v1/analytics</code>
              </div>
              <p class="text-sm text-gray-600 dark:text-gray-300">Submit analytics data with real-time processing</p>
            </div>
          </div>
        </div>

        <div class="bg-white dark:bg-gray-800 p-8 rounded-2xl border border-gray-200 dark:border-gray-700">
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-6">WebSocket Real-time APIs</h3>

          <div class="space-y-4">
            <div class="p-4 bg-gray-50 dark:bg-gray-700 rounded-lg">
              <div class="flex items-center gap-2 mb-2">
                <span class="px-2 py-1 bg-orange-500 text-white text-xs rounded">WS</span>
                <code class="text-sm text-gray-800 dark:text-gray-200">/ws/training</code>
              </div>
              <p class="text-sm text-gray-600 dark:text-gray-300">Real-time training session updates</p>
            </div>

            <div class="p-4 bg-gray-50 dark:bg-gray-700 rounded-lg">
              <div class="flex items-center gap-2 mb-2">
                <span class="px-2 py-1 bg-orange-500 text-white text-xs rounded">WS</span>
                <code class="text-sm text-gray-800 dark:text-gray-200">/ws/analytics</code>
              </div>
              <p class="text-sm text-gray-600 dark:text-gray-300">Live analytics streaming</p>
            </div>

            <div class="p-4 bg-gray-50 dark:bg-gray-700 rounded-lg">
              <div class="flex items-center gap-2 mb-2">
                <span class="px-2 py-1 bg-orange-500 text-white text-xs rounded">WS</span>
                <code class="text-sm text-gray-800 dark:text-gray-200">/ws/notifications</code>
              </div>
              <p class="text-sm text-gray-600 dark:text-gray-300">Real-time system notifications</p>
            </div>
          </div>
        </div>
      </div>

      <!-- API Response Standards -->
      <div class="mt-12 bg-white dark:bg-gray-800 p-8 rounded-2xl border border-gray-200 dark:border-gray-700">
        <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-6">API Response Standards</h3>

        <div class="grid md:grid-cols-3 gap-6">
          <div>
            <h4 class="font-medium text-gray-900 dark:text-white mb-3">Response Format</h4>
            <ul class="text-sm text-gray-600 dark:text-gray-300 space-y-2">
              <li>• JSON: application/json</li>
              <li>• UTF-8 encoding</li>
              <li>• Consistent error handling</li>
              <li>• Standardized pagination</li>
            </ul>
          </div>

          <div>
            <h4 class="font-medium text-gray-900 dark:text-white mb-3">Rate Limiting</h4>
            <ul class="text-sm text-gray-600 dark:text-gray-300 space-y-2">
              <li>• 1000 requests/minute</li>
              <li>• Burst capacity: 200 requests</li>
              <li>• Per-user rate limiting</li>
              <li>• Automatic retry with backoff</li>
            </ul>
          </div>

          <div>
            <h4 class="font-medium text-gray-900 dark:text-white mb-3">Error Handling</h4>
            <ul class="text-sm text-gray-600 dark:text-gray-300 space-y-2">
              <li>• Standard HTTP status codes</li>
              <li>• Detailed error messages</li>
              <li>• Request ID tracking</li>
              <li>• Structured error responses</li>
            </ul>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- Deployment Configurations -->
  <section class="py-20">
    <Container>
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-12 text-center">Deployment Configurations</h2>

      <div class="grid lg:grid-cols-3 gap-8">
        <div class="bg-white dark:bg-gray-800 p-8 rounded-2xl border border-gray-200 dark:border-gray-700">
          <div class="text-center mb-6">
            <div class="w-16 h-16 bg-emerald-500/10 rounded-2xl flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-emerald-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 dark:text-white">Starter</h3>
            <p class="text-gray-600 dark:text-gray-300 text-sm">Up to 1,000 users</p>
          </div>

          <div class="space-y-3 text-sm">
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 bg-emerald-500 rounded-full"></span>
              <span class="text-gray-600 dark:text-gray-300">10GB storage</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 bg-emerald-500 rounded-full"></span>
              <span class="text-gray-600 dark:text-gray-300">100K API calls/month</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 bg-emerald-500 rounded-full"></span>
              <span class="text-gray-600 dark:text-gray-300">Basic support</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 bg-emerald-500 rounded-full"></span>
              <span class="text-gray-600 dark:text-gray-300">Single region</span>
            </div>
          </div>

          <div class="mt-6 pt-6 border-t border-gray-200 dark:border-gray-700">
            <div class="text-center">
              <div class="text-2xl font-bold text-gray-900 dark:text-white">$99</div>
              <div class="text-sm text-gray-600 dark:text-gray-300">per month</div>
            </div>
          </div>
        </div>

        <div class="bg-white dark:bg-gray-800 p-8 rounded-2xl border-2 border-blue-500 dark:border-blue-400 relative">
          <div class="absolute -top-3 left-1/2 transform -translate-x-1/2">
            <span class="bg-blue-500 text-white px-3 py-1 rounded-full text-xs font-medium">RECOMMENDED</span>
          </div>

          <div class="text-center mb-6">
            <div class="w-16 h-16 bg-blue-500/10 rounded-2xl flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-blue-500" fill="currentColor" viewBox="0 0 20 20">
                <path d="M3 4a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1V4zM3 10a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H4a1 1 0 01-1-1v-6zM14 9a1 1 0 00-1 1v5a1 1 0 001 1h2a1 1 0 001-1v-5a1 1 0 00-1-1h-2z" />
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 dark:text-white">Professional</h3>
            <p class="text-gray-600 dark:text-gray-300 text-sm">Up to 10,000 users</p>
          </div>

          <div class="space-y-3 text-sm">
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 bg-blue-500 rounded-full"></span>
              <span class="text-gray-600 dark:text-gray-300">100GB storage</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 bg-blue-500 rounded-full"></span>
              <span class="text-gray-600 dark:text-gray-300">1M API calls/month</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 bg-blue-500 rounded-full"></span>
              <span class="text-gray-600 dark:text-gray-300">Priority support</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 bg-blue-500 rounded-full"></span>
              <span class="text-gray-600 dark:text-gray-300">Multi-region</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 bg-blue-500 rounded-full"></span>
              <span class="text-gray-600 dark:text-gray-300">Advanced analytics</span>
            </div>
          </div>

          <div class="mt-6 pt-6 border-t border-gray-200 dark:border-gray-700">
            <div class="text-center">
              <div class="text-2xl font-bold text-gray-900 dark:text-white">$499</div>
              <div class="text-sm text-gray-600 dark:text-gray-300">per month</div>
            </div>
          </div>
        </div>

        <div class="bg-white dark:bg-gray-800 p-8 rounded-2xl border border-gray-200 dark:border-gray-700">
          <div class="text-center mb-6">
            <div class="w-16 h-16 bg-purple-500/10 rounded-2xl flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-purple-500" fill="currentColor" viewBox="0 0 20 20">
                <path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3z" />
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 dark:text-white">Enterprise</h3>
            <p class="text-gray-600 dark:text-gray-300 text-sm">Unlimited users</p>
          </div>

          <div class="space-y-3 text-sm">
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 bg-purple-500 rounded-full"></span>
              <span class="text-gray-600 dark:text-gray-300">Unlimited storage</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 bg-purple-500 rounded-full"></span>
              <span class="text-gray-600 dark:text-gray-300">Unlimited API calls</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 bg-purple-500 rounded-full"></span>
              <span class="text-gray-600 dark:text-gray-300">24/7 dedicated support</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 bg-purple-500 rounded-full"></span>
              <span class="text-gray-600 dark:text-gray-300">Custom deployment</span>
            </div>
            <div class="flex items-center gap-2">
