---
// Streamline-inspired Hero - Clean, minimal, content-focused
interface Props {
  title?: string;
  subtitle?: string;
  description?: string;
  primaryCTA?: {
    text: string;
    href: string;
  };
  secondaryCTA?: {
    text: string;
    href: string;
  };
}

const {
  title = "Enterprise Mental Health AI",
  subtitle = "Clinical-grade platform for healthcare organizations",
  description = "Deploy AI-powered mental health solutions across your organization. HIPAA compliant, evidence-based, seamlessly integrated with existing healthcare infrastructure.",
  primaryCTA = { text: "Request Demo", href: "/demo" },
  secondaryCTA = { text: "View Documentation", href: "/docs" }
} = Astro.props;
---

<section class="streamline-hero">
  <div class="container">
    <div class="hero-content">
      <!-- Minimal status badge -->
      <div class="status-badge">
        <div class="status-indicator"></div>
        <span>Production Ready • SOC 2 Certified</span>
      </div>

      <!-- Clean typography hierarchy -->
      <h1 class="hero-title">{title}</h1>
      <p class="hero-subtitle">{subtitle}</p>
      <p class="hero-description">{description}</p>

      <!-- Simple CTA layout -->
      <div class="hero-actions">
        <a href={primaryCTA.href} class="btn btn-primary btn-lg">
          {primaryCTA.text}
        </a>
        <a href={secondaryCTA.href} class="btn btn-secondary btn-lg">
          {secondaryCTA.text}
        </a>
      </div>

      <!-- Clean metrics -->
      <div class="metrics">
        <div class="metric">
          <div class="metric-value">500K+</div>
          <div class="metric-label">Sessions Analyzed</div>
        </div>
        <div class="metric">
          <div class="metric-value">98.2%</div>
          <div class="metric-label">Uptime SLA</div>
        </div>
        <div class="metric">
          <div class="metric-value">&lt;200ms</div>
          <div class="metric-label">API Response</div>
        </div>
      </div>
    </div>

    <!-- Minimal visual element -->
    <div class="hero-visual">
      <div class="terminal-window">
        <div class="terminal-header">
          <div class="terminal-controls">
            <div class="control"></div>
            <div class="control"></div>
            <div class="control"></div>
          </div>
          <div class="terminal-title">pixelated-empathy-api</div>
        </div>
        <div class="terminal-content">
          <div class="terminal-line">
            <span class="prompt">$</span>
            <span class="command">curl https://api.pixelated-empathy.com/analyze</span>
          </div>
          <div class="terminal-line">
            <span class="output">{</span>
          </div>
          <div class="terminal-line">
            <span class="output">  "status": "success",</span>
          </div>
          <div class="terminal-line">
            <span class="output">  "confidence": 0.94,</span>
          </div>
          <div class="terminal-line">
            <span class="output">  "recommendation": "cognitive_behavioral_therapy"</span>
          </div>
          <div class="terminal-line">
            <span class="output">}</span>
          </div>
          <div class="terminal-line">
            <span class="prompt">$</span>
            <span class="cursor">_</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .streamline-hero {
    padding: var(--space-24) 0 var(--space-32);
    background: var(--bg-primary);
  }

  .container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: center;
  }

  /* Content */
  .hero-content {
    max-width: 500px;
  }

  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    background: var(--bg-secondary);
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--text-muted);
    margin-bottom: var(--space-8);
  }

  .status-indicator {
    width: 6px;
    height: 6px;
    background: #10b981;
    border-radius: 50%;
  }

  .hero-title {
    font-size: var(--text-6xl);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: var(--space-4);
    letter-spacing: -0.02em;
  }

  .hero-subtitle {
    font-size: var(--text-xl);
    color: var(--text-secondary);
    font-weight: 500;
    margin-bottom: var(--space-6);
    line-height: 1.4;
  }

  .hero-description {
    font-size: var(--text-lg);
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: var(--space-10);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-4);
    margin-bottom: var(--space-16);
  }

  /* Metrics */
  .metrics {
    display: flex;
    gap: var(--space-8);
    padding: var(--space-6) 0;
    border-top: 1px solid var(--border-primary);
  }

  .metric {
    text-align: left;
  }

  .metric-value {
    font-size: var(--text-2xl);
    font-weight: 600;
    color: var(--text-primary);
    font-family: var(--font-mono);
    line-height: 1;
  }

  .metric-label {
    font-size: var(--text-xs);
    color: var(--text-muted);
    margin-top: var(--space-1);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Terminal Visual */
  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .terminal-window {
    width: 100%;
    max-width: 480px;
    background: var(--bg-secondary);
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    overflow: hidden;
  }

  .terminal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-3) var(--space-4);
    background: var(--bg-tertiary);
    border-bottom: 1px solid var(--border-primary);
  }

  .terminal-controls {
    display: flex;
    gap: var(--space-2);
  }

  .control {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--border-secondary);
  }

  .terminal-title {
    font-size: var(--text-xs);
    color: var(--text-muted);
    font-family: var(--font-mono);
  }

  .terminal-content {
    padding: var(--space-4);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: 1.5;
  }

  .terminal-line {
    margin-bottom: var(--space-1);
  }

  .prompt {
    color: var(--text-secondary);
    margin-right: var(--space-2);
  }

  .command {
    color: var(--text-primary);
  }

  .output {
    color: var(--text-muted);
    padding-left: var(--space-4);
  }

  .cursor {
    color: var(--accent);
    animation: blink 1s infinite;
  }

  @keyframes blink {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0; }
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .container {
      grid-template-columns: 1fr;
      gap: var(--space-12);
      text-align: center;
    }

    .hero-content {
      max-width: 600px;
      margin: 0 auto;
    }

    .metrics {
      justify-content: center;
    }
  }

  @media (max-width: 768px) {
    .streamline-hero {
      padding: var(--space-16) 0 var(--space-20);
    }

    .hero-title {
      font-size: var(--text-4xl);
    }

    .hero-subtitle {
      font-size: var(--text-lg);
    }

    .hero-description {
      font-size: var(--text-base);
    }

    .hero-actions {
      flex-direction: column;
      align-items: center;
    }

    .hero-actions .btn {
      width: 100%;
      max-width: 280px;
    }

    .metrics {
      flex-direction: column;
      align-items: center;
      gap: var(--space-4);
      text-align: center;
    }

    .terminal-window {
      max-width: 100%;
    }

    .terminal-content {
      font-size: var(--text-xs);
    }
  }
</style>