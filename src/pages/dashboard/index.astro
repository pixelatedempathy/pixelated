---
export const prerender = false

import DashboardLayout from '../../layouts/DashboardLayout.astro'
import DashboardCard from '@/components/ui/DashboardCard.astro'
import StatsGrid from '@/components/ui/StatsGrid.astro'
import { AnalyticsCharts } from '@/components/dashboard/AnalyticsCharts'

const { user } = Astro.props as { user: any }

const stats = [
  { label: 'Total Sessions', value: '--', color: 'emerald', icon: '📊' },
  { label: 'Practice Hours', value: '--', color: 'cyan', icon: '⏱️' },
  { label: 'Avg. Score', value: '--', color: 'purple', icon: '⭐' },
  { label: 'Growth', value: '--', color: 'pink', icon: '📈' }
]

const recentSessions = [
  { title: 'Crisis Intervention', date: 'Today', score: '--', status: 'completed' },
  { title: 'Trauma Response', date: 'Yesterday', score: '--', status: 'completed' },
  { title: 'Empathy Building', date: '2 days ago', score: '--', status: 'completed' }
]
---

<DashboardLayout title="Dashboard - Pixelated Empathy" description="Your training dashboard overview">
  <div class="space-y-8">
    <!-- Welcome Header -->
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-3xl font-bold text-white mb-2">
          Welcome Back{user?.name ? `, ${user.name.split(' ')[0]}` : ''}
        </h1>
        <p class="text-gray-400">Here's an overview of your training progress</p>
      </div>
      <div class="flex items-center gap-3 px-4 py-2 bg-emerald-500/10 border border-emerald-500/20 rounded-full">
        <div class="w-2 h-2 bg-emerald-400 rounded-full"></div>
        <span class="text-emerald-400 text-sm font-medium">FHE Secured</span>
      </div>
    </div>

    <!-- Stats Grid -->
    <StatsGrid stats={stats} columns={4} />

    <!-- Recent Sessions -->
    <DashboardCard title="Recent Training Sessions" action={{ label: 'View All', href: '/dashboard/training' }}>
      <div class="space-y-3">
        {recentSessions.map((session) => (
          <div class="flex items-center justify-between p-4 bg-white/5 rounded-lg hover:bg-white/10 transition-colors">
            <div>
              <h3 class="font-semibold text-white">{session.title}</h3>
              <p class="text-sm text-gray-400">{session.date}</p>
            </div>
            <div class="flex items-center gap-4">
              <div class="text-right">
                <p class="text-sm text-gray-400">Score</p>
                <p class="font-semibold text-white">{session.score}</p>
              </div>
              <span class="px-3 py-1 bg-emerald-500/20 border border-emerald-500/30 rounded-full text-emerald-400 text-xs font-medium">
                {session.status}
              </span>
            </div>
          </div>
        ))}
      </div>
    </DashboardCard>

    <!-- Analytics Charts -->
    <DashboardCard title="Performance Analytics">
      <AnalyticsCharts client:load />
    </DashboardCard>

    <!-- Quick Actions -->
    <div class="grid md:grid-cols-3 gap-6">
      <a href="/dashboard/training" class="block p-6 bg-black/40 backdrop-blur-xl border border-white/10 rounded-xl hover:border-emerald-500/30 transition-all duration-300">
        <div class="text-4xl mb-4">🎯</div>
        <h3 class="text-xl font-bold text-white mb-2">Start Training</h3>
        <p class="text-gray-400 text-sm">Begin a new training session</p>
      </a>
      
      <a href="/dashboard/analytics" class="block p-6 bg-black/40 backdrop-blur-xl border border-white/10 rounded-xl hover:border-cyan-500/30 transition-all duration-300">
        <div class="text-4xl mb-4">📊</div>
        <h3 class="text-xl font-bold text-white mb-2">View Analytics</h3>
        <p class="text-gray-400 text-sm">Track your progress and insights</p>
      </a>
      
      <a href="/dashboard/settings" class="block p-6 bg-black/40 backdrop-blur-xl border border-white/10 rounded-xl hover:border-purple-500/30 transition-all duration-300">
        <div class="text-4xl mb-4">⚙️</div>
        <h3 class="text-xl font-bold text-white mb-2">Settings</h3>
        <p class="text-gray-400 text-sm">Manage your account preferences</p>
      </a>
    </div>
  </div>
</DashboardLayout>
