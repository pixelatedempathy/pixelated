---
import Layout from '../layouts/Layout.astro'
import PageHero from '../components/ui/PageHero.astro'
import ContentSection from '../components/ui/ContentSection.astro'

const token = Astro.url.searchParams.get('token')
const email = Astro.url.searchParams.get('email')

export const prerender = false
---

<Layout title="Verify Email - Pixelated Empathy" description="Verify your email address">
  <PageHero
    badge="Email Verification"
    title="Verify Your Email"
    subtitle="Complete your registration by verifying your email address."
    gradient={true}
  />

  <ContentSection>
    <div class="max-w-2xl mx-auto text-center">
      {token ? (
        <div class="bg-black/40 backdrop-blur-xl border border-white/10 rounded-2xl p-12">
          <div class="w-20 h-20 bg-gradient-to-r from-emerald-500 to-cyan-500 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
          </div>
          <h2 class="text-3xl font-bold text-white mb-4">Email Verified!</h2>
          <p class="text-xl text-gray-300 mb-8">
            Your email has been successfully verified. You can now access all features of your account.
          </p>
          <a 
            href="/login"
            class="inline-flex items-center justify-center px-8 py-4 bg-gradient-to-r from-emerald-500 to-cyan-500 hover:from-emerald-600 hover:to-cyan-600 text-black font-bold rounded-lg transition-all duration-200 transform hover:scale-105"
          >
            Continue to Login
          </a>
        </div>
      ) : (
        <div class="bg-black/40 backdrop-blur-xl border border-white/10 rounded-2xl p-12">
          <div class="w-20 h-20 bg-gradient-to-r from-blue-500 to-purple-500 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
          </div>
          <h2 class="text-3xl font-bold text-white mb-4">Check Your Email</h2>
          <p class="text-xl text-gray-300 mb-8">
            We've sent a verification link to {email ? <span class="text-emerald-400">{email}</span> : 'your email address'}. 
            Click the link in the email to verify your account.
          </p>
          
          <div class="space-y-4">
            <p class="text-gray-400 text-sm">
              Didn't receive the email? Check your spam folder or
            </p>
            <button 
              id="resend-button"
              class="inline-flex items-center justify-center px-6 py-3 bg-white/10 hover:bg-white/20 border border-white/20 rounded-lg text-white font-medium transition-all duration-200"
            >
              Resend Verification Email
            </button>
          </div>
        </div>
      )}
    </div>
  </ContentSection>
</Layout>

<script>
  document.getElementById('resend-button')?.addEventListener('click', () => {
    alert('Verification email resent! Please check your inbox.')
  })
</script>
