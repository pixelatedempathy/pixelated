---
// Mizu-Style Brutalist Header Component
const navLinks = [
  { name: 'Features', href: '/features' },
  { name: 'About', href: '/about' },
  { name: 'Contact', href: '/contact' },
  { name: 'Demos', href: '/demo-hub', highlight: true },
]
---

<header class="mizu-header">
  <div class="mizu-header-container">
    <nav class="mizu-header-nav" aria-label="main navigation" role="navigation">
      <!-- Logo -->
      <a href="/" class="mizu-header-logo">
        <div class="mizu-header-logo-icon">
          <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
          </svg>
        </div>
        <div class="mizu-header-logo-text">
          <span class="mizu-header-logo-title">Pixelated Empathy</span>
          <span class="mizu-header-logo-subtitle">AI-Powered Mental Health</span>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <ul class="mizu-header-menu" role="menubar" aria-label="Select page">
        {navLinks.map((link) => (
          <li role="none" class="mizu-header-menu-item">
            <a 
              href={link.href} 
              role="menuitem"
              class={`mizu-header-menu-link ${link.highlight ? 'mizu-header-menu-link--active' : ''}`}
            >
              {link.name}
            </a>
          </li>
        ))}
      </ul>

      <!-- CTA Button -->
      <div class="mizu-header-actions">
        <a href="/contact" class="mizu-header-button">
          Get Started
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button 
        id="mizu-mobile-menu-button"
        class="mizu-header-toggle"
        aria-expanded="false"
        aria-label="Toggle navigation"
      >
        <span aria-hidden="true"></span>
        <span aria-hidden="true"></span>
        <span aria-hidden="true"></span>
      </button>
    </nav>

    <!-- Decorative Border - Solid -->
    <div class="mizu-decoration-border mizu-decoration-border--solid">
      <span class="mizu-decoration-border__bottom"></span>
      <span class="mizu-decoration-border__left"></span>
      <span class="mizu-decoration-border__right"></span>
    </div>
  </div>

  <!-- Decorative Border - Dashed (below header) -->
  <div class="mizu-decoration-border mizu-decoration-border--dashed">
    <span class="mizu-decoration-border__bottom"></span>
  </div>

  <!-- Mobile Navigation -->
  <div id="mizu-mobile-menu" class="mizu-header-mobile-menu hidden">
    <ul class="mizu-header-mobile-menu-list">
      {navLinks.map((link) => (
        <li>
          <a 
            href={link.href} 
            class={`mizu-header-mobile-menu-link ${link.highlight ? 'mizu-header-mobile-menu-link--active' : ''}`}
          >
            {link.name}
          </a>
        </li>
      ))}
    </ul>
    <div class="mizu-header-mobile-menu-cta">
      <a href="/contact" class="mizu-header-button mizu-header-button--full">
        Get Started
      </a>
    </div>
  </div>
</header>

<script>
  // Mobile menu toggle
  const mobileMenuButton = document.getElementById('mizu-mobile-menu-button');
  const mobileMenu = document.getElementById('mizu-mobile-menu');
  
  if (mobileMenuButton && mobileMenu) {
    mobileMenuButton.addEventListener('click', () => {
      const isHidden = mobileMenu.classList.contains('hidden');
      
      if (isHidden) {
        mobileMenu.classList.remove('hidden');
        mobileMenuButton.setAttribute('aria-expanded', 'true');
      } else {
        mobileMenu.classList.add('hidden');
        mobileMenuButton.setAttribute('aria-expanded', 'false');
      }
    });
  }
</script>