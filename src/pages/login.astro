---
import Layout from '../layouts/Layout.astro'
import PageHero from '../components/ui/PageHero.astro'
import ContentSection from '../components/ui/ContentSection.astro'
import { LoginForm } from '../components/auth/LoginForm.tsx'

const redirectUrl = Astro.url.searchParams.get('redirect') || '/dashboard'
const isFromDashboard = redirectUrl.includes('/dashboard')

export const prerender = false
---

<Layout title="Login - Pixelated Empathy" description="Log in to your Pixelated Empathy account">
  <PageHero
    badge="Welcome Back"
    title="Login to Your Account"
    subtitle="Access your training dashboard and continue your professional development journey."
    gradient={true}
  />

  <ContentSection>
    <div class="max-w-md mx-auto">
      {isFromDashboard && (
        <div class="mb-6 p-4 border border-yellow-500/20 rounded-xl bg-yellow-500/5">
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-yellow-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <div>
              <h3 class="text-sm font-medium text-white">Session Required</h3>
              <p class="text-xs text-gray-400 mt-1">You need to be logged in to access the dashboard.</p>
            </div>
          </div>
        </div>
      )}

      <div class="bg-black/40 backdrop-blur-xl border border-white/10 rounded-2xl p-8">
        <LoginForm client:load redirectTo={redirectUrl} showSignup={false} />
        
        <div class="mt-6 pt-6 border-t border-white/10 text-center">
          <p class="text-gray-400 text-sm">
            Don't have an account?{' '}
            <a href="/register" class="text-emerald-400 hover:text-emerald-300 font-medium">
              Sign up
            </a>
          </p>
        </div>
      </div>

      <div class="mt-6 text-center">
        <a href="/forgot-password" class="text-gray-400 hover:text-white text-sm">
          Forgot your password?
        </a>
      </div>
    </div>
  </ContentSection>
</Layout>
