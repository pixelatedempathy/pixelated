---
// Hybrid Layout - Streamline minimalism + Mizu elegance
import StreamlineNav from '@/components/layout/StreamlineNav.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: URL | string;
  noindex?: boolean;
  class?: string;
}

const {
  title = 'Pixelated Empathy - Enterprise Mental Health AI Platform',
  description = 'Clinical-grade AI platform combining enterprise security with elegant user experience. Deploy evidence-based mental health solutions with seamless EHR integration.',
  ogImage = '/images/og-hybrid.png',
  canonicalURL = new URL(Astro.url.pathname, Astro.site),
  noindex = false,
  class: className = ''
} = Astro.props;

const siteTitle = title.includes('Pixelated Empathy') ? title : `${title} | Pixelated Empathy`;
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="generator" content={Astro.generator} />
  
  <!-- Primary Meta Tags -->
  <title>{siteTitle}</title>
  <meta name="title" content={siteTitle} />
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  
  {noindex && <meta name="robots" content="noindex, nofollow" />}
  
  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={siteTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  
  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content={canonicalURL} />
  <meta property="twitter:title" content={siteTitle} />
  <meta property="twitter:description" content={description} />
  <meta property="twitter:image" content={ogImage} />
  
  <!-- Enhanced Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  
  <!-- Hybrid Design System -->
  <link rel="stylesheet" href="/src/styles/hybrid-design-system.css" />
  
  <!-- Theme Detection -->
  <script is:inline>
    (() => {
      try {
        const stored = localStorage.getItem("theme");
        const theme = stored ?? "dark";
        document.documentElement.setAttribute("data-theme", theme);
      } catch {}
    })();
  </script>
</head>

<body class={className}>
  <!-- Skip to main content -->
  <a href="#main-content" class="skip-link">Skip to main content</a>
  
  <!-- Navigation -->
  <StreamlineNav />
  
  <!-- Main Content -->
  <main id="main-content" class="main-content">
    <slot />
  </main>
  
  <!-- Enhanced footer -->
  <footer class="hybrid-footer">
    <div class="container">
      <div class="footer-content">
        <div class="footer-brand">
          <div class="footer-logo">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none">
              <rect width="24" height="24" rx="6" fill="currentColor"/>
              <rect x="6" y="8" width="12" height="1.5" fill="var(--bg-primary)" rx="0.75"/>
              <rect x="6" y="11" width="12" height="1.5" fill="var(--bg-primary)" rx="0.75"/>
              <rect x="6" y="14" width="8" height="1.5" fill="var(--bg-primary)" rx="0.75"/>
              <circle cx="20" cy="4" r="2" fill="var(--accent)"/>
            </svg>
            <div class="logo-text">
              <span class="logo-name">Pixelated Empathy</span>
              <span class="logo-tagline">Enterprise Mental Health AI</span>
            </div>
          </div>
          <p class="footer-description">
            Clinical-grade AI platform designed for healthcare organizations. 
            Transform mental health care delivery with enterprise security, 
            seamless integration, and evidence-based solutions.
          </p>
          
          <!-- Compliance badges -->
          <div class="compliance-grid">
            <div class="compliance-badge">
              <div class="badge-icon">🔒</div>
              <div class="badge-text">
                <div class="badge-title">SOC 2</div>
                <div class="badge-subtitle">Type II</div>
              </div>
            </div>
            <div class="compliance-badge">
              <div class="badge-icon">🏥</div>
              <div class="badge-text">
                <div class="badge-title">HIPAA</div>
                <div class="badge-subtitle">Compliant</div>
              </div>
            </div>
            <div class="compliance-badge">
              <div class="badge-icon">🌐</div>
              <div class="badge-text">
                <div class="badge-title">GDPR</div>
                <div class="badge-subtitle">Ready</div>
              </div>
            </div>
          </div>
        </div>
        
        <div class="footer-links">
          <div class="link-section">
            <h4>Platform</h4>
            <a href="/platform/ai-engine">AI Engine</a>
            <a href="/platform/integration">EHR Integration</a>
            <a href="/platform/analytics">Analytics</a>
            <a href="/platform/security">Security</a>
          </div>
          
          <div class="link-section">
            <h4>Solutions</h4>
            <a href="/solutions/healthcare">Healthcare Systems</a>
            <a href="/solutions/enterprise">Enterprise Wellness</a>
            <a href="/solutions/clinical">Clinical Practice</a>
            <a href="/solutions/telehealth">Telehealth</a>
          </div>
          
          <div class="link-section">
            <h4>Resources</h4>
            <a href="/docs">Documentation</a>
            <a href="/api">API Reference</a>
            <a href="/case-studies">Case Studies</a>
            <a href="/whitepapers">Whitepapers</a>
          </div>
          
          <div class="link-section">
            <h4>Company</h4>
            <a href="/about">About Us</a>
            <a href="/careers">Careers</a>
            <a href="/contact">Contact</a>
            <a href="/support">Support</a>
          </div>
        </div>
      </div>
      
      <div class="footer-bottom">
        <div class="footer-legal">
          <p>&copy; 2024 Pixelated Empathy. All rights reserved.</p>
          <div class="legal-links">
            <a href="/privacy">Privacy Policy</a>
            <a href="/terms">Terms of Service</a>
            <a href="/cookies">Cookie Policy</a>
            <a href="/security">Security</a>
          </div>
        </div>
        
        <div class="footer-status">
          <div class="status-indicator">
            <div class="status-dot"></div>
            <span>All Systems Operational</span>
          </div>
          <a href="/status" class="status-link">System Status</a>
        </div>
      </div>
    </div>
  </footer>
  
  <!-- Enhanced scripts -->
  <script>
    // Enhanced theme management
    const initTheme = () => {
      const saved = localStorage.getItem('theme') || 'dark';
      document.documentElement.setAttribute('data-theme', saved);
      
      // System preference listener
      const mediaQuery = window.matchMedia('(prefers-color-scheme: dark)');
      mediaQuery.addEventListener('change', (e) => {
        if (!localStorage.getItem('theme')) {
          document.documentElement.setAttribute('data-theme', e.matches ? 'dark' : 'light');
        }
      });
    };

    // Smooth scroll with offset
    const initScroll = () => {
      document.addEventListener('click', (e) => {
        const link = e.target.closest('a[href^="#"]');
        if (link) {
          e.preventDefault();
          const target = document.querySelector(link.getAttribute('href'));
          if (target) {
            const offset = 80; // Account for fixed header
            const targetPosition = target.offsetTop - offset;
            window.scrollTo({
              top: targetPosition,
              behavior: 'smooth'
            });
          }
        }
      });
    };

    // Intersection observer for animations
    const initAnimations = () => {
      if ('IntersectionObserver' in window) {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('animate-in');
            }
          });
        }, {
          threshold: 0.1,
          rootMargin: '0px 0px -50px 0px'
        });

        // Observe animatable elements
        const elements = document.querySelectorAll('.fade-in, .slide-up, [data-animate]');
        elements.forEach(el => observer.observe(el));
      }
    };

    // Initialize all features
    document.addEventListener('DOMContentLoaded', () => {
      initTheme();
      initScroll();
      initAnimations();
    });
  </script>
</body>
</html>

<style is:global>
  /* Hybrid Layout Global Styles */
  
  .skip-link {
    position: absolute;
    top: -48px;
    left: 8px;
    background: var(--accent);
    color: var(--bg-primary);
    padding: var(--space-3) var(--space-4);
    text-decoration: none;
    border-radius: var(--radius-lg);
    z-index: 10000;
    font-size: var(--text-sm);
    font-weight: 600;
    transition: top var(--transition-normal);
  }

  .skip-link:focus {
    top: 8px;
  }

  .main-content {
    margin-top: 64px;
    min-height: calc(100vh - 128px);
  }

  /* Enhanced footer */
  .hybrid-footer {
    background: var(--bg-secondary);
    border-top: 1px solid var(--border-primary);
    padding: var(--space-20) 0 var(--space-8);
    margin-top: var(--space-32);
  }

  .footer-content {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: var(--space-20);
    margin-bottom: var(--space-16);
  }

  .footer-brand {
    max-width: 400px;
  }

  .footer-logo {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }

  .logo-text {
    display: flex;
    flex-direction: column;
  }

  .logo-name {
    color: var(--text-primary);
    font-weight: 700;
    font-size: var(--text-xl);
    line-height: var(--leading-tight);
  }

  .logo-tagline {
    color: var(--text-secondary);
    font-size: var(--text-sm);
    font-weight: 500;
  }

  .footer-description {
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-8);
  }

  .compliance-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
  }

  .compliance-badge {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3);
    background: var(--bg-card);
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-xl);
    backdrop-filter: blur(16px);
  }

  .badge-icon {
    font-size: var(--text-base);
  }

  .badge-text {
    display: flex;
    flex-direction: column;
  }

  .badge-title {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--text-primary);
    line-height: var(--leading-none);
  }

  .badge-subtitle {
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .footer-links {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-12);
  }

  .link-section h4 {
    color: var(--text-primary);
    font-size: var(--text-base);
    font-weight: 600;
    margin-bottom: var(--space-6);
  }

  .link-section a {
    display: block;
    color: var(--text-secondary);
    text-decoration: none;
    font-size: var(--text-sm);
    padding: var(--space-2) 0;
    transition: color var(--transition-fast);
    line-height: var(--leading-relaxed);
  }

  .link-section a:hover {
    color: var(--accent);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--space-8);
    border-top: 1px solid var(--border-primary);
  }

  .footer-legal {
    display: flex;
    align-items: center;
    gap: var(--space-8);
  }

  .footer-legal p {
    color: var(--text-muted);
    font-size: var(--text-sm);
    margin: 0;
  }

  .legal-links {
    display: flex;
    gap: var(--space-6);
  }

  .legal-links a {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: var(--text-sm);
    transition: color var(--transition-fast);
  }

  .legal-links a:hover {
    color: var(--accent);
  }

  .footer-status {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .status-indicator {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  .status-dot {
    width: 8px;
    height: 8px;
    background: #10b981;
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  .status-link {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: var(--text-sm);
    transition: color var(--transition-fast);
  }

  .status-link:hover {
    color: var(--accent);
  }

  /* Responsive footer */
  @media (max-width: 1024px) {
    .footer-content {
      grid-template-columns: 1fr;
      gap: var(--space-12);
    }

    .footer-links {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-8);
    }

    .compliance-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .hybrid-footer {
      padding: var(--space-16) 0 var(--space-6);
    }

    .footer-links {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }

    .footer-bottom {
      flex-direction: column;
      gap: var(--space-6);
      text-align: center;
    }

    .footer-legal {
      flex-direction: column;
      gap: var(--space-4);
    }

    .legal-links {
      justify-content: center;
      flex-wrap: wrap;
    }

    .compliance-grid {
      grid-template-columns: 1fr;
    }
  }
</style>