---
export const prerender = false

import DashboardLayout from '../../../layouts/DashboardLayout.astro'
import DashboardCard from '@/components/ui/DashboardCard.astro'
import Pagination from '@/components/ui/Pagination.astro'
---

<DashboardLayout title="Training History - Pixelated Empathy">
  <div class="space-y-8">
    <h1 class="text-3xl font-bold text-white">Training History</h1>

    <DashboardCard title="Past Sessions">
      <p class="text-gray-300">Your training history will appear here.</p>
    </DashboardCard>

    <Pagination currentPage={1} totalPages={1} baseUrl="/dashboard/training/history" />
  </div>
</DashboardLayout>
