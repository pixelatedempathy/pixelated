---
export const prerender = false
import DashboardLayout from '../../../layouts/DashboardLayout.astro'
import DashboardCard from '@/components/ui/DashboardCard.astro'
import StatsGrid from '@/components/ui/StatsGrid.astro'

const stats = [
  { label: 'CPU', value: '--', color: 'emerald' },
  { label: 'Memory', value: '--', color: 'cyan' },
  { label: 'Disk', value: '--', color: 'purple' }
]
---
<DashboardLayout title="Monitoring - Admin">
  <div class="space-y-8">
    <h1 class="text-3xl font-bold text-white">Monitoring</h1>
    <StatsGrid stats={stats} columns={3} />
  </div>
</DashboardLayout>
