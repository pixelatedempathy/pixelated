---
import Layout from '@/layouts/Layout.astro'

const caseStudies = [
  {
    title: "[Healthcare Institution Name]",
    subtitle: "Improved Crisis Intervention Training",
    description: "Implementation of AI-powered training simulations resulted in measurable improvements in staff confidence and competency assessments.",
    metrics: {
      trainingHours: "[Hours]",
      satisfaction: "[%]",
      improvement: "[%]"
    },
    category: "Crisis Intervention",
    image: "/images/case-study-placeholder.jpg"
  },
  {
    title: "[Medical Center Name]",
    subtitle: "Enhanced Resident Training Program", 
    description: "Integration of simulation-based learning reduced traditional training time while maintaining competency standards.",
    metrics: {
      trainingHours: "[Hours]",
      satisfaction: "[%]",
      improvement: "[%]"
    },
    category: "Medical Education",
    image: "/images/case-study-placeholder.jpg"
  },
  {
    title: "[Healthcare Network Name]",
    subtitle: "Cultural Competency Training Initiative",
    description: "Multi-site deployment improved cultural sensitivity training and reduced patient feedback concerns across facilities.",
    metrics: {
      trainingHours: "[Hours]",
      satisfaction: "[%]",
      improvement: "[%]"
    },
    category: "Cultural Competency", 
    image: "/images/case-study-placeholder.jpg"
  }
]
---

<Layout title="Case Studies - Pixelated Empathy">
  <main class="min-h-screen bg-gradient-to-br from-gray-900 via-black to-gray-900">
    <!-- Background Elements -->
    <div class="absolute top-20 left-10 w-96 h-96 bg-gradient-to-r from-emerald-500/20 to-cyan-500/20 rounded-full blur-3xl"></div>
    <div class="absolute bottom-20 right-10 w-80 h-80 bg-gradient-to-r from-purple-500/20 to-pink-500/20 rounded-full blur-3xl"></div>

    <div class="container mx-auto px-6 py-24 relative z-10">
      <!-- Header -->
      <div class="text-center mb-16">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-emerald-500/10 border border-emerald-500/20 rounded-full text-emerald-400 text-sm font-mono mb-6">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
          </span>
          Real Results
        </div>
        <h1 class="text-5xl font-bold text-white mb-6">Case Studies</h1>
        <p class="text-xl text-gray-300 max-w-3xl mx-auto">
          Discover how leading healthcare institutions have transformed their training programs and improved patient outcomes with our AI-powered platform.
        </p>
      </div>

      <!-- Case Studies Grid -->
      <div class="grid lg:grid-cols-1 gap-12 mb-16">
        {caseStudies.map((study, index) => (
          <div class="group relative">
            <div class="absolute inset-0 bg-gradient-to-r from-emerald-500/20 to-cyan-500/20 rounded-2xl blur-xl group-hover:blur-2xl transition-all duration-300"></div>
            <div class="relative bg-black/40 backdrop-blur-xl border border-white/10 rounded-2xl p-8 hover:border-emerald-500/30 transition-all duration-300">
              <div class="grid lg:grid-cols-2 gap-8 items-center">
                <div>
                  <div class="inline-block px-3 py-1 bg-emerald-500/20 border border-emerald-500/30 rounded-full text-emerald-400 text-sm font-medium mb-4">
                    {study.category}
                  </div>
                  <h2 class="text-3xl font-bold text-white mb-2">{study.title}</h2>
                  <h3 class="text-xl text-emerald-400 mb-4">{study.subtitle}</h3>
                  <p class="text-gray-300 leading-relaxed mb-6">{study.description}</p>
                  
                  <div class="grid grid-cols-3 gap-4 mb-6">
                    <div class="text-center">
                      <div class="text-2xl font-bold text-white">{study.metrics.trainingHours}</div>
                      <div class="text-sm text-gray-400">Training Hours</div>
                    </div>
                    <div class="text-center">
                      <div class="text-2xl font-bold text-emerald-400">{study.metrics.satisfaction}</div>
                      <div class="text-sm text-gray-400">Satisfaction</div>
                    </div>
                    <div class="text-center">
                      <div class="text-2xl font-bold text-cyan-400">{study.metrics.improvement}</div>
                      <div class="text-sm text-gray-400">Improvement</div>
                    </div>
                  </div>

                  <button class="px-6 py-3 bg-gradient-to-r from-emerald-500 to-cyan-500 hover:from-emerald-600 hover:to-cyan-600 text-black font-bold rounded-lg transition-all duration-200 transform hover:scale-105">
                    Download Full Case Study
                  </button>
                </div>
                
                <div class="relative">
                  <div class="w-full h-64 bg-gradient-to-br from-emerald-500/20 to-cyan-500/20 rounded-xl flex items-center justify-center">
                    <div class="text-6xl text-emerald-400/50">📊</div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- CTA Section -->
      <div class="text-center">
        <div class="group relative inline-block">
          <div class="absolute inset-0 bg-gradient-to-r from-emerald-500/20 to-purple-500/20 rounded-2xl blur-xl group-hover:blur-2xl transition-all duration-300"></div>
          <div class="relative bg-black/40 backdrop-blur-xl border border-emerald-500/30 rounded-2xl p-12 text-center">
            <h2 class="text-3xl font-bold text-white mb-4">Ready to Transform Your Training?</h2>
            <p class="text-gray-300 mb-8 max-w-2xl mx-auto">
              Join hundreds of healthcare institutions that have already improved their training outcomes with our AI-powered platform.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <a href="/contact" class="px-8 py-4 bg-gradient-to-r from-emerald-500 to-cyan-500 hover:from-emerald-600 hover:to-cyan-600 text-black font-bold rounded-lg transition-all duration-200 transform hover:scale-105">
                Request Your Case Study
              </a>
              <a href="/demos" class="px-8 py-4 bg-white/5 backdrop-blur-sm border border-white/10 text-white font-semibold rounded-lg hover:bg-white/10 hover:border-white/20 transition-all duration-300">
                View Live Demo
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>
