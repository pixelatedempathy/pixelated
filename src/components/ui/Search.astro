---
interface Props {
  placeholder?: string
  shortcut?: boolean
}

const { placeholder = 'Search...', shortcut = true } = Astro.props
---

<div class="relative">
  <div class="relative">
    <input
      type="text"
      id="global-search"
      placeholder={placeholder}
      class="w-full px-4 py-3 pl-11 pr-20 bg-black/40 backdrop-blur-xl border border-white/10 rounded-lg text-white placeholder-gray-400 focus:outline-none focus:border-emerald-500/50 transition-colors"
    />
    <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
    </svg>
    {shortcut && (
      <kbd class="absolute right-4 top-1/2 -translate-y-1/2 px-2 py-1 bg-white/10 border border-white/20 rounded text-xs text-gray-400">
        ⌘K
      </kbd>
    )}
  </div>
</div>

<script>
  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault()
      document.getElementById('global-search')?.focus()
    }
  })
</script>
