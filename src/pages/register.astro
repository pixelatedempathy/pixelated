---
import type { AstroGlobal } from 'astro'
import { isAuthenticated } from '../lib/auth'
import Layout from '../layouts/Layout.astro'
import PageHero from '../components/ui/PageHero.astro'
import ContentSection from '../components/ui/ContentSection.astro'
import { RegisterForm } from '../components/auth/RegisterForm.tsx'

const astro = Astro as AstroGlobal

if (await isAuthenticated(astro.cookies)) {
  return astro.redirect('/dashboard')
}

const error = astro.url.searchParams.get('error')

export const prerender = false
---

<Layout title="Create Account - Pixelated Empathy" description="Join Pixelated Empathy to access mental health training resources">
  <PageHero
    badge="Get Started"
    title="Create Your Account"
    subtitle="Join thousands of mental health professionals advancing their skills with AI-powered training."
    gradient={true}
  />

  <ContentSection>
    <div class="max-w-md mx-auto">
      {error && (
        <div class="mb-6 p-4 bg-red-500/10 border border-red-500/20 rounded-xl">
          <p class="text-sm text-red-400">{decodeURIComponent(error)}</p>
        </div>
      )}

      <div class="bg-black/40 backdrop-blur-xl border border-white/10 rounded-2xl p-8">
        <RegisterForm client:load showLogin={true} />
        
        <div class="mt-6 pt-6 border-t border-white/10 text-center">
          <p class="text-gray-400 text-sm">
            Already have an account?{' '}
            <a href="/login" class="text-emerald-400 hover:text-emerald-300 font-medium">
              Log in
            </a>
          </p>
        </div>
      </div>

      <div class="mt-6 text-center text-xs text-gray-400">
        By creating an account, you agree to our{' '}
        <a href="/terms" class="text-emerald-400 hover:text-emerald-300">Terms of Service</a>
        {' '}and{' '}
        <a href="/privacy" class="text-emerald-400 hover:text-emerald-300">Privacy Policy</a>
      </div>
    </div>
  </ContentSection>
</Layout>
