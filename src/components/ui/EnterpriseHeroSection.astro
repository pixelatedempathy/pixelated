---
// Enterprise Hero Section with proper proportions and modern design
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-gradient-to-br from-gray-950 via-gray-900 to-gray-950">
  <!-- Background Effects -->
  <div class="absolute inset-0 bg-grid-white/[0.02] bg-[size:60px_60px]"></div>
  <div class="absolute inset-0 bg-gradient-to-r from-emerald-500/10 via-transparent to-cyan-500/10"></div>
  
  <!-- Floating Elements -->
  <div class="absolute top-20 left-10 w-72 h-72 bg-emerald-500/20 rounded-full blur-3xl animate-pulse"></div>
  <div class="absolute bottom-20 right-10 w-96 h-96 bg-cyan-500/20 rounded-full blur-3xl animate-pulse delay-1000"></div>
  
  <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      
      <!-- Left Content -->
      <div class="text-center lg:text-left">
        <!-- Badge -->
        <div class="inline-flex items-center px-4 py-2 rounded-full bg-emerald-500/10 border border-emerald-500/20 mb-8">
          <span class="w-2 h-2 bg-emerald-400 rounded-full mr-2"></span>
          <span class="text-emerald-400 text-sm font-medium">Next-Gen AI Training</span>
        </div>
        
        <!-- Main Heading -->
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight">
          <span class="block">Transform Mental Health</span>
          <span class="block bg-gradient-to-r from-emerald-400 to-cyan-400 bg-clip-text text-transparent">
            Training with AI
          </span>
        </h1>
        
        <!-- Subtitle -->
        <p class="text-xl text-gray-300 mb-8 max-w-2xl">
          Revolutionary AI simulation platform for mental health professionals. Experience immersive training scenarios, 
          develop advanced therapeutic skills, and improve patient outcomes through cutting-edge technology.
        </p>
        
        <!-- Stats Row -->
        <div class="grid grid-cols-3 gap-8 mb-8">
          <div class="text-center lg:text-left">
            <div class="text-3xl font-bold text-emerald-400">10K+</div>
            <div class="text-sm text-gray-400">Training Sessions</div>
          </div>
          <div class="text-center lg:text-left">
            <div class="text-3xl font-bold text-cyan-400">95%</div>
            <div class="text-sm text-gray-400">Accuracy Rate</div>
          </div>
          <div class="text-center lg:text-left">
            <div class="text-3xl font-bold text-purple-400">24/7</div>
            <div class="text-sm text-gray-400">Availability</div>
          </div>
        </div>
        
        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <a href="/demo" class="bg-gradient-to-r from-emerald-600 to-emerald-700 hover:from-emerald-700 hover:to-emerald-800 text-white px-8 py-4 rounded-xl font-semibold text-lg transition-all duration-300 shadow-lg hover:shadow-emerald-500/25 inline-flex items-center justify-center">
            Start Training
            <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
          </a>
          <a href="/learn-more" class="border border-gray-600 hover:border-gray-500 text-white px-8 py-4 rounded-xl font-semibold text-lg transition-all duration-300 hover:bg-gray-800/50 inline-flex items-center justify-center">
            Learn More
          </a>
        </div>
        
        <!-- Trust Indicators -->
        <div class="mt-12 flex items-center justify-center lg:justify-start space-x-6 text-gray-400">
          <div class="flex items-center space-x-2">
            <svg class="w-5 h-5 text-emerald-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"/>
            </svg>
            <span class="text-sm">HIPAA Compliant</span>
          </div>
          <div class="flex items-center space-x-2">
            <svg class="w-5 h-5 text-emerald-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"/>
            </svg>
            <span class="text-sm">Enterprise Security</span>
          </div>
        </div>
      </div>
      
      <!-- Right Content - AI Simulation Preview -->
      <div class="relative">
        <div class="bg-gray-900/50 backdrop-blur-xl border border-gray-700/50 rounded-2xl p-6 shadow-2xl">
          <!-- AI Simulation Header -->
          <div class="flex items-center justify-between mb-4">
            <div class="flex items-center space-x-2">
              <div class="w-3 h-3 bg-emerald-400 rounded-full"></div>
              <span class="text-emerald-400 text-sm font-medium">AI Simulation</span>
            </div>
            <div class="text-gray-400 text-sm">Live Session</div>
          </div>
          
          <!-- Chat Interface -->
          <div class="space-y-4 mb-6">
            <div class="flex items-start space-x-3">
              <div class="w-8 h-8 bg-gradient-to-br from-blue-500 to-purple-600 rounded-full flex items-center justify-center">
                <span class="text-white text-sm font-semibold">AI</span>
              </div>
              <div class="bg-gray-800/50 rounded-lg p-3 max-w-xs">
                <p class="text-gray-300 text-sm">How are you feeling today? I notice you seem a bit stressed...</p>
              </div>
            </div>
            
            <div class="flex items-start space-x-3 justify-end">
              <div class="bg-emerald-600/20 border border-emerald-500/30 rounded-lg p-3 max-w-xs">
                <p class="text-gray-300 text-sm">I've been having trouble sleeping and feeling anxious about work...</p>
              </div>
              <div class="w-8 h-8 bg-gradient-to-br from-emerald-500 to-cyan-500 rounded-full flex items-center justify-center">
                <span class="text-white text-sm font-semibold">U</span>
              </div>
            </div>
          </div>
          
          <!-- Session Analytics -->
          <div class="border-t border-gray-700/50 pt-4">
            <div class="text-gray-400 text-xs mb-2">Session Analytics - Live</div>
            <div class="grid grid-cols-3 gap-4">
              <div class="text-center">
                <div class="text-emerald-400 font-semibold">92%</div>
                <div class="text-gray-500 text-xs">Engagement</div>
              </div>
              <div class="text-center">
                <div class="text-blue-400 font-semibold">8.4</div>
                <div class="text-gray-500 text-xs">Empathy</div>
              </div>
              <div class="text-center">
                <div class="text-purple-400 font-semibold">A+</div>
                <div class="text-gray-500 text-xs">Grade</div>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Floating Indicators -->
        <div class="absolute -top-4 -right-4 bg-emerald-500 text-white px-3 py-1 rounded-full text-sm font-medium animate-pulse">
          &lt; 100ms response
        </div>
      </div>
    </div>
  </div>
</section>