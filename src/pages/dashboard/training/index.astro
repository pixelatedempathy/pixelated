---
export const prerender = false

import DashboardLayout from '../../../layouts/DashboardLayout.astro'
import DashboardCard from '@/components/ui/DashboardCard.astro'

const sessions = [
  { id: 1, title: 'Crisis Intervention', date: '2024-11-10', status: 'completed', score: '--' },
  { id: 2, title: 'Trauma Response', date: '2024-11-09', status: 'completed', score: '--' },
  { id: 3, title: 'Empathy Building', date: '2024-11-08', status: 'in-progress', score: '--' }
]
---

<DashboardLayout title="Training Sessions - Pixelated Empathy">
  <div class="space-y-8">
    <div class="flex items-center justify-between">
      <h1 class="text-3xl font-bold text-white">Training Sessions</h1>
      <a 
        href="/dashboard/training/new"
        class="px-6 py-3 bg-gradient-to-r from-emerald-500 to-cyan-500 hover:from-emerald-600 hover:to-cyan-600 text-black font-bold rounded-lg transition-all duration-200 transform hover:scale-105"
      >
        Start New Session
      </a>
    </div>

    <DashboardCard title="All Sessions">
      <div class="space-y-3">
        {sessions.map((session) => (
          <a 
            href={`/dashboard/training/${session.id}`}
            class="flex items-center justify-between p-4 bg-white/5 rounded-lg hover:bg-white/10 transition-colors"
          >
            <div>
              <h3 class="font-semibold text-white">{session.title}</h3>
              <p class="text-sm text-gray-400">{session.date}</p>
            </div>
            <div class="flex items-center gap-4">
              <span class={`px-3 py-1 rounded-full text-xs font-medium ${
                session.status === 'completed' ? 'bg-emerald-500/20 border border-emerald-500/30 text-emerald-400' :
                'bg-cyan-500/20 border border-cyan-500/30 text-cyan-400'
              }`}>
                {session.status}
              </span>
            </div>
          </a>
        ))}
      </div>
    </DashboardCard>
  </div>
</DashboardLayout>
