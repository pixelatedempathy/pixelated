---
import Layout from '../layouts/Layout.astro'
import Button from '../components/ui/Button.astro'
---

<Layout title="Pricing - Pixelated Empathy">
  <main class="min-h-screen bg-black text-white">
    <!-- Hero Section -->
    <section class="relative py-32 px-6">
      <!-- Background Elements -->
      <div class="absolute inset-0 overflow-hidden">
        <div class="absolute top-20 left-10 w-96 h-96 bg-gradient-to-r from-emerald-500/20 to-cyan-500/20 rounded-full blur-3xl"></div>
        <div class="absolute bottom-20 right-10 w-80 h-80 bg-gradient-to-r from-purple-500/20 to-pink-500/20 rounded-full blur-3xl"></div>
      </div>

      <div class="relative max-w-7xl mx-auto text-center">
        <h1 class="text-5xl lg:text-7xl font-bold mb-6">
          <span class="bg-gradient-to-r from-emerald-400 via-cyan-400 to-blue-400 bg-clip-text text-transparent">
            Simple, Transparent Pricing
          </span>
        </h1>
        <p class="text-xl text-gray-300 max-w-3xl mx-auto mb-8">
          Choose the plan that fits your training needs. All plans include our core AI training platform with different levels of access and support.
        </p>
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-emerald-500/10 border border-emerald-500/20 rounded-full text-emerald-400 text-sm font-mono">
          <div class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></div>
          14-day free trial • No credit card required
        </div>
      </div>
    </section>

    <!-- Pricing Cards -->
    <section class="py-20 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="grid lg:grid-cols-3 gap-8">
          
          <!-- Free Trial -->
          <div class="relative group">
            <div class="absolute inset-0 bg-gradient-to-r from-gray-500/20 to-gray-400/20 rounded-2xl blur-xl group-hover:blur-2xl transition-all duration-300"></div>
            <div class="relative bg-black/40 backdrop-blur-xl border border-white/10 rounded-2xl p-8 hover:border-white/20 transition-all duration-300">
              <div class="text-center mb-8">
                <h3 class="text-2xl font-bold text-white mb-2">Free Trial</h3>
                <div class="text-4xl font-bold text-white mb-2">$0</div>
                <p class="text-gray-400">14 days • No commitment</p>
              </div>
              
              <ul class="space-y-4 mb-8">
                <li class="flex items-center gap-3">
                  <div class="w-5 h-5 bg-emerald-500 rounded-full flex items-center justify-center">
                    <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                    </svg>
                  </div>
                  <span class="text-gray-300">5 AI training scenarios</span>
                </li>
                <li class="flex items-center gap-3">
                  <div class="w-5 h-5 bg-emerald-500 rounded-full flex items-center justify-center">
                    <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                    </svg>
                  </div>
                  <span class="text-gray-300">Basic progress tracking</span>
                </li>
                <li class="flex items-center gap-3">
                  <div class="w-5 h-5 bg-emerald-500 rounded-full flex items-center justify-center">
                    <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                    </svg>
                  </div>
                  <span class="text-gray-300">Email support</span>
                </li>
                <li class="flex items-center gap-3">
                  <div class="w-5 h-5 bg-emerald-500 rounded-full flex items-center justify-center">
                    <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                    </svg>
                  </div>
                  <span class="text-gray-300">Community access</span>
                </li>
              </ul>
              
              <button class="w-full py-3 px-6 bg-white/10 hover:bg-white/20 border border-white/20 rounded-lg text-white font-medium transition-all duration-200">
                Start Free Trial
              </button>
            </div>
          </div>

          <!-- Professional (Most Popular) -->
          <div class="relative group">
            <div class="absolute -inset-1 bg-gradient-to-r from-emerald-500 to-cyan-500 rounded-2xl blur-xl group-hover:blur-2xl transition-all duration-300"></div>
            <div class="relative bg-black/40 backdrop-blur-xl border border-emerald-500/50 rounded-2xl p-8">
              <div class="absolute -top-4 left-1/2 transform -translate-x-1/2">
                <div class="bg-gradient-to-r from-emerald-500 to-cyan-500 text-black px-4 py-1 rounded-full text-sm font-bold">
                  Most Popular
                </div>
              </div>
              
              <div class="text-center mb-8 mt-4">
                <h3 class="text-2xl font-bold text-white mb-2">Professional</h3>
                <div class="text-4xl font-bold text-white mb-2">
                  $99<span class="text-lg text-gray-400">/month</span>
                </div>
                <p class="text-gray-400">Perfect for individual practitioners</p>
              </div>
              
              <ul class="space-y-4 mb-8">
                <li class="flex items-center gap-3">
                  <div class="w-5 h-5 bg-emerald-500 rounded-full flex items-center justify-center">
                    <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                    </svg>
                  </div>
                  <span class="text-gray-300">Unlimited AI scenarios</span>
                </li>
                <li class="flex items-center gap-3">
                  <div class="w-5 h-5 bg-emerald-500 rounded-full flex items-center justify-center">
                    <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                    </svg>
                  </div>
                  <span class="text-gray-300">Advanced analytics & insights</span>
                </li>
                <li class="flex items-center gap-3">
                  <div class="w-5 h-5 bg-emerald-500 rounded-full flex items-center justify-center">
                    <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                    </svg>
                  </div>
                  <span class="text-gray-300">Crisis intervention training</span>
                </li>
                <li class="flex items-center gap-3">
                  <div class="w-5 h-5 bg-emerald-500 rounded-full flex items-center justify-center">
                    <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                    </svg>
                  </div>
                  <span class="text-gray-300">Priority support</span>
                </li>
                <li class="flex items-center gap-3">
                  <div class="w-5 h-5 bg-emerald-500 rounded-full flex items-center justify-center">
                    <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                    </svg>
                  </div>
                  <span class="text-gray-300">Custom scenario builder</span>
                </li>
                <li class="flex items-center gap-3">
                  <div class="w-5 h-5 bg-emerald-500 rounded-full flex items-center justify-center">
                    <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                    </svg>
                  </div>
                  <span class="text-gray-300">Progress certification</span>
                </li>
              </ul>
              
              <button class="w-full py-3 px-6 bg-gradient-to-r from-emerald-500 to-cyan-500 hover:from-emerald-600 hover:to-cyan-600 text-black font-bold rounded-lg transition-all duration-200 transform hover:scale-105">
                Start Professional
              </button>
            </div>
          </div>

          <!-- Enterprise -->
          <div class="relative group">
            <div class="absolute inset-0 bg-gradient-to-r from-purple-500/20 to-pink-500/20 rounded-2xl blur-xl group-hover:blur-2xl transition-all duration-300"></div>
            <div class="relative bg-black/40 backdrop-blur-xl border border-white/10 rounded-2xl p-8 hover:border-purple-500/30 transition-all duration-300">
              <div class="text-center mb-8">
                <h3 class="text-2xl font-bold text-white mb-2">Enterprise</h3>
                <div class="text-4xl font-bold text-white mb-2">Custom</div>
                <p class="text-gray-400">For institutions & large teams</p>
              </div>
              
              <ul class="space-y-4 mb-8">
                <li class="flex items-center gap-3">
                  <div class="w-5 h-5 bg-purple-500 rounded-full flex items-center justify-center">
                    <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                    </svg>
                  </div>
                  <span class="text-gray-300">Everything in Professional</span>
                </li>
                <li class="flex items-center gap-3">
                  <div class="w-5 h-5 bg-purple-500 rounded-full flex items-center justify-center">
                    <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                    </svg>
                  </div>
                  <span class="text-gray-300">Unlimited team members</span>
                </li>
                <li class="flex items-center gap-3">
                  <div class="w-5 h-5 bg-purple-500 rounded-full flex items-center justify-center">
                    <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                    </svg>
                  </div>
                  <span class="text-gray-300">White-label solution</span>
                </li>
                <li class="flex items-center gap-3">
                  <div class="w-5 h-5 bg-purple-500 rounded-full flex items-center justify-center">
                    <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                    </svg>
                  </div>
                  <span class="text-gray-300">API access & integrations</span>
                </li>
                <li class="flex items-center gap-3">
                  <div class="w-5 h-5 bg-purple-500 rounded-full flex items-center justify-center">
                    <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                    </svg>
                  </div>
                  <span class="text-gray-300">Dedicated success manager</span>
                </li>
                <li class="flex items-center gap-3">
                  <div class="w-5 h-5 bg-purple-500 rounded-full flex items-center justify-center">
                    <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                    </svg>
                  </div>
                  <span class="text-gray-300">SLA & compliance support</span>
                </li>
              </ul>
              
              <button class="w-full py-3 px-6 bg-gradient-to-r from-purple-500 to-pink-500 hover:from-purple-600 hover:to-pink-600 text-white font-bold rounded-lg transition-all duration-200 transform hover:scale-105">
                Contact Sales
              </button>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="py-20 px-6">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-4xl font-bold text-center mb-16">
          <span class="bg-gradient-to-r from-emerald-400 to-cyan-400 bg-clip-text text-transparent">
            Frequently Asked Questions
          </span>
        </h2>
        
        <div class="space-y-6">
          <div class="bg-black/40 backdrop-blur-xl border border-white/10 rounded-xl p-6">
            <h3 class="text-xl font-bold text-white mb-3">What's included in the free trial?</h3>
            <p class="text-gray-300">
              The 14-day free trial includes access to 5 AI training scenarios, basic progress tracking, and email support. No credit card required to start.
            </p>
          </div>
          
          <div class="bg-black/40 backdrop-blur-xl border border-white/10 rounded-xl p-6">
            <h3 class="text-xl font-bold text-white mb-3">Can I upgrade or downgrade my plan?</h3>
            <p class="text-gray-300">
              Yes, you can change your plan at any time. Upgrades take effect immediately, and downgrades take effect at the next billing cycle.
            </p>
          </div>
          
          <div class="bg-black/40 backdrop-blur-xl border border-white/10 rounded-xl p-6">
            <h3 class="text-xl font-bold text-white mb-3">Is my data secure and HIPAA compliant?</h3>
            <p class="text-gray-300">
              Absolutely. We use enterprise-grade encryption and are fully HIPAA compliant. All training data is anonymized and encrypted both in transit and at rest.
            </p>
          </div>
          
          <div class="bg-black/40 backdrop-blur-xl border border-white/10 rounded-xl p-6">
            <h3 class="text-xl font-bold text-white mb-3">Do you offer training and onboarding?</h3>
            <p class="text-gray-300">
              Professional plans include priority support and training resources. Enterprise customers get dedicated onboarding and a success manager.
            </p>
          </div>
          
          <div class="bg-black/40 backdrop-blur-xl border border-white/10 rounded-xl p-6">
            <h3 class="text-xl font-bold text-white mb-3">What payment methods do you accept?</h3>
            <p class="text-gray-300">
              We accept all major credit cards, ACH transfers, and can accommodate purchase orders for Enterprise customers.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-20 px-6">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-4xl font-bold mb-6">
          <span class="bg-gradient-to-r from-emerald-400 to-cyan-400 bg-clip-text text-transparent">
            Ready to Transform Your Training?
          </span>
        </h2>
        <p class="text-xl text-gray-300 mb-8">
          Join thousands of mental health professionals who trust Pixelated Empathy for their training needs.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <Button 
            size="lg"
            class="bg-gradient-to-r from-emerald-500 to-cyan-500 hover:from-emerald-600 hover:to-cyan-600 text-black font-bold transform hover:scale-105"
          >
            Start Free Trial
          </Button>
          <Button 
            variant="outline"
            size="lg"
          >
            Schedule Demo
          </Button>
        </div>
      </div>
    </section>
  </main>
</Layout>
