---
/**
 * Header Component - Redesigned
 * Mizu: Floating glass navigation with smooth interactions
 * Antfu: Minimal, clean design with subtle hover states
 */
import Search from '../ui/Search.astro'
---

<!-- Mizu: Floating Glass Navigation -->
<header class="fixed top-4 left-0 right-0 z-50 px-4">
  <nav
    class="max-w-6xl mx-auto bg-black/40 backdrop-blur-xl border border-white/10 rounded-full px-6 py-3 shadow-2xl"
  >
    <div class="flex items-center justify-between">
      <!-- Brand -->
      <a href="/" class="flex items-center gap-3 group">
        <div
          class="w-8 h-8 bg-gradient-to-br from-emerald-400 to-cyan-400 rounded-lg flex items-center justify-center transition-transform duration-200 group-hover:scale-110"
        >
          <span class="text-white font-bold text-sm">PE</span>
        </div>
        <div class="hidden sm:block">
          <div class="text-white font-semibold text-sm leading-tight">
            Pixelated Empathy
          </div>
          <div class="text-gray-400 text-xs">AI Training Platform</div>
        </div>
      </a>

      <!-- Antfu: Minimal Navigation Links -->
      <div class="hidden md:flex items-center gap-1">
        <a
          href="/features"
          class="nav-link px-4 py-2 text-sm text-gray-300 hover:text-white hover:bg-white/5 rounded-full transition-all duration-150"
        >
          Features
        </a>
        <a
          href="/demos"
          class="nav-link px-4 py-2 text-sm text-gray-300 hover:text-white hover:bg-white/5 rounded-full transition-all duration-150"
        >
          Demos
        </a>
        <a
          href="/pricing"
          class="nav-link px-4 py-2 text-sm text-gray-300 hover:text-white hover:bg-white/5 rounded-full transition-all duration-150"
        >
          Pricing
        </a>
        <a
          href="/team"
          class="nav-link px-4 py-2 text-sm text-gray-300 hover:text-white hover:bg-white/5 rounded-full transition-all duration-150"
        >
          Team
        </a>
        <a
          href="/blog"
          class="nav-link px-4 py-2 text-sm text-gray-300 hover:text-white hover:bg-white/5 rounded-full transition-all duration-150"
        >
          Blog
        </a>
      </div>

      <!-- CTAs -->
      <div class="flex items-center gap-3">
        <Search />
        <a
          href="/signin"
          class="hidden sm:block text-sm text-gray-300 hover:text-white transition-colors duration-150"
        >
          Sign In
        </a>
        <!-- Flabbergasted: Bold CTA -->
        <a
          href="/get-started"
          class="px-5 py-2 bg-gradient-to-r from-emerald-500 to-cyan-500 text-white text-sm font-semibold rounded-full hover:shadow-lg hover:shadow-emerald-500/50 hover:-translate-y-0.5 transition-all duration-200"
        >
          Get Started
        </a>

        <!-- Mobile Menu Button -->
        <button
          id="mobile-menu-button"
          class="md:hidden p-2 text-gray-300 hover:text-white transition-colors"
          aria-label="Toggle menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>
  </nav>
</header>

<!-- Mobile Menu - AstroMaxx Glass Effect -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 hidden"
  tabindex="-1"
  aria-modal="true"
  role="dialog"
  aria-hidden="true"
>
  <div
    class="absolute inset-0 bg-black/80 backdrop-blur-sm"
    id="mobile-menu-backdrop"
  >
  </div>
  <div
    class="absolute top-20 left-4 right-4 bg-black/90 backdrop-blur-xl border border-white/10 rounded-2xl p-6 shadow-2xl"
    id="mobile-menu-panel"
  >
    <nav class="flex flex-col gap-2">
      <a
        href="/features"
        class="px-4 py-3 text-gray-300 hover:text-white hover:bg-white/5 rounded-lg transition-all"
      >
        Features
      </a>
      <a
        href="/demos"
        class="px-4 py-3 text-gray-300 hover:text-white hover:bg-white/5 rounded-lg transition-all"
      >
        Demos
      </a>
      <a
        href="/pricing"
        class="px-4 py-3 text-gray-300 hover:text-white hover:bg-white/5 rounded-lg transition-all"
      >
        Pricing
      </a>
      <a
        href="/team"
        class="px-4 py-3 text-gray-300 hover:text-white hover:bg-white/5 rounded-lg transition-all"
      >
        Team
      </a>
      <a
        href="/blog"
        class="px-4 py-3 text-gray-300 hover:text-white hover:bg-white/5 rounded-lg transition-all"
      >
        Blog
      </a>
      <div class="h-px bg-white/10 my-2"></div>
      <a
        href="/signin"
        class="px-4 py-3 text-gray-300 hover:text-white hover:bg-white/5 rounded-lg transition-all"
      >
        Sign In
      </a>
      <a
        href="/get-started"
        class="px-4 py-3 bg-gradient-to-r from-emerald-500 to-cyan-500 text-white font-semibold rounded-lg text-center hover:shadow-lg transition-all"
      >
        Get Started
      </a>
    </nav>
  </div>
</div>

<script>
  // Mizu: Smooth mobile menu interactions with accessibility
  const menuButton = document.getElementById('mobile-menu-button')
  const mobileMenu = document.getElementById('mobile-menu')
  const menuPanel = document.getElementById('mobile-menu-panel')
  const backdrop = document.getElementById('mobile-menu-backdrop')

  const focusableSelectors = [
    'a[href]',
    'button:not([disabled])',
    'textarea:not([disabled])',
    'input[type="text"]:not([disabled])',
    'input[type="radio"]:not([disabled])',
    'input[type="checkbox"]:not([disabled])',
    'select:not([disabled])',
    '[tabindex]:not([tabindex="-1"])',
  ]

  function getFocusableElements() {
    return menuPanel?.querySelectorAll(focusableSelectors.join(',')) || []
  }

  function trapFocus(e: KeyboardEvent) {
    if (!mobileMenu?.classList.contains('hidden')) {
      const focusable = getFocusableElements()
      if (focusable.length === 0) return

      const first = focusable[0] as HTMLElement
      const last = focusable[focusable.length - 1] as HTMLElement

      if (e.key === 'Tab') {
        if (e.shiftKey) {
          if (document.activeElement === first) {
            e.preventDefault()
            last.focus()
          }
        } else {
          if (document.activeElement === last) {
            e.preventDefault()
            first.focus()
          }
        }
      }

      if (e.key === 'Escape') {
        closeMenu()
      }
    }
  }

  function openMenu() {
    mobileMenu?.classList.remove('hidden')
    mobileMenu?.setAttribute('aria-hidden', 'false')
    menuButton?.setAttribute('aria-expanded', 'true')

    // Focus the first focusable element in the menu
    setTimeout(() => {
      const focusable = getFocusableElements()
      if (focusable.length) (focusable[0] as HTMLElement).focus()
      else mobileMenu?.focus()
    }, 0)

    document.addEventListener('keydown', trapFocus)
  }

  function closeMenu() {
    mobileMenu?.classList.add('hidden')
    mobileMenu?.setAttribute('aria-hidden', 'true')
    menuButton?.setAttribute('aria-expanded', 'false')
    document.removeEventListener('keydown', trapFocus)

    // Return focus to the menu button
    menuButton?.focus()
  }

  menuButton?.addEventListener('click', () => {
    if (mobileMenu?.classList.contains('hidden')) {
      openMenu()
    } else {
      closeMenu()
    }
  })

  backdrop?.addEventListener('click', closeMenu)

  // Expose for external use if needed
  ;(window as any).openMobileMenu = openMenu
  ;(window as any).closeMobileMenu = closeMenu

  // Mizu: Active nav indicator on scroll
  const navLinks = document.querySelectorAll('.nav-link')
  const sections = document.querySelectorAll('section[id]')

  function highlightNav() {
    const scrollY = window.scrollY

    sections.forEach((section) => {
      const sectionHeight = (section as HTMLElement).offsetHeight
      const sectionTop = (section as HTMLElement).offsetTop - 100
      const sectionId = section.getAttribute('id')

      if (scrollY > sectionTop && scrollY <= sectionTop + sectionHeight) {
        navLinks.forEach((link) => {
          link.classList.remove('active', 'text-white')
          if (link.getAttribute('href') === `/#${sectionId}`) {
            link.classList.add('active', 'text-white')
          }
        })
      }
    })
  }

  window.addEventListener('scroll', highlightNav)
</script>

<style>
  /* Mizu: Active nav indicator */
  .nav-link.active {
    position: relative;
  }

  .nav-link.active::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 4px;
    height: 4px;
    background: linear-gradient(to right, #10b981, #06b6d4);
    border-radius: 50%;
  }
</style>
