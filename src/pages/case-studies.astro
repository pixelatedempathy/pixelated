---
export const prerender = true

import Layout from '@/layouts/Layout.astro'
import PageHero from '@/components/ui/PageHero.astro'
import ContentSection from '@/components/ui/ContentSection.astro'
import StatsGrid from '@/components/ui/StatsGrid.astro'

const caseStudies = [
  {
    title: "[Healthcare Institution - Anonymized]",
    subtitle: "Improved Crisis Intervention Training",
    description: "Implementation of AI-powered training simulations resulted in measurable improvements in staff confidence and competency assessments.",
    metrics: [
      { label: "Training Hours", value: "--", color: "white" },
      { label: "Satisfaction", value: "--", color: "emerald" },
      { label: "Improvement", value: "--", color: "cyan" }
    ],
    category: "Crisis Intervention"
  },
  {
    title: "[Medical Center - Anonymized]",
    subtitle: "Enhanced Resident Training Program", 
    description: "Integration of simulation-based learning reduced traditional training time while maintaining competency standards.",
    metrics: [
      { label: "Training Hours", value: "--", color: "white" },
      { label: "Satisfaction", value: "--", color: "emerald" },
      { label: "Improvement", value: "--", color: "cyan" }
    ],
    category: "Medical Education"
  },
  {
    title: "[Healthcare Network - Anonymized]",
    subtitle: "Cultural Competency Training Initiative",
    description: "Multi-site deployment improved cultural sensitivity training and reduced patient feedback concerns across facilities.",
    metrics: [
      { label: "Training Hours", value: "--", color: "white" },
      { label: "Satisfaction", value: "--", color: "emerald" },
      { label: "Improvement", value: "--", color: "cyan" }
    ],
    category: "Cultural Competency"
  }
]
---

<Layout title="Case Studies - Pixelated Empathy">
  <PageHero
    badge="Real Results"
    title="Case Studies"
    subtitle="Discover how leading healthcare institutions have transformed their training programs and improved patient outcomes with our AI-powered platform."
    gradient={true}
  />

  <!-- Case Studies -->
  <ContentSection>
    <div class="space-y-12">
      {caseStudies.map((study) => (
        <div class="relative group">
          <div class="absolute inset-0 bg-gradient-to-r from-emerald-500/20 to-cyan-500/20 rounded-2xl blur-xl group-hover:blur-2xl transition-all duration-300"></div>
          <div class="relative bg-black/40 backdrop-blur-xl border border-white/10 rounded-2xl p-8 hover:border-emerald-500/30 transition-all duration-300">
            <div class="inline-block px-3 py-1 bg-emerald-500/20 border border-emerald-500/30 rounded-full text-emerald-400 text-sm font-medium mb-4">
              {study.category}
            </div>
            <h2 class="text-3xl font-bold text-white mb-2">{study.title}</h2>
            <h3 class="text-xl text-emerald-400 mb-4">{study.subtitle}</h3>
            <p class="text-gray-300 leading-relaxed mb-6">{study.description}</p>
            
            <StatsGrid stats={study.metrics} columns={3} />
            
            <div class="mt-6">
              <button class="px-6 py-3 bg-gradient-to-r from-emerald-500 to-cyan-500 hover:from-emerald-600 hover:to-cyan-600 text-black font-bold rounded-lg transition-all duration-200 transform hover:scale-105">
                Download Full Case Study
              </button>
            </div>
          </div>
        </div>
      ))}
    </div>
  </ContentSection>

  <!-- CTA -->
  <ContentSection diagonal={true}>
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-4xl font-bold mb-6">
        <span class="bg-gradient-to-r from-emerald-400 to-cyan-400 bg-clip-text text-transparent">
          Ready to Transform Your Training?
        </span>
      </h2>
      <p class="text-xl text-gray-300 mb-8">
        Join leading healthcare institutions using Pixelated Empathy to improve training outcomes.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a 
          href="/contact"
          class="inline-flex items-center justify-center px-8 py-4 bg-gradient-to-r from-emerald-500 to-cyan-500 hover:from-emerald-600 hover:to-cyan-600 text-black font-bold rounded-lg transition-all duration-200 transform hover:scale-105"
        >
          Contact Sales
        </a>
        <a 
          href="/demos"
          class="inline-flex items-center justify-center px-8 py-4 bg-white/10 hover:bg-white/20 border border-white/20 rounded-lg text-white font-medium transition-all duration-200"
        >
          Schedule Demo
        </a>
      </div>
    </div>
  </ContentSection>
</Layout>
