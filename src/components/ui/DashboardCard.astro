---
interface Props {
  title: string
  value?: string
  change?: string
  changeType?: 'positive' | 'negative' | 'neutral'
  icon?: string
  status?: 'success' | 'warning' | 'error' | 'info'
  href?: string
}

const { title, value, change, changeType = 'neutral', icon, status, href } = Astro.props

const statusColors = {
  success: 'border-emerald-500/30 bg-emerald-500/10',
  warning: 'border-orange-500/30 bg-orange-500/10',
  error: 'border-red-500/30 bg-red-500/10',
  info: 'border-cyan-500/30 bg-cyan-500/10'
}

const changeColors = {
  positive: 'text-emerald-400',
  negative: 'text-red-400',
  neutral: 'text-gray-400'
}

const Component = href ? 'a' : 'div'
---

<Component 
  href={href}
  class={`bg-black/40 backdrop-blur-xl border rounded-2xl p-6 transition-all duration-300 ${href ? 'hover:border-white/20 hover:-translate-y-1 cursor-pointer' : ''} ${status ? statusColors[status] : 'border-white/10'}`}
>
  <div class="flex items-start justify-between mb-4">
    <div class="flex-1">
      <h3 class="text-sm font-medium text-gray-400 mb-1">{title}</h3>
      {value && (
        <div class="text-3xl font-bold text-white">{value}</div>
      )}
    </div>
    {icon && (
      <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-emerald-500/20 to-cyan-500/10 flex items-center justify-center">
        <Fragment set:html={icon} />
      </div>
    )}
  </div>
  
  {change && (
    <div class={`flex items-center gap-1 text-sm ${changeColors[changeType]}`}>
      {changeType === 'positive' && (
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M5.293 9.707a1 1 0 010-1.414l4-4a1 1 0 011.414 0l4 4a1 1 0 01-1.414 1.414L11 7.414V15a1 1 0 11-2 0V7.414L6.707 9.707a1 1 0 01-1.414 0z" clip-rule="evenodd" />
        </svg>
      )}
      {changeType === 'negative' && (
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M14.707 10.293a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 111.414-1.414L9 12.586V5a1 1 0 012 0v7.586l2.293-2.293a1 1 0 011.414 0z" clip-rule="evenodd" />
        </svg>
      )}
      <span>{change}</span>
    </div>
  )}
  
  <slot />
</Component>
