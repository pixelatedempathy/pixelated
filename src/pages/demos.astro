---
export const prerender = true

import Layout from '../layouts/Layout.astro'
import PageHero from '../components/ui/PageHero.astro'
import ContentSection from '../components/ui/ContentSection.astro'

const scenarios = [
  {
    title: "Crisis Intervention",
    subtitle: "High-stakes scenario training",
    description: "Practice handling crisis situations with AI patients showing signs of severe distress. Learn de-escalation techniques and emergency protocols.",
    features: [
      "Suicidal ideation scenarios",
      "Real-time risk assessment",
      "Emergency protocol guidance"
    ],
    color: "red",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"></path>`,
    link: "/crisis-detection-demo"
  },
  {
    title: "Trauma Response",
    subtitle: "Sensitive care scenarios",
    description: "Learn to work with trauma survivors using evidence-based approaches. Practice creating safe spaces and building therapeutic rapport.",
    features: [
      "PTSD treatment scenarios",
      "Trauma-informed care",
      "Safety and stabilization"
    ],
    color: "purple",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>`,
    link: "/clinical-analysis-demo"
  },
  {
    title: "Empathy Building",
    subtitle: "Connection-focused training",
    description: "Develop deeper empathetic responses through realistic patient interactions. Learn to recognize and respond to emotional cues effectively.",
    features: [
      "Active listening practice",
      "Emotional validation",
      "Rapport building techniques"
    ],
    color: "emerald",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>`,
    link: "/demo-hub"
  },
  {
    title: "Cultural Competency",
    subtitle: "Diverse population training",
    description: "Practice culturally sensitive care with diverse patient populations. Learn to navigate cultural differences and provide inclusive treatment.",
    features: [
      "Cross-cultural scenarios",
      "Bias awareness training",
      "Inclusive communication"
    ],
    color: "blue",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>`,
    link: "/demo-hub"
  }
]
---

<Layout title="Demos - Pixelated Empathy">
  <PageHero
    badge="Live AI Simulation"
    title="See It In Action"
    subtitle="Experience the power of AI-driven mental health training. Watch our demos to see how Pixelated Empathy transforms professional development."
    gradient={true}
  />

  <!-- Video Demo -->
  <ContentSection>
    <div class="text-center mb-12">
      <h2 class="text-4xl font-bold mb-4">
        <span class="bg-gradient-to-r from-blue-400 to-purple-400 bg-clip-text text-transparent">
          Platform Overview
        </span>
      </h2>
      <p class="text-xl text-gray-300">
        Watch a 3-minute overview of our AI training platform
      </p>
    </div>

    <div class="relative group max-w-5xl mx-auto">
      <div class="absolute inset-0 bg-gradient-to-r from-blue-500/20 to-purple-500/20 rounded-2xl blur-xl group-hover:blur-2xl transition-all duration-300"></div>
      <div class="relative bg-black/40 backdrop-blur-xl border border-white/10 rounded-2xl overflow-hidden">
        <div class="aspect-video bg-gradient-to-br from-gray-900 to-black flex items-center justify-center cursor-pointer">
          <div class="text-center">
            <div class="w-20 h-20 bg-gradient-to-r from-blue-500 to-purple-500 rounded-full flex items-center justify-center mb-4 mx-auto cursor-pointer hover:scale-110 transition-transform duration-200">
              <svg class="w-8 h-8 text-white ml-1" fill="currentColor" viewBox="0 0 20 20">
                <path d="M6.3 2.841A1.5 1.5 0 004 4.11V15.89a1.5 1.5 0 002.3 1.269l9.344-5.89a1.5 1.5 0 000-2.538L6.3 2.84z"/>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-white mb-2">Platform Demo Video</h3>
            <p class="text-gray-400">Click to watch our comprehensive platform overview</p>
          </div>
        </div>
      </div>
    </div>
  </ContentSection>

  <!-- Training Scenarios -->
  <ContentSection diagonal={true}>
    <div class="text-center mb-12">
      <h2 class="text-4xl font-bold mb-4">
        <span class="bg-gradient-to-r from-emerald-400 to-cyan-400 bg-clip-text text-transparent">
          Try Our Training Scenarios
        </span>
      </h2>
      <p class="text-xl text-gray-300">
        Experience different types of training scenarios our platform offers
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-8">
      {scenarios.map((scenario) => (
        <div class="relative group">
          <div class={`absolute inset-0 bg-gradient-to-r from-${scenario.color}-500/20 to-cyan-500/20 rounded-2xl blur-xl group-hover:blur-2xl transition-all duration-300`}></div>
          <div class={`relative bg-black/40 backdrop-blur-xl border border-white/10 rounded-2xl p-8 hover:border-${scenario.color}-500/30 transition-all duration-300`}>
            <div class="flex items-center gap-4 mb-6">
              <div class={`w-12 h-12 bg-gradient-to-r from-${scenario.color}-500 to-cyan-500 rounded-lg flex items-center justify-center`}>
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={scenario.icon} />
              </div>
              <div>
                <h3 class="text-xl font-bold text-white">{scenario.title}</h3>
                <p class="text-gray-400">{scenario.subtitle}</p>
              </div>
            </div>
            
            <p class="text-gray-300 mb-6">{scenario.description}</p>
            
            <div class="space-y-3 mb-6">
              {scenario.features.map((feature) => (
                <div class="flex items-center gap-2 text-sm text-gray-400">
                  <div class={`w-2 h-2 bg-${scenario.color}-400 rounded-full`}></div>
                  <span>{feature}</span>
                </div>
              ))}
            </div>
            
            <a href={scenario.link} class={`block w-full py-3 px-6 bg-gradient-to-r from-${scenario.color}-500 to-cyan-500 hover:from-${scenario.color}-600 hover:to-cyan-600 text-white font-bold rounded-lg transition-all duration-200 transform hover:scale-105 text-center`}>
              Try {scenario.title}
            </a>
          </div>
        </div>
      ))}
    </div>
  </ContentSection>

  <!-- Schedule Demo CTA -->
  <ContentSection>
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-4xl font-bold mb-6">
        <span class="bg-gradient-to-r from-emerald-400 to-cyan-400 bg-clip-text text-transparent">
          Want a Personalized Demo?
        </span>
      </h2>
      <p class="text-xl text-gray-300 mb-8">
        Schedule a live demo with our team to see how Pixelated Empathy can transform your training program.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a 
          href="/contact"
          class="inline-flex items-center justify-center px-8 py-4 bg-gradient-to-r from-emerald-500 to-cyan-500 hover:from-emerald-600 hover:to-cyan-600 text-black font-bold rounded-lg transition-all duration-200 transform hover:scale-105"
        >
          Schedule Live Demo
        </a>
        <a 
          href="/demo-hub"
          class="inline-flex items-center justify-center px-8 py-4 bg-white/10 hover:bg-white/20 border border-white/20 rounded-lg text-white font-medium transition-all duration-200"
        >
          Explore All Demos
        </a>
      </div>
    </div>
  </ContentSection>
</Layout>
