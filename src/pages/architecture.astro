---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Container from '@/components/tailus/Container.astro'
import Frame from '@/components/tailus/Frame.astro'
import { Button } from '@/components/ui/button'
---

<BaseLayout
  title="Technical Architecture - Pixelated Empathy"
  description="Enterprise-grade cloud-native architecture powering AI-driven mental health training platform"
  bgType="dark"
>
  <!-- Hero Section - Architecture Showcase -->
  <section class="relative overflow-hidden py-20 lg:py-32">
    <Container>
      <div class="lg:w-2/3 text-center mx-auto">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-emerald-500/10 text-emerald-500 rounded-full text-sm font-medium mb-8">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
          Cloud-Native Enterprise Architecture
        </div>

        <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold text-gray-900 dark:text-white mb-6">
          Built for Scale,
          <span class="text-emerald-500">Ready for Enterprise</span>
        </h1>

        <p class="text-xl text-gray-600 dark:text-gray-300 max-w-3xl mx-auto mb-8">
          Cloudflare Workers-powered architecture with serverless scalability, real-time AI processing,
          and enterprise-grade security. Deployed globally with sub-100ms response times.
        </p>

        <div class="flex flex-wrap justify-center gap-4">
          <Frame>
            <a href="#performance" class="px-6 py-3 bg-emerald-500 hover:bg-emerald-600 text-white rounded-lg font-medium transition-colors">
              View Performance Metrics
            </a>
          </Frame>
          <Frame>
            <a href="#security" class="px-6 py-3 bg-gray-100 hover:bg-gray-200 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-900 dark:text-white rounded-lg font-medium transition-colors">
              Security Compliance
            </a>
          </Frame>
        </div>
      </div>
    </Container>
  </section>

  <!-- Architecture Overview -->
  <section id="overview" class="py-20 bg-gray-50 dark:bg-gray-900">
    <Container>
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">
          Cloud-Native Architecture Stack
        </h2>
        <p class="text-lg text-gray-600 dark:text-gray-300 max-w-2xl mx-auto">
          Modern serverless architecture designed for global scale, real-time processing,
          and enterprise security requirements.
        </p>
      </div>

      <div class="grid lg:grid-cols-3 gap-8 mb-16">
        <!-- Frontend Layer -->
        <div class="bg-white dark:bg-gray-800 p-8 rounded-2xl border border-gray-200 dark:border-gray-700">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-12 h-12 bg-blue-500/10 rounded-xl flex items-center justify-center">
              <svg class="w-6 h-6 text-blue-500" fill="currentColor" viewBox="0 0 20 20">
                <path d="M3 4a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1V4zM3 10a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H4a1 1 0 01-1-1v-6zM14 9a1 1 0 00-1 1v5a1 1 0 001 1h2a1 1 0 001-1v-5a1 1 0 00-1-1h-2z" />
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 dark:text-white">Frontend Layer</h3>
          </div>
          <ul class="space-y-3 text-gray-600 dark:text-gray-300">
            <li class="flex items-center gap-2">
              <span class="w-2 h-2 bg-emerald-500 rounded-full"></span>
              Astro SSR with React Islands
            </li>
            <li class="flex items-center gap-2">
              <span class="w-2 h-2 bg-emerald-500 rounded-full"></span>
              UnoCSS for atomic styling
            </li>
            <li class="flex items-center gap-2">
              <span class="w-2 h-2 bg-emerald-500 rounded-full"></span>
              Real-time WebSocket connections
            </li>
            <li class="flex items-center gap-2">
              <span class="w-2 h-2 bg-emerald-500 rounded-full"></span>
              Progressive Web App capabilities
            </li>
          </ul>
        </div>

        <!-- Backend Layer -->
        <div class="bg-white dark:bg-gray-800 p-8 rounded-2xl border border-gray-200 dark:border-gray-700">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-12 h-12 bg-purple-500/10 rounded-xl flex items-center justify-center">
              <svg class="w-6 h-6 text-purple-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M2 5a2 2 0 012-2h12a2 2 0 012 2v10a2 2 0 01-2 2H4a2 2 0 01-2-2V5zm14 2H4v6h12V7z" clip-rule="evenodd" />
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 dark:text-white">Backend Layer</h3>
          </div>
          <ul class="space-y-3 text-gray-600 dark:text-gray-300">
            <li class="flex items-center gap-2">
              <span class="w-2 h-2 bg-emerald-500 rounded-full"></span>
              Cloudflare Workers (Serverless)
            </li>
            <li class="flex items-center gap-2">
              <span class="w-2 h-2 bg-emerald-500 rounded-full"></span>
              Multi-database architecture
            </li>
            <li class="flex items-center gap-2">
              <span class="w-2 h-2 bg-emerald-500 rounded-full"></span>
              Real-time AI processing
            </li>
            <li class="flex items-center gap-2">
              <span class="w-2 h-2 bg-emerald-500 rounded-full"></span>
              Microservices architecture
            </li>
          </ul>
        </div>

        <!-- AI/ML Layer -->
        <div class="bg-white dark:bg-gray-800 p-8 rounded-2xl border border-gray-200 dark:border-gray-700">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-12 h-12 bg-emerald-500/10 rounded-xl flex items-center justify-center">
              <svg class="w-6 h-6 text-emerald-500" fill="currentColor" viewBox="0 0 20 20">
                <path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3z" />
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 dark:text-white">AI/ML Layer</h3>
          </div>
          <ul class="space-y-3 text-gray-600 dark:text-gray-300">
            <li class="flex items-center gap-2">
              <span class="w-2 h-2 bg-emerald-500 rounded-full"></span>
              TensorFlow.js for client-side AI
            </li>
            <li class="flex items-center gap-2">
              <span class="w-2 h-2 bg-emerald-500 rounded-full"></span>
              Real-time bias detection
            </li>
            <li class="flex items-center gap-2">
              <span class="w-2 h-2 bg-emerald-500 rounded-full"></span>
              Emotion analysis algorithms
            </li>
            <li class="flex items-center gap-2">
              <span class="w-2 h-2 bg-emerald-500 rounded-full"></span>
              HIPAA-compliant data processing
            </li>
          </ul>
        </div>
      </div>
    </Container>
  </section>

  <!-- Performance Metrics -->
  <section id="performance" class="py-20">
    <Container>
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">
          Enterprise Performance Metrics
        </h2>
        <p class="text-lg text-gray-600 dark:text-gray-300 max-w-2xl mx-auto">
          Real-time performance data demonstrating enterprise-grade reliability and scalability.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
        <div class="text-center p-6 bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700">
          <div class="text-3xl font-bold text-emerald-500 mb-2">&lt;100ms</div>
          <div class="text-sm text-gray-600 dark:text-gray-300">Global Response Time</div>
          <div class="text-xs text-emerald-500 mt-1">Cloudflare Edge Network</div>
        </div>

        <div class="text-center p-6 bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700">
          <div class="text-3xl font-bold text-blue-500 mb-2">99.9%</div>
          <div class="text-sm text-gray-600 dark:text-gray-300">Uptime SLA</div>
          <div class="text-xs text-blue-500 mt-1">Enterprise Grade</div>
        </div>

        <div class="text-center p-6 bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700">
          <div class="text-3xl font-bold text-purple-500 mb-2">&lt;3s</div>
          <div class="text-sm text-gray-600 dark:text-gray-300">Page Load Time</div>
          <div class="text-xs text-purple-500 mt-1">Optimized Delivery</div>
        </div>

        <div class="text-center p-6 bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700">
          <div class="text-3xl font-bold text-orange-500 mb-2">100K+</div>
          <div class="text-sm text-gray-600 dark:text-gray-300">Concurrent Users</div>
          <div class="text-xs text-orange-500 mt-1">Scalable Architecture</div>
        </div>
      </div>

      <!-- Architecture Diagram -->
      <div class="bg-white dark:bg-gray-800 p-8 rounded-2xl border border-gray-200 dark:border-gray-700">
        <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-6 text-center">
          Cloud-Native Architecture Flow
        </h3>

        <div class="flex flex-col lg:flex-row items-center justify-center gap-4 lg:gap-8">
          <!-- Client Layer -->
          <div class="flex flex-col items-center">
            <div class="w-16 h-16 bg-blue-500/10 rounded-xl flex items-center justify-center mb-3">
              <svg class="w-8 h-8 text-blue-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M3 4a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1V4zM3 10a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H4a1 1 0 01-1-1v-6zM14 9a1 1 0 00-1 1v5a1 1 0 001 1h2a1 1 0 001-1v-5a1 1 0 00-1-1h-2z" clip-rule="evenodd" />
              </svg>
            </div>
            <div class="text-center">
              <div class="font-semibold text-gray-900 dark:text-white">Client Layer</div>
              <div class="text-sm text-gray-600 dark:text-gray-300">Astro + React</div>
            </div>
          </div>

          <!-- Arrow -->
          <div class="hidden lg:block">
            <svg class="w-8 h-8 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </div>

          <!-- Edge Layer -->
          <div class="flex flex-col items-center">
            <div class="w-16 h-16 bg-purple-500/10 rounded-xl flex items-center justify-center mb-3">
              <svg class="w-8 h-8 text-purple-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M11.49 3.17c-.38-1.56-2.6-1.56-2.98 0a1.532 1.532 0 01-2.286.948c-1.372-.836-2.942.734-2.106 2.106.54.886.061 2.042-.947 2.287-1.561.379-1.561 2.6 0 2.978a1.532 1.532 0 01.947 2.287c-.836 1.372.734 2.942 2.106 2.106a1.532 1.532 0 012.287.947c.379 1.561 2.6 1.561 2.978 0a1.532 1.532 0 012.287-.947c1.372.836 2.942-.734 2.106-2.106a1.532 1.532 0 01.947-2.287c1.561-.379 1.561-2.6 0-2.978a1.532 1.532 0 01-.947-2.287c.836-1.372-.734-2.942-2.106-2.106a1.532 1.532 0 01-2.287-.947zM10 13a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd" />
              </svg>
            </div>
            <div class="text-center">
              <div class="font-semibold text-gray-900 dark:text-white">Edge Layer</div>
              <div class="text-sm text-gray-600 dark:text-gray-300">Cloudflare Workers</div>
            </div>
          </div>

          <!-- Arrow -->
          <div class="hidden lg:block">
            <svg class="w-8 h-8 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </div>

          <!-- Data Layer -->
          <div class="flex flex-col items-center">
            <div class="w-16 h-16 bg-emerald-500/10 rounded-xl flex items-center justify-center mb-3">
              <svg class="w-8 h-8 text-emerald-500" fill="currentColor" viewBox="0 0 20 20">
                <path d="M3 12v3c0 1.657 3.134 3 7 3s7-1.343 7-3v-3c0 1.657-3.134 3-7 3s-7-1.343-7-3z" />
                <path d="M3 7v3c0 1.657 3.134 3 7 3s7-1.343 7-3V7c0 1.657-3.134 3-7 3S3 8.657 3 7z" />
                <path d="M17 5c0 1.657-3.134 3-7 3S3 6.657 3 5s3.134-3 7-3 7 1.343 7 3z" />
              </svg>
            </div>
            <div class="text-center">
              <div class="font-semibold text-gray-900 dark:text-white">Data Layer</div>
              <div class="text-sm text-gray-600 dark:text-gray-300">Multi-Database</div>
            </div>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- Security & Compliance -->
  <section id="security" class="py-20 bg-gray-50 dark:bg-gray-900">
    <Container>
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">
          Enterprise Security & Compliance
        </h2>
        <p class="text-lg text-gray-600 dark:text-gray-300 max-w-2xl mx-auto">
          HIPAA-compliant architecture with advanced encryption, audit logging, and enterprise-grade security protocols.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-white dark:bg-gray-800 p-6 rounded-2xl border border-gray-200 dark:border-gray-700">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-green-500/10 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">HIPAA Compliant</h3>
          </div>
          <p class="text-gray-600 dark:text-gray-300 text-sm">
            Full HIPAA compliance with encrypted data storage, audit logging, and access controls for healthcare data protection.
          </p>
        </div>

        <div class="bg-white dark:bg-gray-800 p-6 rounded-2xl border border-gray-200 dark:border-gray-700">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-blue-500/10 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-blue-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">FHE Encryption</h3>
          </div>
          <p class="text-gray-600 dark:text-gray-300 text-sm">
            Fully Homomorphic Encryption for secure computation on encrypted data without decryption requirements.
          </p>
        </div>

        <div class="bg-white dark:bg-gray-800 p-6 rounded-2xl border border-gray-200 dark:border-gray-700">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-purple-500/10 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-purple-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M3 3a1 1 0 000-1h1v1H3zM4 4H3v1h1V4zM3 6a1 1 0 000-1h1v1H3zM4 7H3v1h1V7zM3 9a1 1 0 000-1h1v1H3zm4 0a1 1 0 000-1h1v1H7zm2 0a1 1 0 100-1h1v1H9zM4 10H3v1h1v-1zm6-3a1 1 0 011-1h1v1h-1a1 1 0 01-1-1zM6 8a1 1 0 100-1H4a1 1 0 100 1h2zM3 13a1 1 0 011-1h1v1H4a1 1 0 01-1-1zm7-1a1 1 0 100-1h1v1h-1zM9 13a1 1 0 011-1h1v1H9a1 1 0 01-1-1zm-3-1a1 1 0 100-1H5a1 1 0 100 1h1zm8 1a1 1 0 011-1h1v1h-1a1 1 0 01-1-1z" clip-rule="evenodd" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Audit Logging</h3>
          </div>
          <p class="text-gray-600 dark:text-gray-300 text-sm">
            Comprehensive audit trails for all data access, modifications, and system events with immutable logging.
          </p>
        </div>

        <div class="bg-white dark:bg-gray-800 p-6 rounded-2xl border border-gray-200 dark:border-gray-700">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-red-500/10 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-red-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M2.458 10C1.226 10 0 9.01 0 7.76c0-1.249 1.226-2.26 2.458-2.26s2.458 1.011 2.458 2.26c0 1.25-1.226 2.26-2.458 2.26zm11.542 0c-1.232 0-2.458-1.01-2.458-2.26 0-1.249 1.226-2.26 2.458-2.26s2.458 1.011 2.458 2.26c0 1.25-1.226 2.26-2.458 2.26zM2.458 16.76c-1.232 0-2.458-1.011-2.458-2.26s1.226-2.26 2.458-2.26 2.458 1.011 2.458 2.26-1.226 2.26-2.458 2.26zm11.542 0c-1.232 0-2.458-1.011-2.458-2.26s1.226-2.26 2.458-2.26 2.458 1.011 2.458 2.26-1.226 2.26-2.458 2.26z" clip-rule="evenodd" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Rate Limiting</h3>
          </div>
          <p class="text-gray-600 dark:text-gray-300 text-sm">
            Advanced rate limiting and DDoS protection with intelligent traffic analysis and automatic scaling.
          </p>
        </div>

        <div class="bg-white dark:bg-gray-800 p-6 rounded-2xl border border-gray-200 dark:border-gray-700">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-orange-500/10 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-orange-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M6.672 1.911a1 1 0 10-1.932.518l-.259.966a1 1 0 001.932.518l.26-.966zM8.66 5.782a1 1 0 10-1.932.517l-.259.966a1 1 0 001.932.518l.26-.966zM11.32 5.782a1 1 0 10-1.932.517l-.259.966a1 1 0 001.932.518l.26-.966zM13.98 1.911a1 1 0 10-1.932.518l-.259.966a1 1 0 001.932.518l.26-.966z" clip-rule="evenodd" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Data Encryption</h3>
          </div>
          <p class="text-gray-600 dark:text-gray-300 text-sm">
            End-to-end encryption with AES-256 for data at rest and TLS 1.3 for data in transit with perfect forward secrecy.
          </p>
        </div>

        <div class="bg-white dark:bg-gray-800 p-6 rounded-2xl border border-gray-200 dark:border-gray-700">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-teal-500/10 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-teal-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Compliance Ready</h3>
          </div>
          <p class="text-gray-600 dark:text-gray-300 text-sm">
            SOC 2 Type II, GDPR, and healthcare industry compliance with automated compliance monitoring and reporting.
          </p>
        </div>
      </div>
    </Container>
  </section>

  <!-- Scalability Features -->
  <section class="py-20">
    <Container>
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">
          Enterprise Scalability Features
        </h2>
        <p class="text-lg text-gray-600 dark:text-gray-300 max-w-2xl mx-auto">
          Built to scale from startup to enterprise with global deployment, multi-tenancy, and advanced monitoring.
        </p>
      </div>

      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h3 class="text-2xl font-semibold text-gray-900 dark:text-white mb-6">
            Global Edge Network Deployment
          </h3>
