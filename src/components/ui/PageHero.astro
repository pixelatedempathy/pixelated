---
/**
 * Reusable Page Hero Component
 * Applies unified design system to all pages
 */
interface Props {
  title: string
  subtitle?: string
  badge?: string
  gradient?: boolean
}

const { title, subtitle, badge, gradient = true } = Astro.props
---

<section class="relative py-24 lg:py-32 overflow-hidden">
  <!-- Antfu: Dot Grid Background -->
  <div class="absolute inset-0" style="background-image: radial-gradient(circle, rgba(255,255,255,0.1) 1px, transparent 1px); background-size: 32px 32px;"></div>
  
  <!-- Flabbergasted: Gradient Blobs -->
  <div class="absolute top-10 right-10 w-64 h-64 bg-gradient-to-br from-purple-500/10 to-pink-500/10 rounded-full blur-3xl"></div>
  <div class="absolute bottom-10 left-10 w-96 h-96 bg-gradient-to-tr from-emerald-500/10 to-cyan-500/10 rounded-full blur-3xl"></div>
  
  <div class="container mx-auto px-6 relative z-10">
    <div class="max-w-4xl mx-auto text-center">
      
      {badge && (
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-emerald-500/10 border border-emerald-500/20 rounded-full mb-6 fade-in-up">
          <span class="text-sm font-medium text-emerald-400">{badge}</span>
        </div>
      )}
      
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight fade-in-up" style="animation-delay: 100ms;">
        {gradient ? (
          <span class="bg-gradient-to-r from-emerald-400 via-cyan-400 to-purple-400 bg-clip-text text-transparent">
            {title}
          </span>
        ) : (
          title
        )}
      </h1>
      
      {subtitle && (
        <p class="text-lg md:text-xl text-gray-300 max-w-2xl mx-auto leading-relaxed fade-in-up" style="animation-delay: 200ms;">
          {subtitle}
        </p>
      )}
      
      <slot />
    </div>
  </div>
</section>
