---
export const prerender = false
import DashboardLayout from '../../layouts/DashboardLayout.astro'
import DashboardCard from '@/components/ui/DashboardCard.astro'
import StatsGrid from '@/components/ui/StatsGrid.astro'

const stats = [
  { label: 'Total Users', value: '--', color: 'emerald' },
  { label: 'Active Sessions', value: '--', color: 'cyan' },
  { label: 'System Health', value: '--', color: 'purple' },
  { label: 'Alerts', value: '0', color: 'pink' }
]
---
<DashboardLayout title="Admin Dashboard - Pixelated Empathy">
  <div class="space-y-8">
    <h1 class="text-3xl font-bold text-white">Admin Dashboard</h1>
    <StatsGrid stats={stats} columns={4} />
    <div class="grid md:grid-cols-2 gap-6">
      <DashboardCard title="System Status"><p class="text-gray-300">All systems operational</p></DashboardCard>
      <DashboardCard title="Recent Activity"><p class="text-gray-300">Activity log</p></DashboardCard>
    </div>
  </div>
</DashboardLayout>
