export const prerender = true

---
import HybridLayout from '@/layouts/HybridLayout.astro'
import HybridHero from '@/components/ui/HybridHero.astro'
import HybridFeatures from '@/components/ui/HybridFeatures.astro'
---

<HybridLayout 
  title="Enterprise Mental Health AI Platform | Pixelated Empathy"
  description="Clinical-grade AI platform combining enterprise security with elegant user experience. Deploy evidence-based mental health solutions with seamless EHR integration."
>
  <HybridHero 
    title="Enterprise Mental Health AI"
    subtitle="Clinical-grade platform designed for healthcare organizations"
    description="Deploy evidence-based AI-powered mental health solutions with enterprise security, seamless EHR integration, and comprehensive compliance frameworks."
    primaryCTA={{ text: "Request Demo", href: "/demo" }}
    secondaryCTA={{ text: "View Documentation", href: "/docs" }}
  />
  
  <HybridFeatures />
</HybridLayout>