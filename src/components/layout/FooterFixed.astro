---
// Simplified Footer - Clean and Professional
const currentYear = new Date().getFullYear()

const footerSections = [
  {
    title: 'Product',
    links: [
      { name: 'Features', href: '/features' },
      { name: 'Demos', href: '/demo-hub' },
      { name: 'Pricing', href: '/pricing' },
    ],
  },
  {
    title: 'Resources',
    links: [
      { name: 'Documentation', href: '/docs' },
      { name: 'Blog', href: '/blog' },
      { name: 'Support', href: '/support' },
    ],
  },
  {
    title: 'Company',
    links: [
      { name: 'About', href: '/about' },
      { name: 'Contact', href: '/contact' },
      { name: 'Privacy', href: '/privacy' },
    ],
  },
]

const socialLinks = [
  {
    name: 'GitHub',
    href: 'https://github.com/pixelated-empathy',
    icon: 'M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z',
  },
  {
    name: 'Twitter',
    href: 'https://twitter.com/pixelatedempathy',
    icon: 'M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z',
  },
]
---

<footer
  class="footer-container"
  role="contentinfo"
  aria-label="Site footer"
>
  <div class="footer-content">
    <!-- Main Footer Content -->
    <div style="display: grid; grid-template-columns: 1fr; gap: var(--space-12); margin-bottom: var(--space-12);">
      <!-- Brand Section -->
      <div style="display: flex; flex-direction: column; gap: var(--space-6);">
        <div style="display: flex; align-items: center; gap: var(--space-4);">
          <div style="width: 2.5rem; height: 2.5rem; background: var(--accent-primary); border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center;">
            <img
              src="/apple-touch-icon.png"
              alt="Pixelated Empathy Logo"
              style="width: 1.5rem; height: 1.5rem; border-radius: var(--radius-sm); filter: brightness(0) invert(1);"
              width="32"
              height="32"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div>
            <h2 style="font-size: var(--text-lg); font-weight: var(--weight-black); line-height: 1.1; letter-spacing: -0.02em; color: var(--text-primary); margin: 0;">
              PIXELATED EMPATHY
            </h2>
            <p style="color: var(--text-muted); font-size: var(--text-sm); margin: var(--space-1) 0 0 0;">
              AI-Powered Mental Health Training
            </p>
          </div>
        </div>

        <p style="color: var(--text-secondary); line-height: 1.6; max-width: 320px; margin: 0;">
          Revolutionizing mental health education through advanced AI simulation and immersive training experiences.
        </p>

        <!-- Social Links -->
        <nav aria-label="Social media links">
          <ul style="display: flex; align-items: center; gap: var(--space-2); list-style: none; margin: 0; padding: 0;">
            {
              socialLinks.map((social) => (
                <li>
                  <a
                    href={social.href}
                    style="display: flex; align-items: center; justify-content: center; width: 2.5rem; height: 2.5rem; color: var(--text-secondary); background: var(--bg-secondary); border: 1px solid var(--border-primary); border-radius: var(--radius-md); transition: all var(--transition-fast); text-decoration: none;"
                    aria-label={`Follow us on ${social.name}`}
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    <svg
                      width="20"
                      height="20"
                      fill="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path d={social.icon} />
                    </svg>
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
      </div>

      <!-- Navigation Sections -->
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: var(--space-8);">
        {
          footerSections.map((section) => (
            <nav
              aria-labelledby={`footer-${section.title.toLowerCase()}`}
            >
              <h3
                id={`footer-${section.title.toLowerCase()}`}
                style="font-size: var(--text-sm); font-weight: var(--weight-bold); color: var(--text-primary); text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 var(--space-4) 0;"
              >
                {section.title}
              </h3>
              <ul style="list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: var(--space-2);">
                {section.links.map((link) => (
                  <li style="margin: 0;">
                    <a href={link.href} style="color: var(--text-tertiary); text-decoration: none; transition: color var(--transition-fast); display: block; padding: var(--space-1) 0; font-size: var(--text-sm);">
                      {link.name}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          ))
        }
      </div>
    </div>

    <!-- Bottom Bar -->
    <div style="padding-top: var(--space-6); border-top: 1px solid var(--border-subtle);">
      <div style="display: flex; flex-direction: column; gap: var(--space-4); align-items: flex-start;">
        <div style="display: flex; flex-direction: column; gap: var(--space-3); align-items: flex-start;">
          <p style="color: var(--text-muted); font-size: var(--text-sm); margin: 0;">
            &copy; {currentYear} Pixelated Empathy. All rights reserved.
          </p>
          <nav aria-label="Legal links" style="display: flex; align-items: center; gap: var(--space-4);">
            <a href="/terms" style="color: var(--text-muted); text-decoration: none; font-size: var(--text-sm); transition: color var(--transition-fast);">Terms</a>
            <a href="/privacy" style="color: var(--text-muted); text-decoration: none; font-size: var(--text-sm); transition: color var(--transition-fast);">Privacy</a>
            <a href="/cookies" style="color: var(--text-muted); text-decoration: none; font-size: var(--text-sm); transition: color var(--transition-fast);">Cookies</a>
          </nav>
        </div>

        <!-- Status Indicator -->
        <div style="display: flex; align-items: center;">
          <div style="display: flex; align-items: center; gap: var(--space-2); padding: var(--space-1) var(--space-3); background: var(--accent-primary-subtle); color: var(--accent-primary); border-radius: var(--radius-full); font-size: var(--text-xs); font-weight: var(--weight-semibold); text-transform: uppercase; letter-spacing: 0.05em;">
            <div style="width: 6px; height: 6px; background: var(--accent-primary); border-radius: 50%; animation: pulse 2s ease-in-out infinite;"></div>
            <span style="margin: 0;">ALL SYSTEMS OPERATIONAL</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  @keyframes pulse {
    0%, 100% {
      opacity: 1;
      transform: scale(1);
      box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4);
    }
    50% {
      opacity: 0.8;
      transform: scale(1.1);
      box-shadow: 0 0 0 8px rgba(16, 185, 129, 0);
    }
  }

  @media (min-width: 768px) {
    .footer-content > div:first-child {
      grid-template-columns: 1fr 2fr;
    }

    .footer-content > div:last-child > div:first-child {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }

    .footer-content > div:last-child > div:first-child > div:first-child {
      align-items: center;
      flex-direction: row;
      gap: var(--space-6);
    }
  }

  @media (max-width: 768px) {
    .footer-content {
      padding: var(--space-8) var(--space-4);
    }

    .footer-content > div:first-child > div:first-child > div:first-child {
      flex-direction: column;
      text-align: center;
    }

    .footer-content > div:first-child > div:first-child > nav > ul {
      justify-content: center;
    }

    .footer-content > div:last-child > div:first-child {
      text-align: center;
      align-items: center;
    }

    .footer-content > div:last-child > div:first-child > div:first-child {
      align-items: center;
      text-align: center;
    }

    .footer-content > div:last-child > div:last-child {
      justify-content: center;
    }
  }
</style>