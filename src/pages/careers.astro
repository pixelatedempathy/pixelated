---
export const prerender = true

import Layout from '@/layouts/Layout.astro'
import PageHero from '@/components/ui/PageHero.astro'
import ContentSection from '@/components/ui/ContentSection.astro'

const jobListings = [
  {
    title: "AI Engineer",
    department: "Engineering",
    location: "Remote",
    type: "Full-time",
    description: "Work on AI models and training simulation systems.",
    requirements: ["Machine learning experience", "Programming skills", "Healthcare interest preferred"]
  },
  {
    title: "Clinical Consultant",
    department: "Clinical",
    location: "Remote",
    type: "Full-time", 
    description: "Design and validate therapeutic training scenarios and frameworks.",
    requirements: ["Clinical psychology background", "Licensed practitioner", "Training experience"]
  },
  {
    title: "Product Designer",
    department: "Design",
    location: "Remote",
    type: "Full-time",
    description: "Create user interfaces for training and assessment tools.",
    requirements: ["UX/UI design experience", "Healthcare/EdTech background helpful", "Design tool proficiency"]
  },
  {
    title: "Platform Engineer",
    department: "Engineering",
    location: "Remote",
    type: "Full-time",
    description: "Build and maintain secure, scalable infrastructure for healthcare applications.",
    requirements: ["Cloud platform experience", "Container technologies", "Security compliance knowledge"]
  },
  {
    title: "Customer Success Specialist",
    department: "Customer Success",
    location: "Remote",
    type: "Full-time",
    description: "Help healthcare institutions implement and adopt training platforms.",
    requirements: ["Customer success experience", "Healthcare industry knowledge", "Communication skills"]
  }
]

const benefits = [
  {
    icon: "🏥",
    title: "Healthcare Impact",
    description: "Work on technology that directly improves mental healthcare outcomes"
  },
  {
    icon: "🌍",
    title: "Remote-First",
    description: "Work from anywhere with flexible hours and quarterly team retreats"
  },
  {
    icon: "💰",
    title: "Competitive Package",
    description: "Top-tier salary, equity, and comprehensive health benefits"
  },
  {
    icon: "📚",
    title: "Learning Budget",
    description: "Annual budget for conferences, courses, and professional development"
  },
  {
    icon: "🎯",
    title: "Mission-Driven",
    description: "Join a team passionate about transforming mental health training"
  },
  {
    icon: "⚖️",
    title: "Work-Life Balance",
    description: "Unlimited PTO, mental health days, and sabbatical opportunities"
  }
]
---

<Layout title="Careers - Pixelated Empathy">
  <PageHero
    badge="Join Our Mission"
    title="Build the Future of Mental Health Training"
    subtitle="Join a passionate team using AI to transform how mental health professionals learn and grow."
    gradient={true}
  />

  <!-- Company Culture -->
  <ContentSection>
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold mb-4">
        <span class="bg-gradient-to-r from-emerald-400 to-cyan-400 bg-clip-text text-transparent">
          Why Join Us
        </span>
      </h2>
      <p class="text-xl text-gray-300 max-w-3xl mx-auto">
        We're building technology that makes a real difference in mental healthcare
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {benefits.map((benefit) => (
        <div class="bg-black/40 backdrop-blur-xl border border-white/10 rounded-xl p-6 hover:border-emerald-500/30 transition-all duration-300">
          <div class="text-4xl mb-4">{benefit.icon}</div>
          <h3 class="text-xl font-bold text-white mb-2">{benefit.title}</h3>
          <p class="text-gray-300">{benefit.description}</p>
        </div>
      ))}
    </div>
  </ContentSection>

  <!-- Job Listings -->
  <ContentSection diagonal={true}>
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold mb-4">
        <span class="bg-gradient-to-r from-purple-400 to-pink-400 bg-clip-text text-transparent">
          Open Positions
        </span>
      </h2>
      <p class="text-xl text-gray-300">
        Find your next role on our growing team
      </p>
    </div>

    <div class="space-y-6 max-w-4xl mx-auto">
      {jobListings.map((job) => (
        <div class="bg-black/40 backdrop-blur-xl border border-white/10 rounded-xl p-8 hover:border-purple-500/30 transition-all duration-300">
          <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 mb-4">
            <div>
              <h3 class="text-2xl font-bold text-white mb-2">{job.title}</h3>
              <div class="flex flex-wrap gap-3 text-sm">
                <span class="px-3 py-1 bg-purple-500/20 border border-purple-500/30 rounded-full text-purple-400">
                  {job.department}
                </span>
                <span class="px-3 py-1 bg-cyan-500/20 border border-cyan-500/30 rounded-full text-cyan-400">
                  {job.location}
                </span>
                <span class="px-3 py-1 bg-emerald-500/20 border border-emerald-500/30 rounded-full text-emerald-400">
                  {job.type}
                </span>
              </div>
            </div>
            <a 
              href={`mailto:careers@pixelatedempathy.com?subject=Application: ${job.title}`}
              class="inline-flex items-center justify-center px-6 py-3 bg-gradient-to-r from-emerald-500 to-cyan-500 hover:from-emerald-600 hover:to-cyan-600 text-black font-bold rounded-lg transition-all duration-200 transform hover:scale-105 whitespace-nowrap"
            >
              Apply Now
            </a>
          </div>
          
          <p class="text-gray-300 mb-4">{job.description}</p>
          
          <div>
            <h4 class="text-white font-semibold mb-2">Requirements:</h4>
            <ul class="space-y-2">
              {job.requirements.map((req) => (
                <li class="flex items-start gap-2 text-gray-300">
                  <svg class="w-5 h-5 text-emerald-400 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                  </svg>
                  {req}
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </ContentSection>

  <!-- Application CTA -->
  <ContentSection>
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-4xl font-bold mb-6">
        <span class="bg-gradient-to-r from-emerald-400 to-cyan-400 bg-clip-text text-transparent">
          Don't See a Perfect Fit?
        </span>
      </h2>
      <p class="text-xl text-gray-300 mb-8">
        We're always interested in hearing from talented people. Send us your resume and let's talk.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a 
          href="mailto:careers@pixelatedempathy.com"
          class="inline-flex items-center justify-center px-8 py-4 bg-gradient-to-r from-emerald-500 to-cyan-500 hover:from-emerald-600 hover:to-cyan-600 text-black font-bold rounded-lg transition-all duration-200 transform hover:scale-105"
        >
          Send Your Resume
        </a>
        <a 
          href="/team"
          class="inline-flex items-center justify-center px-8 py-4 bg-white/10 hover:bg-white/20 border border-white/20 rounded-lg text-white font-medium transition-all duration-200"
        >
          Meet the Team
        </a>
      </div>
    </div>
  </ContentSection>
</Layout>
