---
// Modern Footer with Gemini Theme
---

<footer class="site-footer">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Brand Section -->
      <div class="space-y-4">
        <a href="/" class="flex items-center space-x-2">
          <div class="logo-icon w-8 h-8 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <span class="text-xl font-bold">
            Pixelated Empathy
          </span>
        </a>
        <p>
          Revolutionizing mental health support through AI-powered empathy.
        </p>
      </div>

      <!-- Company Links -->
      <div>
        <h3 class="font-semibold">Company</h3>
        <ul class="mt-4 space-y-2">
          <li><a href="/about" class="transition-colors">About Us</a></li>
          <li><a href="/careers" class="transition-colors">Careers</a></li>
          <li><a href="/contact" class="transition-colors">Contact</a></li>
        </ul>
      </div>

      <!-- Legal Links -->
      <div>
        <h3 class="font-semibold">Legal</h3>
        <ul class="mt-4 space-y-2">
          <li><a href="/privacy" class="transition-colors">Privacy Policy</a></li>
          <li><a href="/terms" class="transition-colors">Terms of Service</a></li>
        </ul>
      </div>

      <!-- Social Links -->
      <div>
        <h3 class="font-semibold">Connect</h3>
        <div class="flex mt-4 space-x-4">
          <a href="#" class="transition-colors">Twitter</a>
          <a href="#" class="transition-colors">LinkedIn</a>
          <a href="#" class="transition-colors">GitHub</a>
        </div>
      </div>
    </div>

    <!-- Footer Bottom -->
    <div class="footer-bottom mt-12 border-t pt-8 flex flex-col md:flex-row justify-between items-center">
      <p>&copy; 2024 Pixelated Empathy. All rights reserved.</p>
      <div class="flex space-x-4 mt-4 md:mt-0">
        <a href="/privacy" class="transition-colors">Privacy</a>
        <a href="/terms" class="transition-colors">Terms</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-surface);
    border-top: 1px solid var(--color-border);
  }
  .logo-icon {
    background-color: var(--color-primary);
  }
  .logo-icon svg, .site-footer span {
    color: var(--color-text-primary);
  }
  .site-footer p, .site-footer a {
    color: var(--color-text-secondary);
  }
  .site-footer h3 {
    color: var(--color-text-primary);
  }
  .site-footer a:hover {
    color: var(--color-text-primary);
  }
  .footer-bottom {
    border-color: var(--color-border);
  }
</style>