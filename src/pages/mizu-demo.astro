---
import Layout from '../layouts/Layout.astro';
import Container from '../components/Container.astro';
---

<Layout title="Mizu Theme Demo - Pixelated Empathy">
  <main>
    <!-- Mizu Hero Section -->
    <section class="mizu-hero">
      <div class="mizu-hero-bg-pattern"></div>
      <div class="mizu-section-spacer">
        <div class="mizu-section-spacer-inner"></div>
      </div>

      <div class="mizu-hero-container">
        <div class="mizu-hero-left">
          <div class="mizu-hero-content">
            <div class="mizu-hero-badge">
              <span>🎭</span>
              EMPATHY ENGINEERED
            </div>
            <h1 class="mizu-hero-title">
              <span class="mizu-hero-title-text">Beyond the screen</span>
              <span class="mizu-hero-title-gradient">lies a deeper connection</span>
            </h1>
            <p class="mizu-hero-subtitle">AI-POWERED CONVERSATIONAL INTELLIGENCE</p>
            <p class="mizu-hero-description">
              We don't just process conversations. We understand them. Most platforms see *what* you say.
              We see *why* you said it, *how* you felt when you said it, and *what* you really needed when you said it.
            </p>
            <div class="mizu-hero-cta">
              <a href="#" class="mizu-btn mizu-btn-primary">
                Request Demo
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 12h14m-7-7l7 7-7 7"/>
                </svg>
              </a>
              <a href="#" class="mizu-btn mizu-btn-secondary">
                View Case Studies
              </a>
            </div>
          </div>
        </div>

        <div class="mizu-hero-right">
          <div class="mizu-hero-visual">
            <div class="mizu-hero-dot-pattern"></div>
            <div class="mizu-hero-visual-content">
              <!-- Visual content placeholder -->
              <div class="mizu-center" style="height: 100%;">
                <div style="width: 200px; height: 200px; background: var(--mizu-accent); opacity: 0.1; border: 1px solid var(--mizu-border);"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Mizu Features Section -->
    <section class="mizu-features">
      <div class="mizu-features-container">
        <div class="mizu-features-header">
          <div class="mizu-features-badge">
            <span>🧠</span>
            THE TECHNOLOGY
          </div>
          <h2 class="mizu-features-title">Built for Those Who Build Communities</h2>
          <p class="mizu-features-description">
            This technology is exclusively designed for organizations that understand:
            your community isn't your product—it's your purpose.
          </p>
        </div>

        <div class="mizu-features-grid">
          <div class="mizu-feature-card">
            <div class="mizu-feature-icon">🎭</div>
            <h3 class="mizu-feature-title">Emotional Cartography</h3>
            <p class="mizu-feature-description">
              We don't just analyze sentiment. We map the emotional journey of every conversation,
              identifying moments that matter.
            </p>
          </div>

          <div class="mizu-feature-card">
            <div class="mizu-feature-icon">🌊</div>
            <h3 class="mizu-feature-title">Conversational Dynamics</h3>
            <p class="mizu-feature-description">
              Understanding that communication is more than words, our system analyzes the flow of dialogue—
              tone patterns, response timing, emotional reciprocity.
            </p>
          </div>

          <div class="mizu-feature-card">
            <div class="mizu-feature-icon">🧩</div>
            <h3 class="mizu-feature-title">Persona Intelligence</h3>
            <p class="mizu-feature-description">
              People aren't static, and neither are our insights. Our Dual-Persona framework recognizes
              when someone is shifting roles and adapts accordingly.
            </p>
          </div>

          <div class="mizu-feature-card">
            <div class="mizu-feature-icon">🎯</div>
            <h3 class="mizu-feature-title">Enterprise-Grade</h3>
            <p class="mizu-feature-description">
              Built with the same technologies that power the world's most demanding applications—
              secure, scalable, and reliable.
            </p>
          </div>

          <div class="mizu-feature-card">
            <div class="mizu-feature-icon">🔒</div>
            <h3 class="mizu-feature-title">HIPAA Compliant</h3>
            <p class="mizu-feature-description">
              Enterprise-ready with full HIPAA compliance, end-to-end encryption,
              and comprehensive security protocols.
            </p>
          </div>

          <div class="mizu-feature-card">
            <div class="mizu-feature-icon">⚡</div>
            <h3 class="mizu-feature-title">Real-time Analytics</h3>
            <p class="mizu-feature-description">
              Get instant insights into conversation dynamics, emotional patterns,
              and therapeutic effectiveness with our advanced analytics engine.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Mizu Stats Section -->
    <section class="mizu-stats">
      <div class="mizu-stats-container">
        <div class="mizu-stats-header">
          <div class="mizu-stats-badge">
            <span>📊</span>
            PERFORMANCE METRICS
          </div>
          <h2 class="mizu-stats-title">Proven Results</h2>
          <p class="mizu-stats-description">
            Our platform delivers measurable improvements in therapeutic outcomes
            and professional development.
          </p>
        </div>

        <div class="mizu-stats-grid">
          <div class="mizu-stat-card">
            <div class="mizu-stat-number">84.8%</div>
            <div class="mizu-stat-label">SWE-Bench Solve Rate</div>
          </div>

          <div class="mizu-stat-card">
            <div class="mizu-stat-number">32.3%</div>
            <div class="mizu-stat-label">Token Reduction</div>
          </div>

          <div class="mizu-stat-card">
            <div class="mizu-stat-number">4.4x</div>
            <div class="mizu-stat-label">Speed Improvement</div>
          </div>

          <div class="mizu-stat-card">
            <div class="mizu-stat-number">27+</div>
            <div class="mizu-stat-label">Neural Models</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Mizu Testimonial Section -->
    <section class="mizu-testimonial">
      <div class="mizu-testimonial-container">
        <div class="mizu-testimonial-content">
          <div class="mizu-testimonial-badge">
            <span>💬</span>
            CLIENT TESTIMONIAL
          </div>
          <p class="mizu-testimonial-quote">
            "The hardest conversations are the ones you can't practice with real people.
            Pixelated Empathy gives our therapists a safe space to master crisis intervention
            and trauma response without any risk to actual clients."
          </p>
          <div class="mizu-testimonial-author">
            <div class="mizu-testimonial-avatar">DR</div>
            <div class="mizu-testimonial-author-info">
              <div class="mizu-testimonial-author-name">Dr. Sarah Chen</div>
              <div class="mizu-testimonial-author-title">Clinical Director, Mental Health Partners</div>
            </div>
          </div>
        </div>

        <div class="mizu-testimonial-metrics">
          <div class="mizu-metric">
            <div class="mizu-metric-value">500+</div>
            <div class="mizu-metric-label">Therapists Trained</div>
          </div>
          <div class="mizu-metric">
            <div class="mizu-metric-value">10,000+</div>
            <div class="mizu-metric-label">Practice Sessions</div>
          </div>
          <div class="mizu-metric">
            <div class="mizu-metric-value">95%</div>
            <div class="mizu-metric-label">Confidence Increase</div>
          </div>
          <div class="mizu-metric">
            <div class="mizu-metric-value">24/7</div>
            <div class="mizu-metric-label">Available Training</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Mizu CTA Section -->
    <section class="mizu-cta">
      <div class="mizu-cta-container">
        <h2 class="mizu-cta-title">Ready to Transform Your Practice?</h2>
        <p class="mizu-cta-description">
          Join forward-thinking mental health professionals who refuse to accept
          "engagement" as a substitute for genuine connection.
        </p>
        <div class="mizu-cta-buttons">
          <a href="#" class="mizu-btn mizu-btn-primary">
            Request Enterprise Access
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14m-7-7l7 7-7 7"/>
            </svg>
          </a>
          <a href="#" class="mizu-btn mizu-btn-secondary">
            Schedule Demo
          </a>
        </div>
        <p class="mizu-cta-note">
          Because while others are building better algorithms, we're building better humans.
        </p>
      </div>
    </section>
  </main>

  <style>
    /* Additional custom styles for this demo */
    .mizu-center {
      display: flex;
      align-items: center;
      justify-content: center;
    }
  </style>
</Layout>