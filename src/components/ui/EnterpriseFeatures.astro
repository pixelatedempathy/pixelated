---
// Enterprise Features Section - Professional grid layout
interface Feature {
  icon: string;
  title: string;
  description: string;
  features: string[];
  href?: string;
}

const features: Feature[] = [
  {
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M12 2L2 7v10c0 5.55 3.84 10 10 12 6.16-2 10-6.45 10-12V7l-10-5z"/>
      <path d="M9 12l2 2 4-4"/>
    </svg>`,
    title: "AI-Powered Clinical Engine",
    description: "Advanced machine learning models trained on clinical data to provide evidence-based therapeutic recommendations.",
    features: [
      "Evidence-based treatment protocols",
      "Real-time risk assessment",
      "Personalized intervention strategies",
      "Clinical outcome prediction"
    ],
    href: "/platform/ai-engine"
  },
  {
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <rect x="3" y="3" width="18" height="18" rx="2"/>
      <path d="M9 9h6v6H9z"/>
      <path d="M16 1v6M8 1v6M1 8h6M1 16h6"/>
    </svg>`,
    title: "Enterprise Integration Suite",
    description: "Seamlessly integrate with existing healthcare systems, EMRs, and clinical workflows.",
    features: [
      "HL7 FHIR compliance",
      "Epic, Cerner integration",
      "Single sign-on (SSO)",
      "Custom API endpoints"
    ],
    href: "/platform/integrations"
  },
  {
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M3 13h18M3 17h18M3 9h18M21 3H3c-.6 0-1 .4-1 1v16c0 .6.4 1 1 1h18c.6 0 1-.4 1-1V4c0-.6-.4-1-1-1z"/>
      <circle cx="7" cy="7" r="1"/>
    </svg>`,
    title: "Advanced Analytics Dashboard",
    description: "Comprehensive insights and reporting for clinical teams, administrators, and compliance officers.",
    features: [
      "Population health metrics",
      "Treatment efficacy tracking",
      "Compliance reporting",
      "ROI analysis tools"
    ],
    href: "/platform/analytics"
  },
  {
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <rect x="3" y="11" width="18" height="10" rx="2"/>
      <circle cx="12" cy="16" r="1"/>
      <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
    </svg>`,
    title: "Enterprise Security & Compliance",
    description: "Bank-grade security with comprehensive compliance frameworks for healthcare organizations.",
    features: [
      "HIPAA compliant infrastructure",
      "SOC 2 Type II certified",
      "End-to-end encryption",
      "Audit logging & monitoring"
    ],
    href: "/platform/security"
  },
  {
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
      <circle cx="9" cy="7" r="4"/>
      <path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>
    </svg>`,
    title: "Multi-Tenant Architecture",
    description: "Scalable platform designed for healthcare systems serving multiple locations and departments.",
    features: [
      "Department-level isolation",
      "Custom branding options",
      "Flexible user permissions",
      "Centralized administration"
    ],
    href: "/platform/architecture"
  },
  {
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
      <path d="M8 12l2.5 2.5L16 9"/>
    </svg>`,
    title: "24/7 Support & Monitoring",
    description: "Enterprise-grade support with dedicated account management and proactive system monitoring.",
    features: [
      "Dedicated success manager",
      "24/7 technical support",
      "Proactive monitoring",
      "SLA guarantees"
    ],
    href: "/support/enterprise"
  }
];
---

<section class="enterprise-features">
  <div class="container">
    <!-- Section Header -->
    <div class="section-header">
      <div class="header-badge">
        <span>Enterprise Platform</span>
      </div>
      <h2 class="section-title">
        Built for <span class="text-gradient">Healthcare at Scale</span>
      </h2>
      <p class="section-description">
        Our enterprise platform delivers the advanced capabilities healthcare organizations need 
        to transform mental health care delivery while maintaining the highest standards of 
        security, compliance, and clinical excellence.
      </p>
    </div>

    <!-- Features Grid -->
    <div class="features-grid">
      {features.map((feature, index) => (
        <div class="feature-card" style={`animation-delay: ${index * 0.1}s`}>
          <div class="card-header">
            <div class="feature-icon">
              <Fragment set:html={feature.icon} />
            </div>
            <h3 class="feature-title">{feature.title}</h3>
            <p class="feature-description">{feature.description}</p>
          </div>

          <div class="feature-list">
            {feature.features.map((item) => (
              <div class="feature-item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="check-icon">
                  <path d="M20 6L9 17l-5-5"/>
                </svg>
                <span>{item}</span>
              </div>
            ))}
          </div>

          {feature.href && (
            <div class="card-footer">
              <a href={feature.href} class="feature-link">
                Learn more
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M7 17L17 7M17 7H7M17 7v10"/>
                </svg>
              </a>
            </div>
          )}
        </div>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="section-cta">
      <div class="cta-content">
        <h3 class="cta-title">Ready to transform your organization's mental health capabilities?</h3>
        <p class="cta-description">
          Join leading healthcare organizations already using Pixelated Empathy to improve patient outcomes.
        </p>
        <div class="cta-actions">
          <a href="/demo" class="btn btn-primary btn-lg">
            Schedule Enterprise Demo
          </a>
          <a href="/contact" class="btn btn-secondary btn-lg">
            Talk to Sales
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .enterprise-features {
    padding: var(--space-24) 0;
    background: var(--bg-primary);
    position: relative;
  }

  .enterprise-features::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border-primary), transparent);
  }

  /* Section Header */
  .section-header {
    text-align: center;
    max-width: 800px;
    margin: 0 auto var(--space-16);
  }

  .header-badge {
    display: inline-flex;
    align-items: center;
    padding: var(--space-2) var(--space-4);
    background: var(--surface-elevated);
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-secondary);
    margin-bottom: var(--space-6);
  }

  .section-title {
    font-size: var(--text-5xl);
    font-weight: 700;
    margin-bottom: var(--space-6);
    line-height: 1.1;
  }

  .section-description {
    font-size: var(--text-xl);
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* Features Grid */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
    gap: var(--space-8);
    margin-bottom: var(--space-20);
  }

  .feature-card {
    background: var(--surface-elevated);
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-2xl);
    padding: var(--space-8);
    transition: all var(--transition-normal);
    animation: slideUp 0.6s ease-out both;
    position: relative;
    overflow: hidden;
  }

  .feature-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--color-primary-500), var(--color-accent-emerald));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--transition-normal);
  }

  .feature-card:hover {
    border-color: var(--border-secondary);
    box-shadow: var(--shadow-xl);
    transform: translateY(-4px);
  }

  .feature-card:hover::before {
    transform: scaleX(1);
  }

  .card-header {
    margin-bottom: var(--space-6);
  }

  .feature-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    background: linear-gradient(135deg, var(--color-primary-500), var(--color-primary-400));
    border-radius: var(--radius-xl);
    margin-bottom: var(--space-6);
    color: white;
    transition: all var(--transition-normal);
  }

  .feature-card:hover .feature-icon {
    transform: scale(1.1);
    box-shadow: var(--shadow-lg);
  }

  .feature-title {
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--space-3);
    line-height: 1.3;
  }

  .feature-description {
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: var(--space-6);
  }

  .feature-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
  }

  .feature-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .check-icon {
    color: var(--color-accent-emerald);
    margin-top: 2px;
    flex-shrink: 0;
  }

  .card-footer {
    border-top: 1px solid var(--border-primary);
    padding-top: var(--space-6);
  }

  .feature-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-primary-500);
    text-decoration: none;
    font-size: var(--text-sm);
    font-weight: 500;
    transition: all var(--transition-fast);
  }

  .feature-link:hover {
    color: var(--color-primary-400);
    transform: translateX(4px);
  }

  /* Section CTA */
  .section-cta {
    background: linear-gradient(135deg, var(--bg-secondary), var(--bg-tertiary));
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-3xl);
    padding: var(--space-12);
    text-align: center;
  }

  .cta-content {
    max-width: 600px;
    margin: 0 auto;
  }

  .cta-title {
    font-size: var(--text-3xl);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--space-4);
    line-height: 1.3;
  }

  .cta-description {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    margin-bottom: var(--space-8);
    line-height: 1.6;
  }

  .cta-actions {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Responsive Design */
  @media (max-width: 1024px) {
    .features-grid {
      grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
      gap: var(--space-6);
    }
  }

  @media (max-width: 768px) {
    .enterprise-features {
      padding: var(--space-16) 0;
    }

    .section-header {
      margin-bottom: var(--space-12);
    }

    .section-title {
      font-size: var(--text-4xl);
    }

    .section-description {
      font-size: var(--text-lg);
    }

    .features-grid {
      grid-template-columns: 1fr;
      gap: var(--space-6);
      margin-bottom: var(--space-16);
    }

    .feature-card {
      padding: var(--space-6);
    }

    .cta-title {
      font-size: var(--text-2xl);
    }

    .cta-actions {
      flex-direction: column;
      align-items: center;
    }

    .cta-actions .btn {
      width: 100%;
      max-width: 280px;
    }
  }

  @media (max-width: 480px) {
    .features-grid {
      grid-template-columns: 1fr;
    }

    .section-cta {
      padding: var(--space-8);
    }

    .feature-icon {
      width: 56px;
      height: 56px;
    }
  }

  /* Animation */
  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(40px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>