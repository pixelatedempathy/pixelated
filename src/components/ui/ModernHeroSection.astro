---
// Modern Hero Section combining Mizu clean layout + Aspect typography + Antfu minimalism
interface Props {
  title?: string;
  subtitle?: string;
  primaryAction?: {
    text: string;
    href: string;
  };
  secondaryAction?: {
    text: string;
    href: string;
  };
  backgroundPattern?: boolean;
}

const {
  title = "Transform Mental Health with AI-Powered Empathy",
  subtitle = "Pixelated Empathy revolutionizes mental health support through advanced AI technology, creating personalized therapeutic experiences that truly understand and respond to human emotions.",
  primaryAction = { text: "Start Your Journey", href: "/get-started" },
  secondaryAction = { text: "Watch Demo", href: "/demo" },
  backgroundPattern = true
} = Astro.props;
---

<section class="modern-hero">
  {backgroundPattern && (
    <div class="hero-background-pattern">
      <div class="floating-shapes">
        <div class="shape shape-1"></div>
        <div class="shape shape-2"></div>
        <div class="shape shape-3"></div>
        <div class="shape shape-4"></div>
      </div>
    </div>
  )}
  
  <div class="container">
    <div class="hero-content fade-in">
      <h1 class="modern-hero-title slide-up">
        {title}
      </h1>
      
      <p class="modern-hero-subtitle slide-up">
        {subtitle}
      </p>
      
      <div class="modern-hero-actions slide-up">
        <a href={primaryAction.href} class="btn btn-primary btn-lg">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14"></path>
            <path d="M12 5l7 7-7 7"></path>
          </svg>
          {primaryAction.text}
        </a>
        
        <a href={secondaryAction.href} class="btn btn-secondary btn-lg">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polygon points="5,3 19,12 5,21"></polygon>
          </svg>
          {secondaryAction.text}
        </a>
      </div>
    </div>
    
    <!-- Modern Stats Section -->
    <div class="hero-stats">
      <div class="stats-grid">
        <div class="stat-item">
          <div class="stat-number">10K+</div>
          <div class="stat-label">Users Helped</div>
        </div>
        <div class="stat-item">
          <div class="stat-number">95%</div>
          <div class="stat-label">Satisfaction Rate</div>
        </div>
        <div class="stat-item">
          <div class="stat-number">24/7</div>
          <div class="stat-label">AI Support</div>
        </div>
        <div class="stat-item">
          <div class="stat-number">HIPAA</div>
          <div class="stat-label">Compliant</div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .modern-hero {
    position: relative;
    background: linear-gradient(135deg, 
      var(--color-background) 0%, 
      var(--color-background-secondary) 100%);
    overflow: hidden;
    padding: var(--space-20) 0 var(--space-24);
  }

  .hero-background-pattern {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    pointer-events: none;
    z-index: 0;
  }

  .floating-shapes {
    position: absolute;
    width: 100%;
    height: 100%;
  }

  .shape {
    position: absolute;
    border-radius: 50%;
    background: linear-gradient(135deg, 
      var(--color-primary-200) 0%, 
      var(--color-accent-blue) 50%, 
      var(--color-accent-purple) 100%);
    opacity: 0.1;
    animation: float 6s ease-in-out infinite;
  }

  .shape-1 {
    width: 200px;
    height: 200px;
    top: 10%;
    left: 10%;
    animation-delay: 0s;
  }

  .shape-2 {
    width: 150px;
    height: 150px;
    top: 60%;
    right: 15%;
    animation-delay: 2s;
  }

  .shape-3 {
    width: 100px;
    height: 100px;
    top: 20%;
    right: 30%;
    animation-delay: 4s;
  }

  .shape-4 {
    width: 120px;
    height: 120px;
    bottom: 20%;
    left: 20%;
    animation-delay: 3s;
  }

  @keyframes float {
    0%, 100% {
      transform: translateY(0px) rotate(0deg);
    }
    50% {
      transform: translateY(-20px) rotate(180deg);
    }
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .modern-hero-title {
    background: linear-gradient(135deg, 
      var(--color-text) 0%, 
      var(--color-primary-500) 50%, 
      var(--color-accent-blue) 100%);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-size: 200% 200%;
    animation: gradientShift 3s ease-in-out infinite;
    margin-bottom: var(--space-6);
  }

  @keyframes gradientShift {
    0%, 100% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
  }

  .modern-hero-subtitle {
    font-size: var(--font-size-xl);
    color: var(--color-text-secondary);
    max-width: 600px;
    margin: 0 auto var(--space-8);
    line-height: var(--line-height-relaxed);
  }

  .modern-hero-actions {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: var(--space-16);
  }

  .btn-lg {
    padding: var(--space-4) var(--space-8);
    font-size: var(--font-size-lg);
    font-weight: 600;
    border-radius: var(--radius-xl);
    min-width: 160px;
  }

  .hero-stats {
    margin-top: var(--space-16);
    padding-top: var(--space-12);
    border-top: 1px solid var(--color-border);
    opacity: 0.8;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: var(--space-8);
    max-width: 600px;
    margin: 0 auto;
  }

  .stat-item {
    text-align: center;
    padding: var(--space-4);
    border-radius: var(--radius-lg);
    background: var(--color-background);
    border: 1px solid var(--color-border);
    transition: all var(--transition-normal);
  }

  .stat-item:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
    border-color: var(--color-primary-200);
  }

  .stat-number {
    font-size: var(--font-size-2xl);
    font-weight: 700;
    color: var(--color-primary-500);
    margin-bottom: var(--space-1);
  }

  .stat-label {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    font-weight: 500;
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    .modern-hero {
      padding: var(--space-16) 0 var(--space-20);
    }

    .modern-hero-title {
      font-size: var(--font-size-4xl);
      line-height: 1.1;
    }

    .modern-hero-subtitle {
      font-size: var(--font-size-lg);
    }

    .modern-hero-actions {
      flex-direction: column;
      align-items: stretch;
      max-width: 300px;
      margin: 0 auto var(--space-12);
    }

    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-4);
    }

    .shape {
      display: none; /* Hide floating shapes on mobile for performance */
    }
  }

  /* Animation delays for staggered entrance */
  .slide-up:nth-child(1) {
    animation-delay: 0.1s;
  }
  .slide-up:nth-child(2) {
    animation-delay: 0.2s;
  }
  .slide-up:nth-child(3) {
    animation-delay: 0.3s;
  }
</style>