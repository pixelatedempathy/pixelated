---
// Feature Showcase Section with modern cards and animations
---

<section class="py-24 bg-gradient-to-b from-gray-950 to-gray-900">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    
    <!-- Section Header -->
    <div class="text-center mb-16">
      <div class="inline-flex items-center px-4 py-2 rounded-full bg-emerald-500/10 border border-emerald-500/20 mb-6">
        <span class="w-2 h-2 bg-emerald-400 rounded-full mr-2"></span>
        <span class="text-emerald-400 text-sm font-medium">Platform Features</span>
      </div>
      
      <h2 class="text-4xl font-bold text-white mb-6">
        Advanced AI Training
      </h2>
      <p class="text-xl text-gray-300 max-w-3xl mx-auto">
        Cutting-edge technology meets evidence-based therapeutic training in our comprehensive platform designed for mental health professionals.
      </p>
    </div>
    
    <!-- Feature Grid -->
    <div class="grid lg:grid-cols-2 gap-8 mb-16">
      
      <!-- HIPAA Compliant -->
      <div class="group relative bg-gray-900/50 backdrop-blur-xl border border-gray-700/50 rounded-2xl p-8 hover:border-emerald-500/30 transition-all duration-300">
        <div class="flex items-start space-x-4">
          <div class="flex-shrink-0">
            <div class="w-12 h-12 bg-gradient-to-br from-red-500 to-red-600 rounded-xl flex items-center justify-center">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5-7v12a2 2 0 01-2 2H6a2 2 0 01-2-2V5a2 2 0 012-2h5m4 0V2a1 1 0 011-1h1a1 1 0 011 1v1m0 0a2 2 0 012 2v1"/>
              </svg>
            </div>
          </div>
          <div class="flex-1">
            <div class="flex items-center justify-between mb-2">
              <h3 class="text-xl font-semibold text-white">HIPAA Compliant</h3>
              <span class="bg-emerald-500/10 text-emerald-400 px-2 py-1 rounded-full text-xs font-medium">100% Secure</span>
            </div>
            <p class="text-gray-300 mb-4">
              Enterprise-grade security ensuring all training data and interactions meet healthcare privacy standards.
            </p>
            <div class="flex items-center text-sm text-gray-400">
              <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"/>
              </svg>
              End-to-end encryption
            </div>
          </div>
        </div>
      </div>
      
      <!-- Instant Feedback -->
      <div class="group relative bg-gray-900/50 backdrop-blur-xl border border-gray-700/50 rounded-2xl p-8 hover:border-emerald-500/30 transition-all duration-300">
        <div class="flex items-start space-x-4">
          <div class="flex-shrink-0">
            <div class="w-12 h-12 bg-gradient-to-br from-emerald-500 to-emerald-600 rounded-xl flex items-center justify-center">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
            </div>
          </div>
          <div class="flex-1">
            <div class="flex items-center justify-between mb-2">
              <h3 class="text-xl font-semibold text-white">Instant Feedback</h3>
              <span class="bg-emerald-500/10 text-emerald-400 px-2 py-1 rounded-full text-xs font-medium">&lt; 100ms response</span>
            </div>
            <p class="text-gray-300 mb-4">
              Receive immediate, actionable feedback on your therapeutic responses and communication style.
            </p>
            <div class="flex items-center text-sm text-gray-400">
              <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"/>
              </svg>
              Real-time analysis
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Trust Section -->
    <div class="relative">
      <div class="text-center mb-12">
        <div class="inline-flex items-center px-4 py-2 rounded-full bg-emerald-500/10 border border-emerald-500/20 mb-6">
          <span class="w-2 h-2 bg-emerald-400 rounded-full mr-2"></span>
          <span class="text-emerald-400 text-sm font-medium">Enterprise Trust</span>
        </div>
        <h3 class="text-3xl font-bold text-white mb-4">Trusted by Professionals</h3>
        <p class="text-gray-300 max-w-2xl mx-auto">
          Leading healthcare institutions rely on our unified AI training platform
        </p>
      </div>
      
      <!-- Stats Grid -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 bg-gradient-to-br from-emerald-500 to-cyan-500 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
            </svg>
          </div>
          <div class="text-3xl font-bold text-emerald-400 mb-1">500+</div>
          <div class="text-sm text-gray-400">Healthcare Institutions</div>
        </div>
        
        <div class="text-center">
          <div class="w-16 h-16 bg-gradient-to-br from-blue-500 to-purple-500 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"/>
            </svg>
          </div>
          <div class="text-3xl font-bold text-blue-400 mb-1">15K+</div>
          <div class="text-sm text-gray-400">Trained Professionals</div>
        </div>
        
        <div class="text-center">
          <div class="w-16 h-16 bg-gradient-to-br from-yellow-500 to-orange-500 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.196-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
            </svg>
          </div>
          <div class="text-3xl font-bold text-yellow-400 mb-1">98%</div>
          <div class="text-sm text-gray-400">Satisfaction Rate</div>
        </div>
        
        <div class="text-center">
          <div class="w-16 h-16 bg-gradient-to-br from-purple-500 to-pink-500 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <div class="text-3xl font-bold text-purple-400 mb-1">24/7</div>
          <div class="text-sm text-gray-400">Platform Availability</div>
        </div>
      </div>
    </div>
  </div>
</section>