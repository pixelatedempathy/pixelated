---
import Layout from '@/layouts/Layout.astro'
import PageHero from '@/components/ui/PageHero.astro'
import ContentSection from '@/components/ui/ContentSection.astro'
import FeatureCard from '@/components/ui/FeatureCard.astro'
import AnimatedCounter from '@/components/ui/AnimatedCounter.astro'
---

<Layout title="Features - Pixelated Empathy">
  <PageHero
    badge="Platform Features"
    title="Everything You Need to Train Better"
    subtitle="Advanced AI simulation meets evidence-based therapeutic training in our comprehensive platform."
  />

  <ContentSection>
    <div class="grid md:grid-cols-2 gap-8 max-w-6xl mx-auto">
      <FeatureCard
        title="AI-Powered Scenarios"
        description="Practice with 1000+ realistic AI-generated patient scenarios covering diverse mental health conditions from anxiety to PTSD."
        color="blue"
        offset="up"
        icon='<svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z"/></svg>'
      >
        <ul class="mt-4 space-y-2 text-sm text-gray-500">
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-blue-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Dynamic difficulty scaling
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-blue-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Evidence-based responses
          </li>
        </ul>
      </FeatureCard>

      <FeatureCard
        title="Instant Feedback"
        description="Receive immediate, actionable feedback on your therapeutic responses. No waiting. No guessing. Just growth."
        color="cyan"
        offset="down"
        icon='<svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M2 5a2 2 0 012-2h7a2 2 0 012 2v4a2 2 0 01-2 2H9l-3 3v-3H4a2 2 0 01-2-2V5z"/><path d="M15 7v2a4 4 0 01-4 4H9.828l-1.766 1.767c.28.149.599.233.938.233h2l3 3v-3h2a2 2 0 002-2V9a2 2 0 00-2-2h-1z"/></svg>'
      >
        <div class="mt-4 px-3 py-1 bg-cyan-500/20 border border-cyan-500/30 rounded-full text-xs font-semibold text-cyan-400 inline-block">
          &lt; 100ms response time
        </div>
      </FeatureCard>

      <FeatureCard
        title="HIPAA Compliant"
        description="Enterprise-grade security ensuring all training data meets healthcare privacy standards. Because your patients' trust matters."
        color="red"
        offset="up"
        icon='<svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>'
      >
        <div class="mt-4 px-3 py-1 bg-red-500/20 border border-red-500/30 rounded-full text-xs font-semibold text-red-400 inline-block">
          100% Secure
        </div>
      </FeatureCard>

      <FeatureCard
        title="Progress Tracking"
        description="Comprehensive analytics and insights to monitor your skill development over time with detailed performance metrics."
        color="purple"
        offset="down"
        icon='<svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M2 11a1 1 0 011-1h2a1 1 0 011 1v5a1 1 0 01-1 1H3a1 1 0 01-1-1v-5zM8 7a1 1 0 011-1h2a1 1 0 011 1v9a1 1 0 01-1 1H9a1 1 0 01-1-1V7zM14 4a1 1 0 011-1h2a1 1 0 011 1v12a1 1 0 01-1 1h-2a1 1 0 01-1-1V4z"/></svg>'
      >
        <div class="mt-4 px-3 py-1 bg-purple-500/20 border border-purple-500/30 rounded-full text-xs font-semibold text-purple-400 inline-block">
          Real-time analytics
        </div>
      </FeatureCard>
    </div>
  </ContentSection>

  <ContentSection diagonal>
    <div class="max-w-4xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 px-4 py-2 bg-emerald-500/10 border border-emerald-500/20 rounded-full mb-6">
        <span class="text-sm font-medium text-emerald-400">Trusted by Professionals</span>
      </div>
      <h2 class="text-4xl font-bold text-white mb-4">Join 135K+ Mental Health Professionals</h2>
      <p class="text-xl text-gray-300 mb-8">
        Leading healthcare institutions trust our platform for training excellence.
      </p>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 mt-12">
        <AnimatedCounter value="500+" label="Healthcare Institutions" />
        <AnimatedCounter value="135K+" label="Trained Professionals" />
        <AnimatedCounter value="98%" label="Satisfaction Rate" />
        <AnimatedCounter value="24" label="Platform Availability" suffix="/7" />
      </div>
    </div>
  </ContentSection>

  <ContentSection>
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-4xl font-bold text-white mb-6">Ready to Get Started?</h2>
      <p class="text-xl text-gray-300 mb-8">
        Join thousands of professionals already using our platform.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/get-started" class="px-8 py-4 bg-gradient-to-r from-emerald-500 to-cyan-500 text-white font-semibold rounded-xl hover:shadow-2xl hover:shadow-emerald-500/50 hover:-translate-y-1 transition-all duration-300">
          Start Free Trial
        </a>
        <a href="/demo" class="px-8 py-4 bg-white/5 backdrop-blur-sm border border-white/10 text-white font-semibold rounded-xl hover:bg-white/10 hover:border-white/20 hover:-translate-y-1 transition-all duration-300">
          Schedule Demo
        </a>
      </div>
    </div>
  </ContentSection>
</Layout>
