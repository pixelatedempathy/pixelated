---
/**
 * Hero Section - Redesigned
 * Flabbergasted: Asymmetric layout, bold personality, playful elements
 * Mizu: Fluid animations, generous spacing
 * AstroMaxx: Glassmorphism, smooth animations
 * Antfu: Clean typography, minimal aesthetic
 */
import AnimatedCounter from './AnimatedCounter.astro'
import Button from './Button.astro'
---

<section class="relative min-h-screen flex items-center overflow-hidden pt-24 pb-16">
  
  <!-- Antfu: Subtle Grid Background -->
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(16,185,129,0.05),transparent_50%)]"></div>
  <div class="absolute inset-0" style="background-image: radial-gradient(circle, rgba(255,255,255,0.1) 1px, transparent 1px); background-size: 32px 32px;"></div>
  
  <!-- Flabbergasted: Playful Geometric Shapes -->
  <div class="absolute top-20 right-10 w-64 h-64 bg-gradient-to-br from-purple-500/10 to-pink-500/10 rounded-full blur-3xl"></div>
  <div class="absolute bottom-20 left-10 w-96 h-96 bg-gradient-to-tr from-emerald-500/10 to-cyan-500/10 rounded-full blur-3xl"></div>
  
  <div class="container mx-auto px-6 relative z-10">
    
    <!-- Flabbergasted: Asymmetric Grid Layout -->
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">
      
      <!-- Left: Content (7 columns) -->
      <div class="lg:col-span-7 space-y-8">
        
        <!-- Flabbergasted: Playful Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-gradient-to-r from-emerald-500/10 to-cyan-500/10 border border-emerald-500/20 rounded-full backdrop-blur-sm fade-in-up">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
          </span>
          <span class="text-sm font-medium text-emerald-400 font-mono">v2.0 | AI Ready</span>
        </div>

        <!-- Mizu + Flabbergasted: Bold Headline with Mixed Weights -->
        <h1 class="font-bold leading-tight fade-in-up" style="font-size: var(--text-4xl); animation-delay: 100ms;">
          <span class="text-white">Transform</span>
          <span class="block text-white">Mental Health</span>
          <span class="block bg-gradient-to-r from-emerald-400 via-cyan-400 to-purple-400 bg-clip-text text-transparent">
            Training with AI
          </span>
        </h1>

        <!-- Antfu: Clean, Readable Description -->
        <p class="text-gray-300 max-w-2xl leading-relaxed fade-in-up" style="font-size: var(--text-lg); animation-delay: 200ms;">
          Revolutionary AI simulation platform for mental health professionals. Experience immersive training scenarios and improve patient outcomes through advanced empathy engineering.
        </p>

        <!-- Flabbergasted: Bold CTA Buttons -->
        <div class="flex flex-wrap gap-4 fade-in-up" style="animation-delay: 300ms;">
          <Button 
            href="/get-started" 
            size="lg"
            class="group bg-gradient-to-r from-emerald-500 to-cyan-500 hover:shadow-2xl hover:shadow-emerald-500/50 hover:-translate-y-1"
          >
            Start Training
            <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
            </svg>
          </Button>
          <Button 
            href="/demo" 
            variant="outline"
            size="lg"
            class="hover:-translate-y-1"
          >
            Watch Demo
          </Button>
        </div>

        <!-- Mizu: Stats with Generous Spacing -->
        <div class="grid grid-cols-3 gap-6 pt-8 fade-in-up" style="animation-delay: 400ms;">
          <AnimatedCounter value="--" label="Training Sessions" />
          <AnimatedCounter value="--" label="Accuracy Rate" />
          <AnimatedCounter value="24/7" label="Availability" />
        </div>

        <!-- Trust Indicators -->
        <div class="flex flex-wrap items-center gap-6 pt-4 text-sm text-gray-400 fade-in-up" style="animation-delay: 500ms;">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-emerald-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
            </svg>
            <span>HIPAA Compliant</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-emerald-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
            </svg>
            <span>Enterprise Security</span>
          </div>
          <div class="flex items-center gap-2 font-mono text-xs bg-gray-900/50 px-3 py-1 rounded border border-gray-800">
            <span class="text-emerald-400">v2.0</span>
            <span class="text-gray-600">|</span>
            <span class="text-cyan-400">API Ready</span>
          </div>
        </div>
      </div>

      <!-- Right: Visual (5 columns) - Flabbergasted: Angled/Offset -->
      <div class="lg:col-span-5 relative fade-in-up" style="animation-delay: 300ms;">
        
        <!-- AstroMaxx: Glass Card with Simulation Preview -->
        <div class="relative">
          <!-- Flabbergasted: Rotated Container -->
          <div class="lg:rotate-3 lg:translate-x-4">
            <div class="bg-black/40 backdrop-blur-xl border border-white/10 rounded-2xl p-6 shadow-[0_25px_50px_-12px_rgba(0,0,0,0.8),0_0_0_1px_rgba(255,255,255,0.05)]">
              
              <!-- Header -->
              <div class="flex items-center justify-between mb-6">
                <div class="flex items-center gap-3">
                  <div class="w-3 h-3 rounded-full bg-red-500"></div>
                  <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                  <div class="w-3 h-3 rounded-full bg-green-500"></div>
                </div>
                <div class="flex items-center gap-2 px-3 py-1 bg-emerald-500/20 border border-emerald-500/30 rounded-full animate-pulse-subtle">
                  <span class="relative flex h-2 w-2">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
                  </span>
                  <span class="text-xs font-medium text-emerald-400">Live AI Simulation</span>
                </div>
              </div>

              <!-- Chat Simulation -->
              <div class="space-y-4">
                <!-- AI Message -->
                <div class="flex gap-3">
                  <div class="w-8 h-8 rounded-full bg-gradient-to-br from-purple-500 to-pink-500 flex items-center justify-center flex-shrink-0">
                    <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M2 5a2 2 0 012-2h7a2 2 0 012 2v4a2 2 0 01-2 2H9l-3 3v-3H4a2 2 0 01-2-2V5z"></path>
                      <path d="M15 7v2a4 4 0 01-4 4H9.828l-1.766 1.767c.28.149.599.233.938.233h2l3 3v-3h2a2 2 0 002-2V9a2 2 0 00-2-2h-1z"></path>
                    </svg>
                  </div>
                  <div class="flex-1 bg-white/5 border border-white/10 rounded-2xl rounded-tl-none p-4">
                    <p class="text-sm text-gray-200 font-medium" style="text-shadow: 0 1px 2px rgba(0,0,0,0.5);">"How are you feeling today? I notice you seem a bit stressed..."</p>
                  </div>
                </div>

                <!-- User Response -->
                <div class="flex gap-3 justify-end">
                  <div class="flex-1 bg-gradient-to-r from-emerald-500/20 to-cyan-500/20 border border-emerald-500/30 rounded-2xl rounded-tr-none p-4">
                    <p class="text-sm text-white font-medium" style="text-shadow: 0 1px 2px rgba(0,0,0,0.5);">"I've been having trouble sleeping and feeling anxious about work..."</p>
                  </div>
                  <div class="w-8 h-8 rounded-full bg-gradient-to-br from-emerald-500 to-cyan-500 flex items-center justify-center flex-shrink-0">
                    <span class="text-white text-xs font-bold">U</span>
                  </div>
                </div>

                <!-- Typing Indicator -->
                <div class="flex gap-3 typing-indicator">
                  <div class="w-8 h-8 rounded-full bg-gradient-to-br from-purple-500 to-pink-500 flex items-center justify-center flex-shrink-0">
                    <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M2 5a2 2 0 012-2h7a2 2 0 012 2v4a2 2 0 01-2 2H9l-3 3v-3H4a2 2 0 01-2-2V5z"></path>
                      <path d="M15 7v2a4 4 0 01-4 4H9.828l-1.766 1.767c.28.149.599.233.938.233h2l3 3v-3h2a2 2 0 002-2V9a2 2 0 00-2-2h-1z"></path>
                    </svg>
                  </div>
                  <div class="flex-1 bg-white/5 border border-white/10 rounded-2xl rounded-tl-none p-4">
                    <div class="flex items-center gap-1">
                      <div class="w-2 h-2 bg-gray-400 rounded-full animate-bounce" style="animation-delay: 0ms;"></div>
                      <div class="w-2 h-2 bg-gray-400 rounded-full animate-bounce" style="animation-delay: 150ms;"></div>
                      <div class="w-2 h-2 bg-gray-400 rounded-full animate-bounce" style="animation-delay: 300ms;"></div>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Real-Time Analytics -->
              <div class="mt-6 pt-6 border-t border-white/10">
                <div class="text-xs text-gray-400 mb-3">Real-Time Analytics</div>
                <div class="grid grid-cols-3 gap-4">
                  <div class="text-center">
                    <div class="text-2xl font-bold text-emerald-400">92%</div>
                    <div class="text-xs text-gray-500">Engagement</div>
                  </div>
                  <div class="text-center">
                    <div class="text-2xl font-bold text-cyan-400">8.4</div>
                    <div class="text-xs text-gray-500">Empathy Score</div>
                  </div>
                  <div class="text-center">
                    <div class="text-2xl font-bold text-purple-400">A+</div>
                    <div class="text-xs text-gray-500">Performance</div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Flabbergasted: Floating Elements -->
          <div class="absolute -top-4 -right-4 w-20 h-20 bg-gradient-to-br from-amber-500 to-orange-500 rounded-2xl rotate-12 opacity-20 blur-xl"></div>
          <div class="absolute -bottom-4 -left-4 w-16 h-16 bg-gradient-to-br from-pink-500 to-purple-500 rounded-full opacity-20 blur-xl"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll Indicator - Antfu Minimal -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
    </svg>
  </div>
</section>

<style>
  /* AstroMaxx: Smooth Animations */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .fade-in-up {
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
  }

  /* Custom animations for enhanced chat simulation */
  @keyframes pulse-subtle {
    0%, 100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.8;
      transform: scale(1.02);
    }
  }

  .animate-pulse-subtle {
    animation: pulse-subtle 2s ease-in-out infinite;
  }

  .typing-indicator {
    animation: fadeInUp 0.5s ease-out 2s both;
  }
</style>
