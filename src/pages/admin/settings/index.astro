---
export const prerender = false
import DashboardLayout from '../../../layouts/DashboardLayout.astro'
import DashboardCard from '@/components/ui/DashboardCard.astro'
import FormInput from '@/components/ui/FormInput.astro'
---
<DashboardLayout title="Settings - Admin">
  <div class="space-y-8">
    <h1 class="text-3xl font-bold text-white">System Settings</h1>
    <DashboardCard title="Config">
      <form class="space-y-4">
        <FormInput label="Site Name" name="siteName" type="text" />
        <button type="submit" class="px-6 py-3 bg-gradient-to-r from-emerald-500 to-cyan-500 text-black font-bold rounded-lg">Save</button>
      </form>
    </DashboardCard>
  </div>
</DashboardLayout>
