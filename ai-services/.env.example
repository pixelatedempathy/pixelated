# Pixelated Empathy AI Services - Environment Variables
# Copy this file to .env and fill in your actual credentials
# NEVER commit .env to version control!

# MongoDB Connection
# Format: mongodb+srv://USERNAME:PASSWORD@CLUSTER/DATABASE?options
MONGODB_URI=mongodb+srv://<USERNAME>:<PASSWORD>@<CLUSTER>.mongodb.net/<DATABASE>?retryWrites=true&w=majority&appName=YOUR_APP_NAME

# API Configuration
FLASK_ENV=development
FLASK_DEBUG=1
API_PORT=5000
