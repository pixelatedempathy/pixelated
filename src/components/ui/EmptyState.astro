---
interface Props {
  icon?: string
  title: string
  description: string
  actionLabel?: string
  actionHref?: string
}

const { icon = '📭', title, description, actionLabel, actionHref } = Astro.props
---

<div class="flex flex-col items-center justify-center py-12 px-6 text-center">
  <div class="text-6xl mb-4">{icon}</div>
  <h3 class="text-2xl font-bold text-white mb-2">{title}</h3>
  <p class="text-gray-400 mb-6 max-w-md">{description}</p>
  {actionLabel && actionHref && (
    <a 
      href={actionHref}
      class="px-6 py-3 bg-gradient-to-r from-emerald-500 to-cyan-500 hover:from-emerald-600 hover:to-cyan-600 text-black font-bold rounded-lg transition-all duration-200 transform hover:scale-105"
    >
      {actionLabel}
    </a>
  )}
  <slot />
</div>
