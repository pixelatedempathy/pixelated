    "source": [
     "# Bulk Secrets Import for Colab\n",
     "\n",
     "Import ALL secrets at once using a single code cell."
    ]
   },
   {
    "cell_type": "code",
    "execution_count": null,
    "metadata": {},
    "outputs": [],
    "source": [
     "# BULK SECRETS IMPORT\n",
     "# Run this ONCE to add all secrets to Colab Secrets\n",
     "\n",
     "from google.colab import userdata\n",
     "import json\n",
     "\n",
     "# Define all secrets here (copy-paste once)\n",
     "SECRETS = {\n",
     "    'OVH_S3_ACCESS_KEY': 'b6939e6b65ef4252b20338499421a5f0',\n",
     "    'OVH_S3_SECRET_KEY': '4a7e939381c6467c88f81a5024672a96',\n",
     "    'OVH_S3_BUCKET': 'pixel-data',\n",
     "    'OVH_S3_ENDPOINT': 'https://s3.us-east-va.io.cloud.ovh.us',\n",
     "    'OVH_S3_REGION': 'us-east-va',\n",
     "    'WANDB_API_KEY': 'your-wandb-key-here',  # Optional\n",
     "    'HF_TOKEN': 'hf_your-token-here',  # Optional\n",
     "}\n",
     "\n",
     "# Add all secrets to Colab Secrets\n",
     "print('Adding secrets to Colab...')\n",
     "for name, value in SECRETS.items():\n",
     "    if value and not value.startswith('your-'):\n",
     "        try:\n",
     "            userdata.set(name, value)\n",
     "            print(f'✅ Added: {name}')\n",
     "        except Exception as e:\n",
     "            print(f'❌ Failed {name}: {e}')\n",
     "\n",
     "print('\\n🎉 Done! All secrets imported.')\n",
     "print('You can now use: userdata.get(\"SECRET_NAME\")')"
    ]
   },
   {
    "cell_type": "markdown",
    "metadata": {},
    "source": [
     "## Alternative: JSON Paste Method\n",
     "\n",
     "If the above doesn't work, paste JSON in one go:"
    ]
   },
   {
    "cell_type": "code",
    "execution_count": null,
    "metadata": {},
    "outputs": [],
    "source": [
     "# Paste this JSON once, then run\n",
     "\n",
     "SECRETS_JSON = '''\n",
     "{\n",
     "    \\"OVH_S3_ACCESS_KEY\\": \\"b6939e6b65ef4252b20338499421a5f0\\",\n",
     "    \\"OVH_S3_SECRET_KEY\\": \\"4a7e939381c6467c88f81a5024672a96\\",\n",
     "    \\"OVH_S3_BUCKET\\": \\"pixel-data\\",\n",
     "    \\"OVH_S3_ENDPOINT\\": \\"https://s3.us-east-va.io.cloud.ovh.us\\"\n",
     "}\n",
     "'''\n",
     "\n",
     "import json\n",
     "from google.colab import userdata\n",
     "\n",
     "secrets = json.loads(SECRETS_JSON)\n",
     "for name, value in secrets.items():\n",
     "    userdata.set(name, value)\n",
     "    print(f'Added: {name}')\n",
     "\n",
     "print('\\n✅ All secrets imported!')"
    ]
   },
   {
    "cell_type": "markdown",
    "metadata": {},
    "source": [
     "## Usage in Training\n",
     "\n",
     "After importing secrets above, load them in any notebook:"
    ]
   },
   {
    "cell_type": "code",
    "execution_count": null,
    "metadata": {},
    "outputs": [],
    "source": [
     "# Load all secrets into environment\n",
     "from google.colab import userdata\n",
     "import os\n",
     "\n",
     "SECRET_NAMES = [\n",
     "    'OVH_S3_ACCESS_KEY',\n",
     "    'OVH_S3_SECRET_KEY',\n",
     "    'OVH_S3_BUCKET',\n",
     "    'OVH_S3_ENDPOINT',\n",
     "    'OVH_S3_REGION',\n",
     "    'WANDB_API_KEY',\n",
     "    'HF_TOKEN',\n",
     "]\n",
     "\n",
     "for name in SECRET_NAMES:\n",
     "    try:\n",
     "        os.environ[name] = userdata.get(name)\n",
     "        print(f'✅ Loaded: {name}')\n",
     "    except:\n",
     "        print(f'⚠️  Missing: {name}')\n",
     "\n",
     "print('\\n🚀 Ready to train!')"
    ]
   }
  ]
}
