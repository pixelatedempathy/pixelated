---
interface Props {
  title: string
  excerpt: string
  href: string
  image?: string
  category?: string
  date?: string
  readTime?: string
  author?: string
}

const { title, excerpt, href, image, category, date, readTime, author } = Astro.props
---

<a 
  href={href}
  class="group block bg-black/40 backdrop-blur-xl border border-white/10 rounded-2xl overflow-hidden hover:border-white/20 hover:-translate-y-2 transition-all duration-300"
>
  {image && (
    <div class="aspect-video overflow-hidden">
      <img 
        src={image} 
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
      />
    </div>
  )}
  
  <div class="p-6">
    <div class="flex items-center gap-3 mb-4">
      {category && (
        <span class="px-3 py-1 bg-emerald-500/20 border border-emerald-500/30 text-emerald-400 text-xs font-semibold rounded-full">
          {category}
        </span>
      )}
      {readTime && (
        <span class="text-gray-500 text-sm flex items-center gap-1">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          {readTime}
        </span>
      )}
    </div>
    
    <h3 class="text-xl font-bold text-white mb-3 group-hover:text-emerald-400 transition-colors">
      {title}
    </h3>
    
    <p class="text-gray-400 leading-relaxed mb-4 line-clamp-3">
      {excerpt}
    </p>
    
    <div class="flex items-center justify-between text-sm text-gray-500">
      {author && <span>{author}</span>}
      {date && <span>{date}</span>}
    </div>
  </div>
</a>
