---
import BaseLayout from '@/layouts/BaseLayout.astro'
import ModernHeroSection from '@/components/ui/ModernHeroSection.astro'
import FeaturesSection from '@/components/ui/FeaturesSection.astro'
import '@/styles/mizu-theme.css'
---

<BaseLayout
  title="AI-Powered Mental Health Training"
  description="Revolutionary AI simulation platform for mental health professionals. Experience immersive training scenarios and improve patient outcomes through cutting-edge technology."
  bgType="dark"
>
  <!-- Two-Pane Hero Section -->
  <ModernHeroSection />

  <!-- Features Section - Blocked Grid -->
  <FeaturesSection />

  <!-- Stats Section - Blocked Grid -->
  <section class="mizu-stats">
    <div class="mizu-stats-container">
      <div class="mizu-decoration-border mizu-decoration-border--dashed">
        <span class="mizu-decoration-border__top"></span>
        <span class="mizu-decoration-border__bottom"></span>
      </div>
      <div class="mizu-stats-header">
        <div class="mizu-stats-badge">
          <span>Enterprise Trust</span>
        </div>
        <h2 class="mizu-stats-title">Trusted by Professionals</h2>
        <p class="mizu-stats-description">
          Leading healthcare institutions rely on our unified AI training platform
        </p>
      </div>

      <div class="mizu-stats-grid">
        <div class="mizu-stat-card">
          <div class="mizu-stat-number">500+</div>
          <div class="mizu-stat-label">Healthcare Institutions</div>
        </div>
        <div class="mizu-stat-card">
          <div class="mizu-stat-number">15K+</div>
          <div class="mizu-stat-label">Trained Professionals</div>
        </div>
        <div class="mizu-stat-card">
          <div class="mizu-stat-number">98%</div>
          <div class="mizu-stat-label">Satisfaction Rate</div>
        </div>
        <div class="mizu-stat-card">
          <div class="mizu-stat-number">24/7</div>
          <div class="mizu-stat-label">Platform Availability</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonial Section - Two Pane -->
  <section class="mizu-testimonial">
    <div class="mizu-testimonial-container">
      <div class="mizu-testimonial-content">
        <div class="mizu-testimonial-badge">
          <span>Professional Testimonial</span>
        </div>

        <blockquote class="mizu-testimonial-quote">
          "This platform has revolutionized how we train our therapists. The AI scenarios are incredibly realistic and the analytics provide invaluable insights that directly improve patient outcomes."
        </blockquote>

        <div class="mizu-testimonial-author">
          <div class="mizu-testimonial-avatar">SC</div>
          <div class="mizu-testimonial-author-info">
            <div class="mizu-testimonial-author-name">Dr. Sarah Chen</div>
            <div class="mizu-testimonial-author-title">Director of Training, Metro Health System</div>
          </div>
        </div>
      </div>

      <div class="mizu-testimonial-metrics">
        <div class="mizu-metric">
          <div class="mizu-metric-value">40%</div>
          <div class="mizu-metric-label">Faster Training</div>
        </div>
        <div class="mizu-metric">
          <div class="mizu-metric-value">85%</div>
          <div class="mizu-metric-label">Patient Outcomes</div>
        </div>
        <div class="mizu-metric">
          <div class="mizu-metric-value">92%</div>
          <div class="mizu-metric-label">Therapist Confidence</div>
        </div>
        <div class="mizu-metric">
          <div class="mizu-metric-value">60%</div>
          <div class="mizu-metric-label">Cost Reduction</div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section - Blocked -->
  <section class="mizu-cta">
    <div class="mizu-cta-container">
      <h2 class="mizu-cta-title">Ready to Transform Mental Health Training?</h2>
      <p class="mizu-cta-description">
        Join thousands of mental health professionals who are already using our
        AI-powered platform to enhance their skills and improve patient outcomes.
      </p>
      <div class="mizu-cta-buttons">
        <a href="/auth/signup" class="mizu-btn mizu-btn-primary">
          Start Free Trial
        </a>
        <a href="/demo" class="mizu-btn mizu-btn-secondary">
          View Demo
        </a>
      </div>
      <p class="mizu-cta-note">
        No credit card required • 14-day free trial • Cancel anytime
      </p>
    </div>
  </section>
</BaseLayout>
