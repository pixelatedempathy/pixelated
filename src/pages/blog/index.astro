---
import { getCollection, type CollectionEntry } from 'astro:content'
import Layout from '@/layouts/Layout.astro'
import PageHero from '@/components/ui/PageHero.astro'
import ContentSection from '@/components/ui/ContentSection.astro'
import BlogCard from '@/components/ui/BlogCard.astro'
import Pagination from '@/components/ui/Pagination.astro'

function formatDate(dateInput: any) {
  if (!dateInput) return '-'
  const date = new Date(dateInput)
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
}

function getReadingTime(content: string) {
  const wordsPerMinute = 200
  const words = content.split(/\s+/).length
  const minutes = Math.ceil(words / wordsPerMinute)
  return `${minutes} min read`
}

export const prerender = true

type BlogPost = CollectionEntry<'blog'>

const allPosts = await getCollection('blog', ({ data }: BlogPost) => {
  return import.meta.env.PROD ? !data.draft : true
})

const posts = allPosts.sort(
  (a: BlogPost, b: BlogPost) =>
    new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
)

const tagFrequency = {}
allPosts.forEach((post) => {
  (post.data.tags || []).forEach((tag) => {
    tagFrequency[tag] = (tagFrequency[tag] || 0) + 1
  })
})
const topTags = Object.keys(tagFrequency)
  .sort((a, b) => tagFrequency[b] - tagFrequency[a])
  .slice(0, 6)
---

<Layout title="Blog - Pixelated Empathy" description="Writing on therapy, technology, and digital empathy.">
  <PageHero
    badge="Blog"
    title="Insights & Updates"
    subtitle="Writing on therapy, technology, and digital empathy. Sharing thoughts on creating meaningful therapeutic experiences through AI."
    gradient={true}
  />

  <!-- Category Filters -->
  <ContentSection>
    <div class="flex flex-wrap gap-3 justify-center mb-12">
      <button class="px-4 py-2 bg-emerald-500/20 border border-emerald-500/30 rounded-full text-emerald-400 font-medium hover:bg-emerald-500/30 transition-all duration-200">
        All Posts
      </button>
      {topTags.map((tag) => (
        <button class="px-4 py-2 bg-white/10 border border-white/20 rounded-full text-gray-300 font-medium hover:bg-white/20 transition-all duration-200">
          {tag}
        </button>
      ))}
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {posts.map((post) => (
        <BlogCard
          title={post.data.title}
          description={post.data.description}
          image={post.data.heroImage}
          category={post.data.tags?.[0] || 'Article'}
          readTime={getReadingTime(post.body)}
          date={formatDate(post.data.pubDate)}
          href={`/blog/${post.slug}`}
        />
      ))}
    </div>
  </ContentSection>

  <!-- Pagination -->
  <ContentSection>
    <Pagination
      currentPage={1}
      totalPages={Math.ceil(posts.length / 9)}
      baseUrl="/blog/page"
    />
  </ContentSection>
</Layout>
