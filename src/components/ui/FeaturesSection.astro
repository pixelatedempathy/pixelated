---
// Clean Mizu-inspired Features Section - Simplified to 4 key features
const features = [
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>`,
    title: 'AI-Powered Scenarios',
    description: 'Experience realistic patient interactions through advanced AI simulation that adapts to your responses in real-time.',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>`,
    title: 'Real-Time Analytics',
    description: 'Track your progress with detailed analytics on empathy scores, response quality, and therapeutic effectiveness.',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>`,
    title: 'Evidence-Based Training',
    description: 'Built on proven therapeutic methodologies and continuously updated with the latest research findings.',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>`,
    title: 'HIPAA Compliant',
    description: 'Enterprise-grade security ensuring all training data and interactions meet healthcare privacy standards.',
  },
]
---

<section class="mizu-features">
  <div class="mizu-features-container">
    <!-- Section Header -->
    <div class="mizu-features-header">
      <div class="mizu-features-badge">
        <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path>
        </svg>
        <span>Platform Features</span>
      </div>

      <h2 class="mizu-features-title">Advanced AI Training</h2>

      <p class="mizu-features-description">
        Cutting-edge technology meets evidence-based therapeutic training in our
        comprehensive platform designed for mental health professionals.
      </p>
    </div>

    <!-- Features Grid -->
    <div class="mizu-features-grid">
      {features.map((feature) => (
        <div class="mizu-feature-card">
          <div class="mizu-feature-icon">
            <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path set:html={feature.icon} />
            </svg>
          </div>
          <h3 class="mizu-feature-title">{feature.title}</h3>
          <p class="mizu-feature-description">{feature.description}</p>
        </div>
      ))}
    </div>
    <div class="mizu-decoration-border mizu-decoration-border--solid">
      <span class="mizu-decoration-border__top"></span>
      <span class="mizu-decoration-border__right"></span>
      <span class="mizu-decoration-border__bottom"></span>
      <span class="mizu-decoration-border__left"></span>
    </div>
  </div>
</section>
