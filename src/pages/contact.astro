---
import Layout from '@/layouts/Layout.astro'
import PageHero from '@/components/ui/PageHero.astro'
import ContentSection from '@/components/ui/ContentSection.astro'
---

<Layout title="Contact Us - Pixelated Empathy">
  <PageHero
    badge="Get in Touch"
    title="Contact Us"
    subtitle="Have questions? We're here to help. Reach out to our team and we'll get back to you within 24 hours."
  />

  <ContentSection>
    <div class="max-w-5xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-12">
        <!-- Contact Form -->
        <div
          class="bg-black/40 backdrop-blur-xl border border-white/10 rounded-2xl p-8"
        >
          <h2 class="text-2xl font-bold text-white mb-6">Send us a message</h2>

          <form id="contact-form" class="space-y-6" novalidate>
            <div>
              <label
                for="name"
                class="block text-sm font-medium text-gray-300 mb-2"
                >Name <span class="text-red-400">*</span></label
              >
              <input
                type="text"
                id="name"
                name="name"
                required
                minlength="2"
                class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:border-emerald-500/50 transition-colors"
                placeholder="Your name"
              />
              <span class="error-message hidden text-red-400 text-sm mt-1"
              ></span>
            </div>

            <div>
              <label
                for="email"
                class="block text-sm font-medium text-gray-300 mb-2"
                >Email <span class="text-red-400">*</span></label
              >
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:border-emerald-500/50 transition-colors"
                placeholder="your@email.com"
              />
              <span class="error-message hidden text-red-400 text-sm mt-1"
              ></span>
            </div>

            <div>
              <label
                for="subject"
                class="block text-sm font-medium text-gray-300 mb-2"
                >Subject <span class="text-red-400">*</span></label
              >
              <input
                type="text"
                id="subject"
                name="subject"
                required
                minlength="3"
                class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:border-emerald-500/50 transition-colors"
                placeholder="How can we help?"
              />
              <span class="error-message hidden text-red-400 text-sm mt-1"
              ></span>
            </div>

            <div>
              <label
                for="message"
                class="block text-sm font-medium text-gray-300 mb-2"
                >Message <span class="text-red-400">*</span></label
              >
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                minlength="10"
                class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:border-emerald-500/50 transition-colors resize-none"
                placeholder="Tell us more..."></textarea>
              <span class="error-message hidden text-red-400 text-sm mt-1"
              ></span>
            </div>

            <!-- Form status messages -->
            <div id="form-status" class="hidden p-4 rounded-lg"></div>

            <button
              type="submit"
              id="submit-button"
              class="w-full px-8 py-4 bg-gradient-to-r from-emerald-500 to-cyan-500 text-white font-semibold rounded-xl hover:shadow-2xl hover:shadow-emerald-500/50 hover:-translate-y-1 transition-all duration-300 disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:translate-y-0"
            >
              Send Message
            </button>
          </form>

          <script>
            // Contact form validation and submission
            const form = document.getElementById(
              'contact-form',
            ) as HTMLFormElement
            const submitButton = document.getElementById(
              'submit-button',
            ) as HTMLButtonElement
            const formStatus = document.getElementById(
              'form-status',
            ) as HTMLDivElement

            // Email validation regex
            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/

            // Validation functions
            function validateField(
              field: HTMLInputElement | HTMLTextAreaElement,
            ): boolean {
              const errorSpan = field.parentElement?.querySelector(
                '.error-message',
              ) as HTMLSpanElement
              let isValid = true
              let errorMessage = ''

              if (field.hasAttribute('required') && !field.value.trim()) {
                isValid = false
                errorMessage = 'This field is required'
              } else if (
                field.type === 'email' &&
                field.value &&
                !emailRegex.test(field.value)
              ) {
                isValid = false
                errorMessage = 'Please enter a valid email address'
              } else if (field.hasAttribute('minlength')) {
                const minLength = parseInt(
                  field.getAttribute('minlength') || '0',
                )
                if (field.value.length < minLength) {
                  isValid = false
                  errorMessage = `Minimum ${minLength} characters required`
                }
              }

              if (errorSpan) {
                if (isValid) {
                  errorSpan.classList.add('hidden')
                  errorSpan.textContent = ''
                  field.classList.remove('border-red-500')
                  field.classList.add('border-white/10')
                } else {
                  errorSpan.classList.remove('hidden')
                  errorSpan.textContent = errorMessage
                  field.classList.add('border-red-500')
                  field.classList.remove('border-white/10')
                }
              }

              return isValid
            }

            function showStatus(message: string, isError: boolean = false) {
              formStatus.classList.remove('hidden')
              formStatus.textContent = message
              formStatus.className = `p-4 rounded-lg ${isError ? 'bg-red-500/20 text-red-400 border border-red-500/30' : 'bg-emerald-500/20 text-emerald-400 border border-emerald-500/30'}`
            }

            function hideStatus() {
              formStatus.classList.add('hidden')
            }

            // Real-time validation on blur
            const fields = form.querySelectorAll('input, textarea')
            fields.forEach((field) => {
              field.addEventListener('blur', () => {
                validateField(field as HTMLInputElement | HTMLTextAreaElement)
              })

              // Clear error on input
              field.addEventListener('input', () => {
                const errorSpan = field.parentElement?.querySelector(
                  '.error-message',
                ) as HTMLSpanElement
                if (errorSpan && !errorSpan.classList.contains('hidden')) {
                  field.classList.remove('border-red-500')
                  field.classList.add('border-white/10')
                  errorSpan.classList.add('hidden')
                }
              })
            })

            // Form submission
            form.addEventListener('submit', async (e) => {
              e.preventDefault()
              hideStatus()

              // Validate all fields
              let isFormValid = true
              fields.forEach((field) => {
                if (
                  !validateField(
                    field as HTMLInputElement | HTMLTextAreaElement,
                  )
                ) {
                  isFormValid = false
                }
              })

              if (!isFormValid) {
                showStatus('Please correct the errors above', true)
                return
              }

              // Disable submit button and show loading state
              submitButton.disabled = true
              submitButton.textContent = 'Sending...'

              // Get form data
              const formData = new FormData(form)
              const data = {
                name: formData.get('name'),
                email: formData.get('email'),
                subject: formData.get('subject'),
                message: formData.get('message'),
              }

              try {
                // Submit to API endpoint
                const response = await fetch('/api/contact', {
                  method: 'POST',
                  headers: {
                    'Content-Type': 'application/json',
                  },
                  body: JSON.stringify(data),
                })

                const result = await response.json()

                if (response.ok && result.success) {
                  showStatus(
                    result.message ||
                      "✓ Message sent successfully! We'll get back to you within 24 hours.",
                    false,
                  )
                  form.reset()

                  // Re-enable button after delay
                  setTimeout(() => {
                    submitButton.disabled = false
                    submitButton.textContent = 'Send Message'
                  }, 2000)
                } else {
                  // Show validation or error message from server
                  showStatus(
                    result.message ||
                      '× Failed to send message. Please try again.',
                    true,
                  )
                  submitButton.disabled = false
                  submitButton.textContent = 'Send Message'
                }
              } catch (error) {
                console.error('Form submission error:', error)
                showStatus(
                  '× Network error. Please check your connection and try again, or email us directly.',
                  true,
                )
                submitButton.disabled = false
                submitButton.textContent = 'Send Message'
              }
            })
          </script>
        </div>

        <!-- Contact Info -->
        <div class="space-y-8">
          <div
            class="bg-black/40 backdrop-blur-xl border border-white/10 rounded-2xl p-8"
          >
            <div
              class="w-12 h-12 bg-gradient-to-br from-emerald-500 to-cyan-500 rounded-xl flex items-center justify-center mb-4"
            >
              <svg
                class="w-6 h-6 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                ></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-white mb-2">Email</h3>
            <p class="text-gray-400 mb-2">For general inquiries</p>
            <a
              href="mailto:hello@pixelatedempathy.com"
              class="text-emerald-400 hover:text-emerald-300 transition-colors"
            >
              hello@pixelatedempathy.com
            </a>
          </div>

          <div
            class="bg-black/40 backdrop-blur-xl border border-white/10 rounded-2xl p-8"
          >
            <div
              class="w-12 h-12 bg-gradient-to-br from-blue-500 to-indigo-500 rounded-xl flex items-center justify-center mb-4"
            >
              <svg
                class="w-6 h-6 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                ></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-white mb-2">Enterprise Sales</h3>
            <p class="text-gray-400 mb-2">For institutional partnerships</p>
            <a
              href="mailto:sales@pixelatedempathy.com"
              class="text-blue-400 hover:text-blue-300 transition-colors"
            >
              sales@pixelatedempathy.com
            </a>
          </div>

          <div
            class="bg-black/40 backdrop-blur-xl border border-white/10 rounded-2xl p-8"
          >
            <div
              class="w-12 h-12 bg-gradient-to-br from-purple-500 to-pink-500 rounded-xl flex items-center justify-center mb-4"
            >
              <svg
                class="w-6 h-6 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"
                ></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-white mb-2">Support</h3>
            <p class="text-gray-400 mb-2">Need technical help?</p>
            <a
              href="mailto:support@pixelatedempathy.com"
              class="text-purple-400 hover:text-purple-300 transition-colors"
            >
              support@pixelatedempathy.com
            </a>
          </div>
        </div>
      </div>
    </div>
  </ContentSection>
</Layout>
