---
export const prerender = true

import Layout from '../layouts/Layout.astro'
import PageHero from '../components/ui/PageHero.astro'
import ContentSection from '../components/ui/ContentSection.astro'

const leadership = [
  {
    initials: 'AK',
    name: 'Dr. Alex Kim',
    role: 'CEO & Co-Founder',
    credentials: 'PhD Clinical Psychology, Stanford',
    bio: 'Former Director of Digital Therapeutics at UCSF. 15+ years in clinical practice and AI research. Published 40+ papers on therapeutic AI applications.',
    color: 'emerald'
  },
  {
    initials: 'MR',
    name: 'Maria Rodriguez',
    role: 'CTO & Co-Founder',
    credentials: 'MS Computer Science, MIT',
    bio: 'Former Principal Engineer at Google DeepMind. Expert in conversational AI and natural language processing. Led development of therapeutic chatbot systems.',
    color: 'blue'
  },
  {
    initials: 'JC',
    name: 'Dr. James Chen',
    role: 'Chief Clinical Officer',
    credentials: 'MD Psychiatry, Johns Hopkins',
    bio: 'Board-certified psychiatrist with 20+ years experience. Former Chief of Psychiatry at Mayo Clinic. Specializes in crisis intervention and trauma-informed care.',
    color: 'purple'
  }
]

const team = [
  {
    initials: 'SK',
    name: 'Sarah Kim',
    role: 'Head of Product',
    department: 'Product'
  },
  {
    initials: 'DL',
    name: 'David Lee',
    role: 'Lead AI Engineer',
    department: 'Engineering'
  },
  {
    initials: 'EP',
    name: 'Dr. Emily Park',
    role: 'Research Director',
    department: 'Research'
  },
  {
    initials: 'TC',
    name: 'Tom Chen',
    role: 'Head of Design',
    department: 'Design'
  },
  {
    initials: 'LW',
    name: 'Lisa Wang',
    role: 'Clinical Training Lead',
    department: 'Clinical'
  },
  {
    initials: 'RJ',
    name: 'Raj Patel',
    role: 'Security Engineer',
    department: 'Engineering'
  }
]
---

<Layout title="Team - Pixelated Empathy">
  <PageHero
    badge="Our Team"
    title="Meet Our Team"
    subtitle="We're a passionate team of technologists, clinicians, and researchers dedicated to transforming mental health training through AI innovation."
    gradient={true}
  />

  <!-- Leadership Team -->
  <ContentSection>
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold mb-4">
        <span class="bg-gradient-to-r from-emerald-400 to-cyan-400 bg-clip-text text-transparent">
          Leadership Team
        </span>
      </h2>
      <p class="text-xl text-gray-300">
        Experienced leaders driving innovation in AI and mental health
      </p>
    </div>

    <div class="grid lg:grid-cols-3 gap-8">
      {leadership.map((member) => (
        <div class="relative group">
          <div class={`absolute inset-0 bg-gradient-to-r from-${member.color}-500/20 to-cyan-500/20 rounded-2xl blur-xl group-hover:blur-2xl transition-all duration-300`}></div>
          <div class={`relative bg-black/40 backdrop-blur-xl border border-white/10 rounded-2xl p-8 hover:border-${member.color}-500/30 transition-all duration-300`}>
            <div class="text-center mb-6">
              <div class={`w-24 h-24 bg-gradient-to-r from-${member.color}-500 to-cyan-500 rounded-full flex items-center justify-center text-white text-2xl font-bold mx-auto mb-4`}>
                {member.initials}
              </div>
              <h3 class="text-xl font-bold text-white mb-1">{member.name}</h3>
              <p class={`text-${member.color}-400 font-medium mb-2`}>{member.role}</p>
              <p class="text-gray-400 text-sm">{member.credentials}</p>
            </div>
            
            <p class="text-gray-300 text-sm mb-6">
              {member.bio}
            </p>
            
            <div class="flex justify-center space-x-4">
              <a href="#" class={`w-8 h-8 bg-white/10 hover:bg-${member.color}-500/20 rounded-full flex items-center justify-center transition-colors duration-200`}>
                <svg class={`w-4 h-4 text-gray-400 hover:text-${member.color}-400`} fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.338 16.338H13.67V12.16c0-.995-.017-2.277-1.387-2.277-1.39 0-1.601 1.086-1.601 2.207v4.248H8.014v-8.59h2.559v1.174h.037c.356-.675 1.227-1.387 2.526-1.387 2.703 0 3.203 1.778 3.203 4.092v4.711zM5.005 6.575a1.548 1.548 0 11-.003-3.096 1.548 1.548 0 01.003 3.096zm-1.337 9.763H6.34v-8.59H3.667v8.59zM17.668 1H2.328C1.595 1 1 1.581 1 2.298v15.403C1 18.418 1.595 19 2.328 19h15.34c.734 0 1.332-.582 1.332-1.299V2.298C19 1.581 18.402 1 17.668 1z" clip-rule="evenodd"></path>
                </svg>
              </a>
              <a href="#" class={`w-8 h-8 bg-white/10 hover:bg-${member.color}-500/20 rounded-full flex items-center justify-center transition-colors duration-200`}>
                <svg class={`w-4 h-4 text-gray-400 hover:text-${member.color}-400`} fill="currentColor" viewBox="0 0 20 20">
                  <path d="M6.29 18.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0020 3.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.073 4.073 0 01.8 7.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 010 16.407a11.616 11.616 0 006.29 1.84"></path>
                </svg>
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </ContentSection>

  <!-- Team Members -->
  <ContentSection diagonal={true}>
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold mb-4">
        <span class="bg-gradient-to-r from-purple-400 to-pink-400 bg-clip-text text-transparent">
          Our Team
        </span>
      </h2>
      <p class="text-xl text-gray-300">
        Talented professionals across product, engineering, research, and clinical teams
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {team.map((member) => (
        <div class="bg-black/40 backdrop-blur-xl border border-white/10 rounded-xl p-6 hover:border-purple-500/30 transition-all duration-300">
          <div class="flex items-center gap-4">
            <div class="w-16 h-16 bg-gradient-to-r from-purple-500 to-pink-500 rounded-full flex items-center justify-center text-white text-lg font-bold">
              {member.initials}
            </div>
            <div>
              <h3 class="text-lg font-bold text-white">{member.name}</h3>
              <p class="text-purple-400 text-sm font-medium">{member.role}</p>
              <p class="text-gray-400 text-xs">{member.department}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </ContentSection>

  <!-- Join Us CTA -->
  <ContentSection>
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-4xl font-bold mb-6">
        <span class="bg-gradient-to-r from-emerald-400 to-cyan-400 bg-clip-text text-transparent">
          Join Our Mission
        </span>
      </h2>
      <p class="text-xl text-gray-300 mb-8">
        We're always looking for talented individuals who share our passion for transforming mental health training through technology.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a 
          href="/careers"
          class="inline-flex items-center justify-center px-8 py-4 bg-gradient-to-r from-emerald-500 to-cyan-500 hover:from-emerald-600 hover:to-cyan-600 text-black font-bold rounded-lg transition-all duration-200 transform hover:scale-105"
        >
          View Open Positions
        </a>
        <a 
          href="/contact"
          class="inline-flex items-center justify-center px-8 py-4 bg-white/10 hover:bg-white/20 border border-white/20 rounded-lg text-white font-medium transition-all duration-200"
        >
          Get in Touch
        </a>
      </div>
    </div>
  </ContentSection>
</Layout>
