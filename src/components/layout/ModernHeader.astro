---
// Modern Enterprise Header with Gemini Theme
---

<header class="site-header fixed top-0 left-0 right-0 z-50 backdrop-blur-xl">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <!-- Logo/Brand -->
      <div class="flex items-center">
        <a href="/" class="flex items-center space-x-2 group">
          <div class="logo-icon w-8 h-8 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <span class="text-xl font-bold">
            Pixelated Empathy
          </span>
        </a>
      </div>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center space-x-8">
        <a href="/" class="nav-link px-3 py-2 rounded-md text-sm font-medium transition-colors">Home</a>
        <a href="/about" class="nav-link px-3 py-2 rounded-md text-sm font-medium transition-colors">About</a>
        <a href="/pricing" class="nav-link px-3 py-2 rounded-md text-sm font-medium transition-colors">Pricing</a>
        <a href="/contact" class="nav-link px-3 py-2 rounded-md text-sm font-medium transition-colors">Contact</a>
      </nav>

      <!-- CTA Buttons -->
      <div class="hidden md:flex items-center space-x-4">
        <a href="/login" class="nav-link px-3 py-2 rounded-md text-sm font-medium transition-colors">Sign In</a>
        <a href="/demo" class="btn btn-primary">Get Demo</a>
      </div>

      <!-- Mobile menu button -->
      <div class="md:hidden">
        <button 
          type="button" 
          id="mobile-menu-button"
          class="p-2 rounded-md transition-colors"
          aria-controls="mobile-menu" 
          aria-expanded="false"
        >
          <span class="sr-only">Open main menu</span>
          <svg class="block h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div class="md:hidden hidden" id="mobile-menu">
    <div class="mobile-menu-container">
      <div class="px-2 pt-2 pb-3 space-y-1">
        <a href="/" class="block px-3 py-2 rounded-md text-base font-medium transition-colors">Home</a>
        <a href="/about" class="block px-3 py-2 rounded-md text-base font-medium transition-colors">About</a>
        <a href="/pricing" class="block px-3 py-2 rounded-md text-base font-medium transition-colors">Pricing</a>
        <a href="/contact" class="block px-3 py-2 rounded-md text-base font-medium transition-colors">Contact</a>
        <div class="border-t pt-4 pb-3">
          <a href="/login" class="block px-3 py-2 rounded-md text-base font-medium transition-colors">Sign In</a>
          <a href="/demo" class="btn btn-primary mt-2">Get Demo</a>
        </div>
      </div>
    </div>
  </div>
</header>

<style>
  .site-header {
    background-color: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
  }
  .logo-icon {
    background-color: var(--color-primary);
  }
  .logo-icon svg, .site-header, .site-header span {
    color: var(--color-text-primary);
  }
  .nav-link, #mobile-menu-button, #mobile-menu a {
    color: var(--color-text-secondary);
  }
  .nav-link:hover, #mobile-menu-button:hover, #mobile-menu a:hover {
    color: var(--color-text-primary);
  }
  .mobile-menu-container {
    border-top: 1px solid var(--color-border);
    background-color: var(--color-surface);
  }
  #mobile-menu .border-t {
    border-color: var(--color-border);
  }
</style>

<script>
  // Mobile menu toggle
  const button = document.getElementById('mobile-menu-button');
  const menu = document.getElementById('mobile-menu');
  
  if (button && menu) {
    button.addEventListener('click', () => {
      const isExpanded = button.getAttribute('aria-expanded') === 'true';
      button.setAttribute('aria-expanded', (!isExpanded).toString());
      menu.classList.toggle('hidden');
    });
  }
</script>