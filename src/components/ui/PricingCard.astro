---
import Button from './Button.astro'

interface Props {
  name: string
  price: string
  period?: string
  description: string
  features: string[]
  cta: string
  ctaHref: string
  popular?: boolean
  variant?: 'default' | 'highlighted'
}

const { 
  name, 
  price, 
  period = '/month', 
  description, 
  features, 
  cta, 
  ctaHref,
  popular = false,
  variant = 'default'
} = Astro.props

const isHighlighted = variant === 'highlighted' || popular
---

<div class={`relative bg-black/40 backdrop-blur-xl border rounded-2xl p-8 transition-all duration-300 h-full flex flex-col ${isHighlighted ? 'border-emerald-500/50 shadow-2xl shadow-emerald-500/20 scale-105' : 'border-white/10 hover:border-white/20'}`}>
  {popular && (
    <div class="absolute -top-4 left-1/2 -translate-x-1/2">
      <span class="px-4 py-1 bg-gradient-to-r from-emerald-500 to-cyan-500 text-white text-sm font-semibold rounded-full">
        Most Popular
      </span>
    </div>
  )}
  
  <div class="mb-6">
    <h3 class="text-2xl font-bold text-white mb-2">{name}</h3>
    <p class="text-gray-400 text-sm">{description}</p>
  </div>
  
  <div class="mb-8">
    <div class="flex items-baseline gap-2">
      <span class="text-5xl font-bold text-white">{price}</span>
      {period && <span class="text-gray-400">{period}</span>}
    </div>
  </div>
  
  <ul class="space-y-4 mb-8 flex-1">
    {features.map((feature) => (
      <li class="flex items-start gap-3">
        <svg class="w-5 h-5 text-emerald-400 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
        </svg>
        <span class="text-gray-300">{feature}</span>
      </li>
    ))}
  </ul>
  
  <Button 
    href={ctaHref}
    variant={isHighlighted ? 'default' : 'outline'}
    size="lg"
    class={`w-full ${isHighlighted ? 'bg-gradient-to-r from-emerald-500 to-cyan-500' : ''}`}
  >
    {cta}
  </Button>
</div>
