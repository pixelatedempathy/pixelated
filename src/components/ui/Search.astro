---
const pages = [
  { title: 'Home', url: '/', description: 'AI Training Platform for Mental Health' },
  { title: 'Features', url: '/features', description: 'Platform capabilities and features' },
  { title: 'Pricing', url: '/pricing', description: 'Plans and pricing options' },
  { title: 'Demos', url: '/demos', description: 'Interactive product demonstrations' },
  { title: 'Team', url: '/team', description: 'Meet our team' },
  { title: 'Case Studies', url: '/case-studies', description: 'Success stories' },
  { title: 'Blog', url: '/blog', description: 'Latest insights and updates' },
  { title: 'Careers', url: '/careers', description: 'Join our team' },
  { title: 'Contact', url: '/contact', description: 'Get in touch' },
  { title: 'Support', url: '/support', description: 'Help and support' },
  { title: 'Documentation', url: '/docs', description: 'Technical documentation' },
]
---

<div class="search-container">
  <button
    data-search-trigger
    class="flex items-center gap-2 px-3 py-2 bg-white/5 border border-white/10 rounded-lg text-gray-400 hover:text-white hover:border-white/20 transition-all"
    aria-label="Search"
  >
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
    </svg>
    <span class="text-sm">Search</span>
    <kbd class="hidden sm:inline-block px-2 py-0.5 text-xs bg-white/10 rounded">⌘K</kbd>
  </button>

  <div data-search-modal class="hidden fixed inset-0 z-50 bg-black/80 backdrop-blur-sm">
    <div class="container mx-auto px-6 py-20">
      <div class="max-w-2xl mx-auto bg-gray-900 rounded-xl border border-white/10 shadow-2xl">
        <div class="p-4 border-b border-white/10">
          <input
            data-search-input
            type="text"
            placeholder="Search pages..."
            class="w-full bg-transparent text-white placeholder-gray-500 focus:outline-none"
          />
        </div>
        <div data-search-results class="max-h-96 overflow-y-auto p-2">
          {pages.map(page => (
            <a
              href={page.url}
              class="search-result block p-3 rounded-lg hover:bg-white/5 transition-colors"
              data-title={page.title.toLowerCase()}
              data-description={page.description.toLowerCase()}
            >
              <div class="font-medium text-white">{page.title}</div>
              <div class="text-sm text-gray-400">{page.description}</div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const trigger = document.querySelector('[data-search-trigger]')
  const modal = document.querySelector('[data-search-modal]')
  const input = document.querySelector('[data-search-input]') as HTMLInputElement
  const results = document.querySelector('[data-search-results]')

  trigger?.addEventListener('click', () => {
    modal?.classList.remove('hidden')
    input?.focus()
  })

  modal?.addEventListener('click', (e) => {
    if (e.target === modal) modal.classList.add('hidden')
  })

  // Keyboard shortcut
  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault()
      modal?.classList.remove('hidden')
      input?.focus()
    }
    if (e.key === 'Escape') {
      modal?.classList.add('hidden')
    }
  })

  // Search filter
  input?.addEventListener('input', (e) => {
    const query = (e.target as HTMLInputElement).value.toLowerCase()
    const items = results?.querySelectorAll('.search-result')
    
    items?.forEach(item => {
      const title = item.getAttribute('data-title') || ''
      const desc = item.getAttribute('data-description') || ''
      const matches = title.includes(query) || desc.includes(query)
      ;(item as HTMLElement).style.display = matches ? 'block' : 'none'
    })
  })
</script>
