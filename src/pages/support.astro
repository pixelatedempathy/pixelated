---
export const prerender = true

import Layout from '@/layouts/Layout.astro'
import PageHero from '@/components/ui/PageHero.astro'
import ContentSection from '@/components/ui/ContentSection.astro'
import FormInput from '@/components/ui/FormInput.astro'
import FormTextarea from '@/components/ui/FormTextarea.astro'
import FormSelect from '@/components/ui/FormSelect.astro'

const faqs = [
  {
    question: "How do I get started with the platform?",
    answer: "After signing up, you'll receive access to our onboarding guide and training materials. Our customer success team will also schedule a welcome call to help you get started."
  },
  {
    question: "What technical requirements are needed?",
    answer: "The platform runs in modern web browsers and requires a stable internet connection. We recommend Chrome, Firefox, Safari, or Edge for the best experience."
  },
  {
    question: "How is patient data protected?",
    answer: "We maintain HIPAA compliance with end-to-end encryption, secure data centers, and regular security audits. All data is encrypted both in transit and at rest."
  },
  {
    question: "Can I integrate with existing systems?",
    answer: "Yes, we offer API integrations and can work with your IT team to connect with existing EMR systems and training platforms."
  },
  {
    question: "What support is available?",
    answer: "We provide 24/7 technical support, comprehensive documentation, video tutorials, and dedicated customer success managers for enterprise clients."
  },
  {
    question: "How do I report a bug or issue?",
    answer: "Use the support ticket form below or email support@pixelatedempathy.com. Include details about the issue and steps to reproduce it."
  }
]

const contactOptions = [
  {
    icon: "📧",
    title: "Email Support",
    description: "support@pixelatedempathy.com",
    link: "mailto:support@pixelatedempathy.com"
  },
  {
    icon: "💬",
    title: "Live Chat",
    description: "Available 24/7",
    link: "#"
  },
  {
    icon: "📚",
    title: "Documentation",
    description: "Browse our guides",
    link: "/docs"
  }
]
---

<Layout title="Support - Pixelated Empathy">
  <PageHero
    badge="24/7 Support"
    title="How Can We Help?"
    subtitle="Get the support you need to make the most of our platform. Browse our FAQ or submit a support ticket."
    gradient={true}
  />

  <!-- FAQ Section -->
  <ContentSection>
    <h2 class="text-4xl font-bold text-center mb-12">
      <span class="bg-gradient-to-r from-emerald-400 to-cyan-400 bg-clip-text text-transparent">
        Frequently Asked Questions
      </span>
    </h2>
    
    <div class="space-y-4 max-w-4xl mx-auto">
      {faqs.map((faq, index) => (
        <div class="bg-black/40 backdrop-blur-xl border border-white/10 rounded-xl overflow-hidden hover:border-emerald-500/30 transition-all duration-300">
          <button 
            class="faq-toggle w-full px-6 py-4 text-left flex items-center justify-between hover:bg-white/5 transition-colors"
            data-target={`faq-${index}`}
          >
            <h3 class="text-lg font-semibold text-white pr-4">{faq.question}</h3>
            <svg class="w-5 h-5 text-gray-400 transform transition-transform faq-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div id={`faq-${index}`} class="faq-content hidden px-6 pb-4">
            <p class="text-gray-300 leading-relaxed">{faq.answer}</p>
          </div>
        </div>
      ))}
    </div>
  </ContentSection>

  <!-- Support Ticket Form -->
  <ContentSection diagonal={true}>
    <div class="max-w-2xl mx-auto">
      <h2 class="text-4xl font-bold text-center mb-12">
        <span class="bg-gradient-to-r from-purple-400 to-pink-400 bg-clip-text text-transparent">
          Submit Support Ticket
        </span>
      </h2>
      
      <div class="bg-black/40 backdrop-blur-xl border border-white/10 rounded-2xl p-8">
        <form id="support-form" class="space-y-6">
          <FormInput
            label="Name"
            name="name"
            type="text"
            placeholder="Your name"
            required={true}
          />
          
          <FormInput
            label="Email"
            name="email"
            type="email"
            placeholder="your@email.com"
            required={true}
          />
          
          <FormSelect
            label="Issue Type"
            name="issue-type"
            options={[
              { value: "", label: "Select issue type" },
              { value: "technical", label: "Technical Issue" },
              { value: "billing", label: "Billing Question" },
              { value: "feature", label: "Feature Request" },
              { value: "other", label: "Other" }
            ]}
            required={true}
          />
          
          <FormTextarea
            label="Description"
            name="description"
            placeholder="Please describe your issue in detail..."
            rows={6}
            required={true}
          />
          
          <button 
            type="submit"
            class="w-full py-3 px-6 bg-gradient-to-r from-emerald-500 to-cyan-500 hover:from-emerald-600 hover:to-cyan-600 text-black font-bold rounded-lg transition-all duration-200 transform hover:scale-105"
          >
            Submit Ticket
          </button>
        </form>
      </div>
    </div>
  </ContentSection>

  <!-- Contact Options -->
  <ContentSection>
    <h2 class="text-4xl font-bold text-center mb-12">
      <span class="bg-gradient-to-r from-emerald-400 to-cyan-400 bg-clip-text text-transparent">
        Other Ways to Reach Us
      </span>
    </h2>
    
    <div class="grid md:grid-cols-3 gap-6 max-w-4xl mx-auto">
      {contactOptions.map((option) => (
        <a 
          href={option.link}
          class="bg-black/40 backdrop-blur-xl border border-white/10 rounded-xl p-6 hover:border-emerald-500/30 transition-all duration-300 text-center"
        >
          <div class="text-4xl mb-4">{option.icon}</div>
          <h3 class="text-xl font-bold text-white mb-2">{option.title}</h3>
          <p class="text-gray-300">{option.description}</p>
        </a>
      ))}
    </div>
  </ContentSection>
</Layout>

<script>
  document.querySelectorAll('.faq-toggle').forEach(button => {
    button.addEventListener('click', () => {
      const targetId = button.getAttribute('data-target')
      const content = document.getElementById(targetId)
      const icon = button.querySelector('.faq-icon')
      
      if (content && icon) {
        content.classList.toggle('hidden')
        icon.classList.toggle('rotate-180')
      }
    })
  })
</script>
