---
interface Props {
  variant?: 'spinner' | 'skeleton' | 'dots'
  size?: 'sm' | 'md' | 'lg'
  text?: string
}

const { variant = 'spinner', size = 'md', text } = Astro.props

const sizeClasses = {
  sm: 'w-4 h-4',
  md: 'w-8 h-8',
  lg: 'w-12 h-12'
}
---

{variant === 'spinner' && (
  <div class="flex flex-col items-center justify-center gap-3">
    <div class={`${sizeClasses[size]} border-2 border-emerald-500/30 border-t-emerald-500 rounded-full animate-spin`}></div>
    {text && <p class="text-gray-400 text-sm">{text}</p>}
  </div>
)}

{variant === 'dots' && (
  <div class="flex items-center gap-2">
    <div class="w-2 h-2 bg-emerald-500 rounded-full animate-bounce" style="animation-delay: 0ms"></div>
    <div class="w-2 h-2 bg-emerald-500 rounded-full animate-bounce" style="animation-delay: 150ms"></div>
    <div class="w-2 h-2 bg-emerald-500 rounded-full animate-bounce" style="animation-delay: 300ms"></div>
  </div>
)}

{variant === 'skeleton' && (
  <div class="animate-pulse space-y-3">
    <div class="h-4 bg-white/10 rounded w-3/4"></div>
    <div class="h-4 bg-white/10 rounded w-1/2"></div>
    <div class="h-4 bg-white/10 rounded w-5/6"></div>
  </div>
)}
