          <li><a href="/demo-hub" class="text-secondary hover:text-primary transition-colors text-sm">Demos</a></li>
          <li><a href="/pricing" class="text-secondary hover:text-primary transition-colors text-sm">Pricing</a></li>
          <li><a href="/enterprise" class="text-secondary hover:text-primary transition-colors text-sm">Enterprise</a></li>
        </ul>
      </div>

      <!-- Resources Column -->
      <div>
        <h3 class="font-semibold text-primary mb-4">Resources</h3>
        <ul class="space-y-3">
          <li><a href="/docs" class="text-secondary hover:text-primary transition-colors text-sm">Documentation</a></li>
          <li><a href="/blog" class="text-secondary hover:text-primary transition-colors text-sm">Blog</a></li>
          <li><a href="/support" class="text-secondary hover:text-primary transition-colors text-sm">Support</a></li>
          <li><a href="/status" class="text-secondary hover:text-primary transition-colors text-sm">Status</a></li>
        </ul>
      </div>

      <!-- Company Column -->
      <div>
        <h3 class="font-semibold text-primary mb-4">Company</h3>
        <ul class="space-y-3">
          <li><a href="/about" class="text-secondary hover:text-primary transition-colors text-sm">About</a></li>
          <li><a href="/contact" class="text-secondary hover:text-primary transition-colors text-sm">Contact</a></li>
          <li><a href="/careers" class="text-secondary hover:text-primary transition-colors text-sm">Careers</a></li>
          <li><a href="/privacy" class="text-secondary hover:text-primary transition-colors text-sm">Privacy</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom Section -->
    <div class="border-t border-primary mt-12 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <div class="flex items-center gap-4">
        <p class="text-sm text-secondary">
          © 2025 Pixelated Empathy. All rights reserved.
        </p>
        <div class="flex items-center gap-2">
          <div class="w-2 h-2 rounded-full bg-emerald-400"></div>
          <span class="text-xs text-secondary font-medium">ALL SYSTEMS OPERATIONAL</span>
        </div>
      </div>
      
      <div class="flex items-center gap-6 text-sm">
        <a href="/terms" class="text-secondary hover:text-primary transition-colors">Terms</a>
        <a href="/privacy" class="text-secondary hover:text-primary transition-colors">Privacy</a>
        <a href="/cookies" class="text-secondary hover:text-primary transition-colors">Cookies</a>
