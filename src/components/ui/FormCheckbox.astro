---
interface Props {
  label: string
  name: string
  required?: boolean
  checked?: boolean
  error?: string
  helperText?: string
  labelPosition?: 'right' | 'left'
}

const { 
  label, 
  name, 
  required = false,
  checked = false,
  error,
  helperText,
  labelPosition = 'right'
} = Astro.props

const hasError = !!error
---

<div class="form-checkbox-group">
  <label class={`flex items-start gap-3 cursor-pointer group ${labelPosition === 'left' ? 'flex-row-reverse justify-end' : ''}`}>
    <div class="relative flex items-center">
      <input
        type="checkbox"
        id={name}
        name={name}
        required={required}
        checked={checked}
        class="peer sr-only"
      />
      <div class={`w-5 h-5 border-2 rounded transition-all duration-200 flex items-center justify-center peer-checked:bg-gradient-to-br peer-checked:from-emerald-500 peer-checked:to-cyan-500 peer-checked:border-transparent peer-focus:ring-2 peer-focus:ring-emerald-500 peer-focus:ring-offset-2 peer-focus:ring-offset-black ${hasError ? 'border-red-500/50' : 'border-white/30'}`}>
        <svg class="w-3 h-3 text-white opacity-0 peer-checked:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
        </svg>
      </div>
    </div>
    
    <div class="flex-1">
      <span class={`text-sm ${hasError ? 'text-red-400' : 'text-gray-300'} group-hover:text-white transition-colors`}>
        {label}
        {required && <span class="text-red-400 ml-1">*</span>}
      </span>
      
      {helperText && !error && (
        <p class="mt-1 text-xs text-gray-500">{helperText}</p>
      )}
      
      {error && (
        <p class="mt-1 text-xs text-red-400 flex items-center gap-1">
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
          </svg>
          {error}
        </p>
      )}
    </div>
  </label>
</div>

<style>
  /* Custom checkbox styling with peer selector */
  input[type="checkbox"]:checked + div {
    background: linear-gradient(to bottom right, #10b981, #06b6d4);
  }
</style>
