---
// Mizu-inspired Two-Pane Hero Section with AntfuStyle refinements
---

<section class="mizu-hero">
  <!-- AntfuStyle-inspired subtle background pattern -->
  <div class="mizu-hero-bg-pattern" aria-hidden="true"></div>
  
  <div class="mizu-hero-container">
    <!-- Left Pane - Content -->
    <div class="mizu-hero-left">
      <header class="mizu-hero-header">
        <div class="mizu-hero-badge">
          <svg width="12" height="12" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path>
          </svg>
          <span>Next-Generation AI Training</span>
        </div>

        <h1 class="mizu-hero-title">
          <span class="mizu-hero-title-text">Transform Mental Health<br />Training with<br /><span class="mizu-hero-title-gradient">AI Simulation</span></span>
          <div class="mizu-decoration-border mizu-decoration-border--dashed">
            <span class="mizu-decoration-border__top"></span>
            <span class="mizu-decoration-border__bottom"></span>
          </div>
        </h1>

        <p class="mizu-hero-subtitle">build for the future</p>
      </header>

      <div class="mizu-hero-content">
        <p class="mizu-hero-description">
          Let AI handle the heavy lifting — from data insights to launch strategies — 
          so you can focus on creating products that customers love.
        </p>
        <div class="mizu-hero-cta">
          <a href="/demo-hub" class="mizu-btn mizu-btn-primary">
            Start Training
            <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
            </svg>
          </a>
          <a href="/features" class="mizu-btn mizu-btn-secondary">
            Learn More
          </a>
        </div>
      </div>
    </div>

    <!-- Right Pane - Visual -->
    <div class="mizu-hero-right">
      <!-- Visual content area with AntfuStyle-inspired dot pattern -->
      <div class="mizu-hero-visual">
        <div class="mizu-hero-visual-content">
          <!-- Subtle dot pattern overlay -->
          <div class="mizu-hero-dot-pattern" aria-hidden="true"></div>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Decorative borders around entire section -->
  <div class="mizu-decoration-border mizu-decoration-border--solid">
    <span class="mizu-decoration-border__top"></span>
    <span class="mizu-decoration-border__right"></span>
    <span class="mizu-decoration-border__bottom"></span>
    <span class="mizu-decoration-border__left"></span>
  </div>
</section>

<!-- Section Spacer with Decorative Borders -->
<div class="mizu-section-spacer">
  <div class="mizu-section-spacer-inner">
    <div class="mizu-decoration-border mizu-decoration-border--dashed">
      <span class="mizu-decoration-border__left"></span>
      <span class="mizu-decoration-border__right"></span>
    </div>
  </div>
</div>
