---
import Layout from '../layouts/Layout.astro'
---

<Layout title="Clinical Analysis Demo - Pixelated Empathy">
  <main class="min-h-screen bg-black text-white pt-24 pb-16">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-12">
        <h1 class="text-4xl font-bold mb-4">
          <span class="bg-gradient-to-r from-purple-400 to-pink-400 bg-clip-text text-transparent">
            Clinical Analysis Demo
          </span>
        </h1>
        <p class="text-xl text-gray-300">
          Advanced trauma response and clinical formulation training
        </p>
      </div>
      
      <div id="clinical-demo-container"></div>
    </div>
  </main>
</Layout>

<script>
  import ClinicalAnalysisDemo from '../components/demo/ClinicalAnalysisDemo'
  import { createRoot } from 'react-dom/client'
  import { createElement } from 'react'

  const container = document.getElementById('clinical-demo-container')
  if (container) {
    const root = createRoot(container)
    root.render(createElement(ClinicalAnalysisDemo))
  }
</script>
