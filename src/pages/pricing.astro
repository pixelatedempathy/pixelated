---
export const prerender = true

import Layout from '../layouts/Layout.astro'
import PageHero from '../components/ui/PageHero.astro'
import ContentSection from '../components/ui/ContentSection.astro'
import PricingCard from '../components/ui/PricingCard.astro'

const pricingPlans = [
  {
    name: 'Free Trial',
    price: '$0',
    period: '14 days',
    description: 'Perfect for exploring the platform',
    features: [
      'Access to 50+ training scenarios',
      'Basic AI feedback',
      'Performance analytics',
      'Email support',
      'Single user account'
    ],
    cta: 'Start Free Trial',
    ctaHref: '/get-started'
  },
  {
    name: 'Professional',
    price: '$--',
    period: '/month',
    description: 'For individual practitioners',
    features: [
      'Unlimited training scenarios',
      'Advanced AI feedback',
      'Detailed analytics & reports',
      'Priority email support',
      'Custom scenario creation',
      'Progress tracking',
      'Certificate of completion'
    ],
    cta: 'Start Professional',
    ctaHref: '/get-started?plan=professional',
    popular: true
  },
  {
    name: 'Enterprise',
    price: 'Custom',
    period: '',
    description: 'For organizations and institutions',
    features: [
      'Everything in Professional',
      'Unlimited team members',
      'Custom AI training models',
      'Dedicated account manager',
      'SSO & advanced security',
      'API access',
      'Custom integrations',
      'SLA guarantee'
    ],
    cta: 'Contact Sales',
    ctaHref: '/contact'
  }
]
---

<Layout title="Pricing - Pixelated Empathy">
  <PageHero
    badge="Pricing Plans"
    title="Simple, Transparent Pricing"
    subtitle="Choose the plan that fits your training needs. All plans include our core AI training platform."
    gradient={true}
  />
  
  <ContentSection>
    <div class="text-center mb-12">
      <div class="inline-flex items-center gap-2 px-4 py-2 bg-emerald-500/10 border border-emerald-500/20 rounded-full text-emerald-400 text-sm font-mono">
        <div class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></div>
        14-day free trial • No credit card required
      </div>
    </div>
    
    <div class="grid lg:grid-cols-3 gap-8 max-w-7xl mx-auto">
      {pricingPlans.map((plan) => (
        <PricingCard {...plan} />
      ))}
    </div>
  </ContentSection>

  <!-- FAQ Section -->
  <ContentSection diagonal={true}>
    <h2 class="text-4xl font-bold text-center mb-16">
      <span class="bg-gradient-to-r from-emerald-400 to-cyan-400 bg-clip-text text-transparent">
        Frequently Asked Questions
      </span>
    </h2>
    
    <div class="space-y-6 max-w-4xl mx-auto">
      <div class="bg-black/40 backdrop-blur-xl border border-white/10 rounded-xl p-6 hover:border-emerald-500/30 transition-all duration-300">
        <h3 class="text-xl font-bold text-white mb-3">What's included in the free trial?</h3>
        <p class="text-gray-300">
          The 14-day free trial includes access to 50+ AI training scenarios, basic progress tracking, and email support. No credit card required to start.
        </p>
      </div>
      
      <div class="bg-black/40 backdrop-blur-xl border border-white/10 rounded-xl p-6 hover:border-emerald-500/30 transition-all duration-300">
        <h3 class="text-xl font-bold text-white mb-3">Can I upgrade or downgrade my plan?</h3>
        <p class="text-gray-300">
          Yes, you can change your plan at any time. Upgrades take effect immediately, and downgrades take effect at the next billing cycle.
        </p>
      </div>
      
      <div class="bg-black/40 backdrop-blur-xl border border-white/10 rounded-xl p-6 hover:border-emerald-500/30 transition-all duration-300">
        <h3 class="text-xl font-bold text-white mb-3">Is my data secure and HIPAA compliant?</h3>
        <p class="text-gray-300">
          Absolutely. We use enterprise-grade encryption and are fully HIPAA compliant. All training data is anonymized and encrypted both in transit and at rest.
        </p>
      </div>
      
      <div class="bg-black/40 backdrop-blur-xl border border-white/10 rounded-xl p-6 hover:border-emerald-500/30 transition-all duration-300">
        <h3 class="text-xl font-bold text-white mb-3">Do you offer training and onboarding?</h3>
        <p class="text-gray-300">
          Professional plans include priority support and training resources. Enterprise customers get dedicated onboarding and a success manager.
        </p>
      </div>
      
      <div class="bg-black/40 backdrop-blur-xl border border-white/10 rounded-xl p-6 hover:border-emerald-500/30 transition-all duration-300">
        <h3 class="text-xl font-bold text-white mb-3">What payment methods do you accept?</h3>
        <p class="text-gray-300">
          We accept all major credit cards, ACH transfers, and can accommodate purchase orders for Enterprise customers.
        </p>
      </div>
    </div>
  </ContentSection>

  <!-- CTA Section -->
  <ContentSection>
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-4xl font-bold mb-6">
        <span class="bg-gradient-to-r from-emerald-400 to-cyan-400 bg-clip-text text-transparent">
          Ready to Transform Your Training?
        </span>
      </h2>
      <p class="text-xl text-gray-300 mb-8">
        Join mental health professionals who trust Pixelated Empathy for their training needs.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a 
          href="/get-started"
          class="inline-flex items-center justify-center px-8 py-4 bg-gradient-to-r from-emerald-500 to-cyan-500 hover:from-emerald-600 hover:to-cyan-600 text-black font-bold rounded-lg transition-all duration-200 transform hover:scale-105"
        >
          Start Free Trial
        </a>
        <a 
          href="/demos"
          class="inline-flex items-center justify-center px-8 py-4 bg-white/10 hover:bg-white/20 border border-white/20 rounded-lg text-white font-medium transition-all duration-200"
        >
          Schedule Demo
        </a>
      </div>
    </div>
  </ContentSection>
</Layout>
