---
import Layout from '@/layouts/Layout.astro'

const services = [
  {
    name: "API Gateway",
    status: "operational",
    description: "Core API endpoints and authentication"
  },
  {
    name: "Training Engine",
    status: "operational", 
    description: "AI simulation and training modules"
  },
  {
    name: "Database",
    status: "operational",
    description: "User data and session storage"
  },
  {
    name: "File Storage",
    status: "operational",
    description: "Training materials and media files"
  },
  {
    name: "Analytics",
    status: "operational",
    description: "Performance tracking and reporting"
  }
]

const incidents = [
  // No recent incidents to display
]
---

<Layout title="System Status - Pixelated Empathy">
  <main class="min-h-screen bg-gradient-to-br from-gray-900 via-black to-gray-900">
    <div class="container mx-auto px-6 py-24 relative z-10">
      <!-- Header -->
      <div class="text-center mb-16">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-green-500/10 border border-green-500/20 rounded-full text-green-400 text-sm font-mono mb-6">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
          </span>
          All Systems Operational
        </div>
        <h1 class="text-5xl font-bold text-white mb-6">System Status</h1>
        <p class="text-xl text-gray-300 max-w-3xl mx-auto">
          Real-time status of our platform services and infrastructure.
        </p>
      </div>

      <!-- Overall Status -->
      <div class="mb-12">
        <div class="bg-black/40 backdrop-blur-xl border border-white/10 rounded-2xl p-8">
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-2xl font-bold text-white">Platform Status</h2>
            <div class="flex items-center gap-2 px-4 py-2 bg-green-500/20 border border-green-500/30 rounded-full">
              <div class="w-3 h-3 bg-green-500 rounded-full"></div>
              <span class="text-green-400 font-medium">Operational</span>
            </div>
          </div>
          <div class="grid md:grid-cols-3 gap-6">
            <div class="text-center">
              <div class="text-3xl font-bold text-green-400 mb-2">--</div>
              <div class="text-sm text-gray-400">30-day Uptime</div>
            </div>
            <div class="text-center">
              <div class="text-3xl font-bold text-white mb-2">--</div>
              <div class="text-sm text-gray-400">Avg Response Time</div>
            </div>
            <div class="text-center">
              <div class="text-3xl font-bold text-white mb-2">0</div>
              <div class="text-sm text-gray-400">Active Incidents</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Service Status -->
      <div class="mb-12">
        <h2 class="text-3xl font-bold text-white mb-8">Service Status</h2>
        <div class="space-y-4">
          {services.map((service) => (
            <div class="bg-black/40 backdrop-blur-xl border border-white/10 rounded-2xl p-6">
              <div class="flex items-center justify-between">
                <div class="flex-1">
                  <div class="flex items-center gap-4 mb-2">
                    <div class={`w-3 h-3 rounded-full ${
                      service.status === 'operational' ? 'bg-green-500' :
                      service.status === 'degraded' ? 'bg-yellow-500' : 'bg-red-500'
                    }`}></div>
                    <h3 class="text-xl font-semibold text-white">{service.name}</h3>
                    <span class={`px-3 py-1 rounded-full text-sm font-medium ${
                      service.status === 'operational' ? 'bg-green-500/20 text-green-400 border border-green-500/30' :
                      service.status === 'degraded' ? 'bg-yellow-500/20 text-yellow-400 border border-yellow-500/30' :
                      'bg-red-500/20 text-red-400 border border-red-500/30'
                    }`}>
                      {service.status === 'operational' ? 'Operational' :
                       service.status === 'degraded' ? 'Degraded' : 'Down'}
                    </span>
                  </div>
                  <p class="text-gray-400 text-sm mb-2">{service.description}</p>
                </div>
                <div class="text-right">
                  <div class="text-lg font-bold text-white">--</div>
                  <div class="text-sm text-gray-400">Uptime</div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Incident History -->
      <div class="mb-12">
        <h2 class="text-3xl font-bold text-white mb-8">Recent Incidents</h2>
        {incidents.length > 0 ? (
          <div class="space-y-4">
            {incidents.map((incident) => (
              <div class="bg-black/40 backdrop-blur-xl border border-white/10 rounded-2xl p-6">
                <div class="flex items-start justify-between mb-4">
                  <div class="flex-1">
                    <div class="flex items-center gap-4 mb-2">
                      <div class="w-3 h-3 bg-gray-500 rounded-full"></div>
                      <h3 class="text-lg font-semibold text-white">{incident.title}</h3>
                      <span class="px-3 py-1 bg-gray-500/20 text-gray-400 border border-gray-500/30 rounded-full text-sm font-medium">
                        Resolved
                      </span>
                    </div>
                    <p class="text-gray-300 mb-2">{incident.description}</p>
                  </div>
                  <div class="text-right text-sm text-gray-400">
                    <div>{incident.date}</div>
                    <div>Duration: {incident.duration}</div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        ) : (
          <div class="bg-black/40 backdrop-blur-xl border border-white/10 rounded-2xl p-8 text-center">
            <div class="text-gray-400">No recent incidents to report</div>
          </div>
        )}
      </div>

      <!-- Subscribe to Updates -->
      <div class="text-center">
        <div class="bg-black/40 backdrop-blur-xl border border-white/10 rounded-2xl p-8">
          <h2 class="text-2xl font-bold text-white mb-4">Stay Updated</h2>
          <p class="text-gray-300 mb-6">
            Bookmark this page to check system status anytime.
          </p>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  // Auto-refresh status every 30 seconds
  document.addEventListener('astro:page-load', () => {
    setInterval(() => {
      window.location.reload()
    }, 30000)
  })
</script>
</Layout>
