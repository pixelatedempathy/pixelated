---
// Streamline Layout - Clean, minimal, content-focused
import StreamlineNav from '@/components/layout/StreamlineNav.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: URL | string;
  noindex?: boolean;
  class?: string;
}

const {
  title = 'Pixelated Empathy - Enterprise Mental Health AI Platform',
  description = 'Clinical-grade AI platform for healthcare organizations. Deploy evidence-based mental health solutions with enterprise security and seamless integration.',
  ogImage = '/images/og-streamline.png',
  canonicalURL = new URL(Astro.url.pathname, Astro.site),
  noindex = false,
  class: className = ''
} = Astro.props;

const siteTitle = title.includes('Pixelated Empathy') ? title : `${title} | Pixelated Empathy`;
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="generator" content={Astro.generator} />
  
  <!-- Primary Meta Tags -->
  <title>{siteTitle}</title>
  <meta name="title" content={siteTitle} />
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  
  {noindex && <meta name="robots" content="noindex, nofollow" />}
  
  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={siteTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  
  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content={canonicalURL} />
  <meta property="twitter:title" content={siteTitle} />
  <meta property="twitter:description" content={description} />
  <meta property="twitter:image" content={ogImage} />
  
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  
  <!-- Streamline Design System -->
  <link rel="stylesheet" href="/src/styles/streamline-enterprise-system.css" />
  
  <!-- Theme Detection -->
  <script is:inline>
    (() => {
      try {
        const stored = localStorage.getItem("theme");
        const theme = stored ?? "dark";
        document.documentElement.setAttribute("data-theme", theme);
      } catch {}
    })();
  </script>
</head>

<body class={className}>
  <!-- Skip to main content -->
  <a href="#main-content" class="skip-link">Skip to main content</a>
  
  <!-- Navigation -->
  <StreamlineNav />
  
  <!-- Main Content -->
  <main id="main-content" class="main-content">
    <slot />
  </main>
  
  <!-- Simple footer -->
  <footer class="streamline-footer">
    <div class="container">
      <div class="footer-content">
        <div class="footer-brand">
          <div class="footer-logo">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
              <rect width="24" height="24" rx="4" fill="currentColor"/>
              <rect x="6" y="8" width="12" height="1" fill="var(--bg-primary)"/>
              <rect x="6" y="11" width="12" height="1" fill="var(--bg-primary)"/>
              <rect x="6" y="14" width="8" height="1" fill="var(--bg-primary)"/>
            </svg>
            <span>Pixelated Empathy</span>
          </div>
          <p class="footer-description">
            Enterprise mental health AI platform for healthcare organizations.
          </p>
        </div>
        
        <div class="footer-links">
          <div class="link-section">
            <h4>Platform</h4>
            <a href="/platform/ai">AI Engine</a>
            <a href="/platform/integration">Integration</a>
            <a href="/platform/analytics">Analytics</a>
            <a href="/platform/security">Security</a>
          </div>
          
          <div class="link-section">
            <h4>Solutions</h4>
            <a href="/solutions/healthcare">Healthcare</a>
            <a href="/solutions/enterprise">Enterprise</a>
            <a href="/solutions/clinical">Clinical</a>
            <a href="/solutions/telehealth">Telehealth</a>
          </div>
          
          <div class="link-section">
            <h4>Resources</h4>
            <a href="/docs">Documentation</a>
            <a href="/api">API Reference</a>
            <a href="/support">Support</a>
            <a href="/status">System Status</a>
          </div>
          
          <div class="link-section">
            <h4>Company</h4>
            <a href="/about">About</a>
            <a href="/careers">Careers</a>
            <a href="/contact">Contact</a>
            <a href="/legal">Legal</a>
          </div>
        </div>
      </div>
      
      <div class="footer-bottom">
        <p>&copy; 2024 Pixelated Empathy. All rights reserved.</p>
        <div class="footer-legal">
          <a href="/privacy">Privacy</a>
          <a href="/terms">Terms</a>
          <a href="/security">Security</a>
        </div>
      </div>
    </div>
  </footer>
  
  <!-- Minimal scripts -->
  <script>
    // Clean theme management
    const initTheme = () => {
      const saved = localStorage.getItem('theme') || 'dark';
      document.documentElement.setAttribute('data-theme', saved);
    };

    // Simple smooth scroll
    const initScroll = () => {
      document.addEventListener('click', (e) => {
        const link = e.target.closest('a[href^="#"]');
        if (link) {
          e.preventDefault();
          const target = document.querySelector(link.getAttribute('href'));
          if (target) {
            const offset = document.querySelector('.streamline-nav')?.offsetHeight || 0;
            window.scrollTo({
              top: target.offsetTop - offset - 20,
              behavior: 'smooth'
            });
          }
        }
      });
    };

    // Initialize
    document.addEventListener('DOMContentLoaded', () => {
      initTheme();
      initScroll();
    });
  </script>
</body>
</html>

<style is:global>
  /* Streamline Layout Global Styles */
  
  .skip-link {
    position: absolute;
    top: -48px;
    left: 8px;
    background: var(--accent);
    color: var(--bg-primary);
    padding: 12px 16px;
    text-decoration: none;
    border-radius: var(--radius-md);
    z-index: 10000;
    font-size: var(--text-sm);
    font-weight: 500;
    transition: top var(--transition);
  }

  .skip-link:focus {
    top: 8px;
  }

  .main-content {
    margin-top: 64px;
    min-height: calc(100vh - 128px);
  }

  /* Simple footer */
  .streamline-footer {
    background: var(--bg-secondary);
    border-top: 1px solid var(--border-primary);
    padding: var(--space-16) 0 var(--space-8);
  }

  .footer-content {
    display: grid;
    grid-template-columns: 1fr 3fr;
    gap: var(--space-16);
    margin-bottom: var(--space-12);
  }

  .footer-brand {
    max-width: 300px;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--text-primary);
    font-weight: 600;
    font-size: var(--text-lg);
    margin-bottom: var(--space-4);
  }

  .footer-description {
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .footer-links {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-8);
  }

  .link-section h4 {
    color: var(--text-primary);
    font-size: var(--text-sm);
    font-weight: 600;
    margin-bottom: var(--space-4);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .link-section a {
    display: block;
    color: var(--text-secondary);
    text-decoration: none;
    font-size: var(--text-sm);
    padding: var(--space-1) 0;
    transition: color var(--transition);
  }

  .link-section a:hover {
    color: var(--text-primary);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--space-8);
    border-top: 1px solid var(--border-primary);
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  .footer-legal {
    display: flex;
    gap: var(--space-6);
  }

  .footer-legal a {
    color: var(--text-secondary);
    text-decoration: none;
    transition: color var(--transition);
  }

  .footer-legal a:hover {
    color: var(--text-primary);
  }

  /* Responsive footer */
  @media (max-width: 1024px) {
    .footer-content {
      grid-template-columns: 1fr;
      gap: var(--space-12);
    }

    .footer-links {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .footer-links {
      grid-template-columns: 1fr;
    }

    .footer-bottom {
      flex-direction: column;
      gap: var(--space-4);
      text-align: center;
    }
  }
</style>