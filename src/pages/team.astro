---
import Layout from '../layouts/Layout.astro'
---

<Layout title="Team - Pixelated Empathy">
  <main class="min-h-screen bg-black text-white">
    <!-- Hero Section -->
    <section class="relative py-32 px-6">
      <!-- Background Elements -->
      <div class="absolute inset-0 overflow-hidden">
        <div class="absolute top-20 left-10 w-96 h-96 bg-gradient-to-r from-emerald-500/20 to-cyan-500/20 rounded-full blur-3xl"></div>
        <div class="absolute bottom-20 right-10 w-80 h-80 bg-gradient-to-r from-purple-500/20 to-pink-500/20 rounded-full blur-3xl"></div>
      </div>

      <div class="relative max-w-7xl mx-auto text-center">
        <h1 class="text-5xl lg:text-7xl font-bold mb-6">
          <span class="bg-gradient-to-r from-emerald-400 via-cyan-400 to-purple-400 bg-clip-text text-transparent">
            Meet Our Team
          </span>
        </h1>
        <p class="text-xl text-gray-300 max-w-3xl mx-auto mb-8">
          We're a passionate team of technologists, clinicians, and researchers dedicated to transforming mental health training through AI innovation.
        </p>
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-emerald-500/10 border border-emerald-500/20 rounded-full text-emerald-400 text-sm font-mono">
          <div class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></div>
          Building the future of empathetic AI
        </div>
      </div>
    </section>

    <!-- Leadership Team -->
    <section class="py-20 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold mb-4">
            <span class="bg-gradient-to-r from-emerald-400 to-cyan-400 bg-clip-text text-transparent">
              Leadership Team
            </span>
          </h2>
          <p class="text-xl text-gray-300">
            Experienced leaders driving innovation in AI and mental health
          </p>
        </div>

        <div class="grid lg:grid-cols-3 gap-8 mb-16">
          <!-- CEO -->
          <div class="relative group">
            <div class="absolute inset-0 bg-gradient-to-r from-emerald-500/20 to-cyan-500/20 rounded-2xl blur-xl group-hover:blur-2xl transition-all duration-300"></div>
            <div class="relative bg-black/40 backdrop-blur-xl border border-white/10 rounded-2xl p-8 hover:border-emerald-500/30 transition-all duration-300">
              <div class="text-center mb-6">
                <div class="w-24 h-24 bg-gradient-to-r from-emerald-500 to-cyan-500 rounded-full flex items-center justify-center text-white text-2xl font-bold mx-auto mb-4">
                  AK
                </div>
                <h3 class="text-xl font-bold text-white mb-1">Dr. Alex Kim</h3>
                <p class="text-emerald-400 font-medium mb-2">CEO & Co-Founder</p>
                <p class="text-gray-400 text-sm">PhD Clinical Psychology, Stanford</p>
              </div>
              
              <p class="text-gray-300 text-sm mb-6">
                Former Director of Digital Therapeutics at UCSF. 15+ years in clinical practice and AI research. Published 40+ papers on therapeutic AI applications.
              </p>
              
              <div class="flex justify-center space-x-4">
                <a href="#" class="w-8 h-8 bg-white/10 hover:bg-emerald-500/20 rounded-full flex items-center justify-center transition-colors duration-200">
                  <svg class="w-4 h-4 text-gray-400 hover:text-emerald-400" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.338 16.338H13.67V12.16c0-.995-.017-2.277-1.387-2.277-1.39 0-1.601 1.086-1.601 2.207v4.248H8.014v-8.59h2.559v1.174h.037c.356-.675 1.227-1.387 2.526-1.387 2.703 0 3.203 1.778 3.203 4.092v4.711zM5.005 6.575a1.548 1.548 0 11-.003-3.096 1.548 1.548 0 01.003 3.096zm-1.337 9.763H6.34v-8.59H3.667v8.59zM17.668 1H2.328C1.595 1 1 1.581 1 2.298v15.403C1 18.418 1.595 19 2.328 19h15.34c.734 0 1.332-.582 1.332-1.299V2.298C19 1.581 18.402 1 17.668 1z" clip-rule="evenodd"></path>
                  </svg>
                </a>
                <a href="#" class="w-8 h-8 bg-white/10 hover:bg-emerald-500/20 rounded-full flex items-center justify-center transition-colors duration-200">
                  <svg class="w-4 h-4 text-gray-400 hover:text-emerald-400" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M6.29 18.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0020 3.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.073 4.073 0 01.8 7.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 010 16.407a11.616 11.616 0 006.29 1.84"></path>
                  </svg>
                </a>
              </div>
            </div>
          </div>

          <!-- CTO -->
          <div class="relative group">
            <div class="absolute inset-0 bg-gradient-to-r from-blue-500/20 to-purple-500/20 rounded-2xl blur-xl group-hover:blur-2xl transition-all duration-300"></div>
            <div class="relative bg-black/40 backdrop-blur-xl border border-white/10 rounded-2xl p-8 hover:border-blue-500/30 transition-all duration-300">
              <div class="text-center mb-6">
                <div class="w-24 h-24 bg-gradient-to-r from-blue-500 to-purple-500 rounded-full flex items-center justify-center text-white text-2xl font-bold mx-auto mb-4">
                  MR
                </div>
                <h3 class="text-xl font-bold text-white mb-1">Maria Rodriguez</h3>
                <p class="text-blue-400 font-medium mb-2">CTO & Co-Founder</p>
                <p class="text-gray-400 text-sm">MS Computer Science, MIT</p>
              </div>
              
              <p class="text-gray-300 text-sm mb-6">
                Former Principal Engineer at Google DeepMind. Expert in conversational AI and natural language processing. Led development of therapeutic chatbot systems.
              </p>
              
              <div class="flex justify-center space-x-4">
                <a href="#" class="w-8 h-8 bg-white/10 hover:bg-blue-500/20 rounded-full flex items-center justify-center transition-colors duration-200">
                  <svg class="w-4 h-4 text-gray-400 hover:text-blue-400" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.338 16.338H13.67V12.16c0-.995-.017-2.277-1.387-2.277-1.39 0-1.601 1.086-1.601 2.207v4.248H8.014v-8.59h2.559v1.174h.037c.356-.675 1.227-1.387 2.526-1.387 2.703 0 3.203 1.778 3.203 4.092v4.711zM5.005 6.575a1.548 1.548 0 11-.003-3.096 1.548 1.548 0 01.003 3.096zm-1.337 9.763H6.34v-8.59H3.667v8.59zM17.668 1H2.328C1.595 1 1 1.581 1 2.298v15.403C1 18.418 1.595 19 2.328 19h15.34c.734 0 1.332-.582 1.332-1.299V2.298C19 1.581 18.402 1 17.668 1z" clip-rule="evenodd"></path>
                  </svg>
                </a>
                <a href="#" class="w-8 h-8 bg-white/10 hover:bg-blue-500/20 rounded-full flex items-center justify-center transition-colors duration-200">
                  <svg class="w-4 h-4 text-gray-400 hover:text-blue-400" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 0C4.477 0 0 4.484 0 10.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0110 4.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.203 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0020 10.017C20 4.484 15.522 0 10 0z" clip-rule="evenodd"></path>
                  </svg>
                </a>
              </div>
            </div>
          </div>

          <!-- Clinical Director -->
          <div class="relative group">
            <div class="absolute inset-0 bg-gradient-to-r from-purple-500/20 to-pink-500/20 rounded-2xl blur-xl group-hover:blur-2xl transition-all duration-300"></div>
            <div class="relative bg-black/40 backdrop-blur-xl border border-white/10 rounded-2xl p-8 hover:border-purple-500/30 transition-all duration-300">
              <div class="text-center mb-6">
                <div class="w-24 h-24 bg-gradient-to-r from-purple-500 to-pink-500 rounded-full flex items-center justify-center text-white text-2xl font-bold mx-auto mb-4">
                  JT
                </div>
                <h3 class="text-xl font-bold text-white mb-1">Dr. James Thompson</h3>
                <p class="text-purple-400 font-medium mb-2">Clinical Director</p>
                <p class="text-gray-400 text-sm">MD Psychiatry, Johns Hopkins</p>
              </div>
              
              <p class="text-gray-300 text-sm mb-6">
                Board-certified psychiatrist with 20+ years in crisis intervention. Former Chief of Emergency Psychiatry at Mass General. Expert in trauma-informed care.
              </p>
              
              <div class="flex justify-center space-x-4">
                <a href="#" class="w-8 h-8 bg-white/10 hover:bg-purple-500/20 rounded-full flex items-center justify-center transition-colors duration-200">
                  <svg class="w-4 h-4 text-gray-400 hover:text-purple-400" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.338 16.338H13.67V12.16c0-.995-.017-2.277-1.387-2.277-1.39 0-1.601 1.086-1.601 2.207v4.248H8.014v-8.59h2.559v1.174h.037c.356-.675 1.227-1.387 2.526-1.387 2.703 0 3.203 1.778 3.203 4.092v4.711zM5.005 6.575a1.548 1.548 0 11-.003-3.096 1.548 1.548 0 01.003 3.096zm-1.337 9.763H6.34v-8.59H3.667v8.59zM17.668 1H2.328C1.595 1 1 1.581 1 2.298v15.403C1 18.418 1.595 19 2.328 19h15.34c.734 0 1.332-.582 1.332-1.299V2.298C19 1.581 18.402 1 17.668 1z" clip-rule="evenodd"></path>
                  </svg>
                </a>
                <a href="#" class="w-8 h-8 bg-white/10 hover:bg-purple-500/20 rounded-full flex items-center justify-center transition-colors duration-200">
                  <svg class="w-4 h-4 text-gray-400 hover:text-purple-400" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M6.29 18.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0020 3.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.073 4.073 0 01.8 7.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 010 16.407a11.616 11.616 0 006.29 1.84"></path>
                  </svg>
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- Extended Team -->
        <div class="grid lg:grid-cols-4 gap-6">
          <!-- Head of AI Research -->
          <div class="bg-black/40 backdrop-blur-xl border border-white/10 rounded-xl p-6 hover:border-emerald-500/20 transition-all duration-300">
            <div class="text-center mb-4">
              <div class="w-16 h-16 bg-gradient-to-r from-emerald-500 to-teal-500 rounded-full flex items-center justify-center text-white text-lg font-bold mx-auto mb-3">
                SP
              </div>
              <h4 class="font-bold text-white mb-1">Dr. Sarah Patel</h4>
              <p class="text-emerald-400 text-sm font-medium mb-1">Head of AI Research</p>
              <p class="text-gray-400 text-xs">PhD Machine Learning, CMU</p>
            </div>
            <p class="text-gray-300 text-xs">
              Leading our AI research initiatives and model development for therapeutic applications.
            </p>
          </div>

          <!-- VP of Engineering -->
          <div class="bg-black/40 backdrop-blur-xl border border-white/10 rounded-xl p-6 hover:border-blue-500/20 transition-all duration-300">
            <div class="text-center mb-4">
              <div class="w-16 h-16 bg-gradient-to-r from-blue-500 to-indigo-500 rounded-full flex items-center justify-center text-white text-lg font-bold mx-auto mb-3">
                DL
              </div>
              <h4 class="font-bold text-white mb-1">David Lee</h4>
              <p class="text-blue-400 text-sm font-medium mb-1">VP of Engineering</p>
              <p class="text-gray-400 text-xs">MS Software Engineering</p>
            </div>
            <p class="text-gray-300 text-xs">
              Scaling our platform infrastructure and leading the engineering team.
            </p>
          </div>

          <!-- Head of Clinical Affairs -->
          <div class="bg-black/40 backdrop-blur-xl border border-white/10 rounded-xl p-6 hover:border-purple-500/20 transition-all duration-300">
            <div class="text-center mb-4">
              <div class="w-16 h-16 bg-gradient-to-r from-purple-500 to-violet-500 rounded-full flex items-center justify-center text-white text-lg font-bold mx-auto mb-3">
                EW
              </div>
              <h4 class="font-bold text-white mb-1">Dr. Emily Wilson</h4>
              <p class="text-purple-400 text-sm font-medium mb-1">Head of Clinical Affairs</p>
              <p class="text-gray-400 text-xs">PhD Clinical Psychology</p>
            </div>
            <p class="text-gray-300 text-xs">
              Ensuring clinical accuracy and therapeutic best practices in our AI models.
            </p>
          </div>

          <!-- Head of Product -->
          <div class="bg-black/40 backdrop-blur-xl border border-white/10 rounded-xl p-6 hover:border-pink-500/20 transition-all duration-300">
            <div class="text-center mb-4">
              <div class="w-16 h-16 bg-gradient-to-r from-pink-500 to-rose-500 rounded-full flex items-center justify-center text-white text-lg font-bold mx-auto mb-3">
                RC
              </div>
              <h4 class="font-bold text-white mb-1">Rachel Chen</h4>
              <p class="text-pink-400 text-sm font-medium mb-1">Head of Product</p>
              <p class="text-gray-400 text-xs">MBA Product Management</p>
            </div>
            <p class="text-gray-300 text-xs">
              Driving product strategy and user experience design for our platform.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Company Values -->
    <section class="py-20 px-6">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold mb-4">
            <span class="bg-gradient-to-r from-emerald-400 to-cyan-400 bg-clip-text text-transparent">
              Our Values
            </span>
          </h2>
          <p class="text-xl text-gray-300">
            The principles that guide everything we do
          </p>
        </div>

        <div class="grid lg:grid-cols-3 gap-8">
          <div class="text-center">
            <div class="w-16 h-16 bg-gradient-to-r from-emerald-500 to-cyan-500 rounded-full flex items-center justify-center mx-auto mb-6">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-white mb-4">Empathy First</h3>
            <p class="text-gray-300">
              Every decision we make is guided by empathy for the professionals we serve and the patients they care for.
            </p>
          </div>

          <div class="text-center">
            <div class="w-16 h-16 bg-gradient-to-r from-blue-500 to-purple-500 rounded-full flex items-center justify-center mx-auto mb-6">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-white mb-4">Clinical Excellence</h3>
            <p class="text-gray-300">
              We maintain the highest standards of clinical accuracy and evidence-based practices in all our AI models.
            </p>
          </div>

          <div class="text-center">
            <div class="w-16 h-16 bg-gradient-to-r from-purple-500 to-pink-500 rounded-full flex items-center justify-center mx-auto mb-6">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-white mb-4">Innovation</h3>
            <p class="text-gray-300">
              We push the boundaries of what's possible with AI while never losing sight of human connection and care.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Join Our Team CTA -->
    <section class="py-20 px-6">
      <div class="max-w-4xl mx-auto">
        <div class="relative group">
          <div class="absolute inset-0 bg-gradient-to-r from-emerald-500/20 to-purple-500/20 rounded-2xl blur-xl group-hover:blur-2xl transition-all duration-300"></div>
          <div class="relative bg-black/40 backdrop-blur-xl border border-emerald-500/30 rounded-2xl p-12 text-center">
            <h2 class="text-4xl font-bold mb-6">
              <span class="bg-gradient-to-r from-emerald-400 to-purple-400 bg-clip-text text-transparent">
                Join Our Mission
              </span>
            </h2>
            <p class="text-xl text-gray-300 mb-8">
              Help us build the future of mental health training. We're looking for passionate individuals who want to make a real impact.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center mb-6">
              <button class="px-8 py-4 bg-gradient-to-r from-emerald-500 to-purple-500 hover:from-emerald-600 hover:to-purple-600 text-white font-bold rounded-lg transition-all duration-200 transform hover:scale-105">
                View Open Positions
              </button>
              <button class="px-8 py-4 bg-white/10 hover:bg-white/20 border border-white/20 text-white font-medium rounded-lg transition-all duration-200">
                Learn About Our Culture
              </button>
            </div>
            <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 text-center">
              <div>
                <div class="text-2xl font-bold text-emerald-400">50+</div>
                <div class="text-sm text-gray-400">Team Members</div>
              </div>
              <div>
                <div class="text-2xl font-bold text-cyan-400">15+</div>
                <div class="text-sm text-gray-400">Countries</div>
              </div>
              <div>
                <div class="text-2xl font-bold text-purple-400">100%</div>
                <div class="text-sm text-gray-400">Remote Friendly</div>
              </div>
              <div>
                <div class="text-2xl font-bold text-pink-400">4.9/5</div>
                <div class="text-sm text-gray-400">Employee Rating</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
