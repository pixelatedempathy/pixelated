---
// Modern Footer inspired by all three themes
interface FooterSection {
  title: string;
  links: Array<{
    label: string;
    href: string;
  }>;
}

const footerSections: FooterSection[] = [
  {
    title: "Solutions",
    links: [
      { label: "For Individuals", href: "/solutions/individuals" },
      { label: "For Therapists", href: "/solutions/therapists" },
      { label: "For Organizations", href: "/solutions/organizations" },
      { label: "Enterprise", href: "/enterprise" }
    ]
  },
  {
    title: "Features",
    links: [
      { label: "AI Therapy", href: "/features/ai-therapy" },
      { label: "Emotion Analysis", href: "/features/emotion-analysis" },
      { label: "Progress Tracking", href: "/features/progress-tracking" },
      { label: "Crisis Support", href: "/features/crisis-support" }
    ]
  },
  {
    title: "Resources",
    links: [
      { label: "Research Papers", href: "/research" },
      { label: "Documentation", href: "/docs" },
      { label: "Help Center", href: "/help" },
      { label: "Blog", href: "/blog" }
    ]
  },
  {
    title: "Company",
    links: [
      { label: "About Us", href: "/about" },
      { label: "Careers", href: "/careers" },
      { label: "Contact", href: "/contact" },
      { label: "Press", href: "/press" }
    ]
  }
];

const socialLinks = [
  {
    name: "Twitter",
    href: "https://twitter.com/pixelatedempathy",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`
  },
  {
    name: "LinkedIn",
    href: "https://linkedin.com/company/pixelatedempathy",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`
  },
  {
    name: "GitHub",
    href: "https://github.com/pixelatedempathy",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>`
  }
];
---

<footer class="modern-footer">
  <div class="container">
    <!-- Main Footer Content -->
    <div class="footer-main">
      <!-- Brand Section -->
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <div class="logo-container">
            <div class="logo-icon">
              <svg width="40" height="40" viewBox="0 0 32 32" fill="none">
                <path d="M16 2L26 8v8c0 7.18-4.82 13.94-12 16-7.18-2.06-12-8.82-12-16V8l10-6z" 
                      fill="var(--color-primary-500)" opacity="0.2"/>
                <path d="M16 2L26 8v8c0 7.18-4.82 13.94-12 16-7.18-2.06-12-8.82-12-16V8l10-6z" 
                      stroke="var(--color-primary-500)" stroke-width="2"/>
                <circle cx="16" cy="14" r="3" fill="var(--color-primary-500)"/>
                <path d="M12 20c0-2.21 1.79-4 4-4s4 1.79 4 4" stroke="var(--color-primary-500)" stroke-width="2"/>
              </svg>
            </div>
            <span class="logo-text">Pixelated Empathy</span>
          </div>
        </a>
        
        <p class="footer-description">
          Revolutionizing mental health support through AI-powered empathy. 
          Creating personalized therapeutic experiences that understand and respond to human emotions.
        </p>

        <div class="social-links">
          {socialLinks.map((social) => (
            <a 
              href={social.href} 
              class="social-link"
              aria-label={`Follow us on ${social.name}`}
              target="_blank"
              rel="noopener noreferrer"
            >
              <Fragment set:html={social.icon} />
            </a>
          ))}
        </div>
      </div>

      <!-- Footer Links Grid -->
      <div class="footer-grid">
        {footerSections.map((section) => (
          <div class="footer-section">
            <h3 class="footer-title">{section.title}</h3>
            <ul class="footer-links">
              {section.links.map((link) => (
                <li>
                  <a href={link.href} class="footer-link">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <!-- Newsletter Signup -->
      <div class="newsletter-section">
        <h3 class="footer-title">Stay Updated</h3>
        <p class="newsletter-description">
          Get the latest updates on mental health AI research and features.
        </p>
        <form class="newsletter-form" action="/api/newsletter" method="POST">
          <div class="input-group">
            <input 
              type="email" 
              name="email"
              placeholder="Enter your email"
              class="newsletter-input"
              required
              aria-label="Email address"
            />
            <button type="submit" class="newsletter-button">
              Subscribe
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 12h14"></path>
                <path d="M12 5l7 7-7 7"></path>
              </svg>
            </button>
          </div>
          <p class="newsletter-privacy">
            We respect your privacy. Unsubscribe at any time.
          </p>
        </form>
      </div>
    </div>

    <!-- Footer Bottom -->
    <div class="footer-bottom">
      <div class="footer-bottom-content">
        <div class="copyright">
          <p>&copy; 2024 Pixelated Empathy. All rights reserved.</p>
        </div>
        
        <div class="footer-bottom-links">
          <a href="/privacy" class="footer-bottom-link">Privacy Policy</a>
          <a href="/terms" class="footer-bottom-link">Terms of Service</a>
          <a href="/cookies" class="footer-bottom-link">Cookie Policy</a>
          <a href="/accessibility" class="footer-bottom-link">Accessibility</a>
        </div>

        <div class="certifications">
          <div class="cert-badge">
            <span class="cert-text">HIPAA</span>
            <span class="cert-subtext">Compliant</span>
          </div>
          <div class="cert-badge">
            <span class="cert-text">SOC 2</span>
            <span class="cert-subtext">Type II</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  .modern-footer {
    background: var(--color-background-secondary);
    border-top: 1px solid var(--color-border);
  }

  .footer-main {
    display: grid;
    grid-template-columns: 1fr 2fr 1fr;
    gap: var(--space-12);
    padding: var(--space-16) 0 var(--space-12);
  }

  /* Brand Section */
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .footer-logo .logo-container {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
  }

  .footer-logo .logo-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: var(--radius-xl);
    background: linear-gradient(135deg, var(--color-primary-100), var(--color-primary-200));
  }

  .footer-logo .logo-text {
    font-size: var(--font-size-xl);
    font-weight: 700;
    color: var(--color-text);
  }

  .footer-description {
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
    margin-bottom: var(--space-6);
  }

  .social-links {
    display: flex;
    gap: var(--space-4);
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-lg);
    background: var(--color-background);
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
    transition: all var(--transition-normal);
  }

  .social-link:hover {
    background: var(--color-primary-500);
    color: white;
    border-color: var(--color-primary-500);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  /* Footer Links Grid */
  .footer-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-8);
  }

  .footer-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .footer-title {
    font-size: var(--font-size-lg);
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-2);
  }

  .footer-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer-link {
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color var(--transition-fast);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
  }

  .footer-link:hover {
    color: var(--color-primary-500);
  }

  /* Newsletter Section */
  .newsletter-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .newsletter-description {
    color: var(--color-text-secondary);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
  }

  .newsletter-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .input-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .newsletter-input {
    width: 100%;
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-background);
    color: var(--color-text);
    font-size: var(--font-size-sm);
    transition: all var(--transition-normal);
  }

  .newsletter-input:focus {
    outline: none;
    border-color: var(--color-primary-500);
    box-shadow: 0 0 0 3px var(--color-primary-100);
  }

  .newsletter-button {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    background: var(--color-primary-500);
    color: white;
    border: none;
    border-radius: var(--radius-lg);
    font-size: var(--font-size-sm);
    font-weight: 500;
    cursor: pointer;
    transition: all var(--transition-normal);
  }

  .newsletter-button:hover {
    background: var(--color-primary-600);
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
  }

  .newsletter-privacy {
    color: var(--color-text-secondary);
    font-size: var(--font-size-xs);
    line-height: var(--line-height-normal);
  }

  /* Footer Bottom */
  .footer-bottom {
    padding: var(--space-8) 0;
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-8);
  }

  .footer-bottom-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-6);
  }

  .copyright p {
    color: var(--color-text-secondary);
    font-size: var(--font-size-sm);
    margin: 0;
  }

  .footer-bottom-links {
    display: flex;
    gap: var(--space-6);
  }

  .footer-bottom-link {
    color: var(--color-text-secondary);
    text-decoration: none;
    font-size: var(--font-size-sm);
    transition: color var(--transition-fast);
  }

  .footer-bottom-link:hover {
    color: var(--color-primary-500);
  }

  .certifications {
    display: flex;
    gap: var(--space-4);
  }

  .cert-badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: var(--space-2) var(--space-3);
    background: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    min-width: 60px;
  }

  .cert-text {
    font-size: var(--font-size-xs);
    font-weight: 600;
    color: var(--color-text);
    line-height: 1;
  }

  .cert-subtext {
    font-size: 10px;
    color: var(--color-text-secondary);
    line-height: 1;
  }

  /* Responsive Design */
  @media (max-width: 1024px) {
    .footer-main {
      grid-template-columns: 1fr 1.5fr;
      gap: var(--space-10);
    }

    .newsletter-section {
      grid-column: 1 / -1;
      margin-top: var(--space-8);
      padding-top: var(--space-8);
      border-top: 1px solid var(--color-border);
    }

    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .footer-main {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-6);
    }

    .footer-bottom-content {
      flex-direction: column;
      text-align: center;
      gap: var(--space-4);
    }

    .footer-bottom-links {
      flex-wrap: wrap;
      justify-content: center;
    }

    .input-group {
      flex-direction: column;
    }

    .newsletter-input,
    .newsletter-button {
      width: 100%;
    }
  }

  @media (max-width: 480px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }

    .social-links {
      justify-content: center;
    }

    .certifications {
      justify-content: center;
    }
  }
</style>