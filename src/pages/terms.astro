---
import Layout from '@/layouts/Layout.astro'
---

<Layout title="Terms of Service" description="Pixelated Empathy Terms of Service - Legal terms and conditions for using our AI-powered mental health training platform.">
  <div class="py-24 bg-gray-950">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h1 class="text-5xl font-bold text-white mb-6">Terms of Service</h1>
        <p class="text-gray-400">Last updated: {new Date().toLocaleDateString()}</p>
      </div>
      
      <div class="prose prose-lg prose-invert max-w-none">
        <section class="mb-8">
          <h2>Agreement to Terms</h2>
          <p>
            By accessing and using Pixelated Empathy's services, you agree to be bound by these Terms of Service 
            and all applicable laws and regulations. If you do not agree with any of these terms, you are 
            prohibited from using or accessing this site.
          </p>
        </section>
        
        <section class="mb-8">
          <h2>Service Description</h2>
          <p>
            Pixelated Empathy provides AI-powered simulation training for mental health professionals. 
            Our platform offers:
          </p>
          <ul>
            <li>Interactive AI simulation scenarios</li>
            <li>Real-time performance feedback and analytics</li>
            <li>Training progress tracking and reporting</li>
            <li>Educational resources and materials</li>
          </ul>
        </section>
        
        <section class="mb-8">
          <h2>User Responsibilities</h2>
          <p>As a user of our platform, you agree to:</p>
          <ul>
            <li>Provide accurate and complete information</li>
            <li>Maintain the confidentiality of your account credentials</li>
            <li>Use the platform for professional training purposes only</li>
            <li>Comply with all applicable healthcare regulations</li>
            <li>Not attempt to reverse engineer or compromise our systems</li>
          </ul>
        </section>
        
        <section class="mb-8">
          <h2>Professional Use</h2>
          <p>
            Our platform is designed for licensed mental health professionals and students in accredited programs. 
            The AI simulations are for training purposes only and do not replace professional supervision, 
            clinical judgment, or actual patient care.
          </p>
        </section>
        
        <section class="mb-8">
          <h2>Intellectual Property</h2>
          <p>
            All content, features, and functionality of the Pixelated Empathy platform are owned by 
            Pixelated Empathy, Inc. and are protected by copyright, trademark, and other intellectual property laws.
          </p>
        </section>
        
        <section class="mb-8">
          <h2>Limitation of Liability</h2>
          <p>
            In no event shall Pixelated Empathy be liable for any indirect, incidental, special, 
            consequential, or punitive damages arising out of your use of our services.
          </p>
        </section>
        
        <section class="mb-8">
          <h2>Termination</h2>
          <p>
            We may terminate or suspend your account immediately, without prior notice or liability, 
            for any reason whatsoever, including breach of these Terms.
          </p>
        </section>
        
        <section class="mb-8">
          <h2>Contact Information</h2>
          <p>
            Questions about the Terms of Service should be sent to:
            <br />
            <a href="mailto:legal@pixelatedempathy.com" class="text-emerald-400 hover:text-emerald-300">
              legal@pixelatedempathy.com
            </a>
          </p>
        </section>
      </div>
    </div>
  </div>
</Layout>