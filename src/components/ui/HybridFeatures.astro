---
// Hybrid Features - Streamline content focus + Mizu elegance
interface Feature {
  icon: string;
  title: string;
  description: string;
  specs?: string[];
  metrics?: {
    value: string;
    label: string;
  };
  link?: string;
}

const features: Feature[] = [
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M12 2L2 7v10c0 5.55 3.84 10 10 12 6.16-2 10-6.45 10-12V7l-10-5z"/>
      <path d="M9 12l2 2 4-4"/>
    </svg>`,
    title: "Clinical AI Engine",
    description: "Evidence-based machine learning models trained on clinical datasets with continuous learning capabilities and real-time adaptation.",
    specs: ["99.2% diagnostic accuracy", "Sub-150ms response time", "HIPAA compliant processing", "24/7 system monitoring"],
    metrics: { value: "94%", label: "Clinical Validation" },
    link: "/platform/ai-engine"
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <rect x="3" y="3" width="18" height="18" rx="2"/>
      <path d="M9 9h6v6H9z"/>
      <path d="M16 1v6M8 1v6"/>
    </svg>`,
    title: "EHR Integration Suite",
    description: "Seamlessly connect with existing healthcare systems through standardized APIs, webhooks, and real-time data synchronization.",
    specs: ["HL7 FHIR R4 standard", "Epic/Cerner certified", "RESTful API endpoints", "Real-time data sync"],
    metrics: { value: "50+", label: "EHR Systems" },
    link: "/platform/integration"
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M3 13h18M3 17h18M3 9h18"/>
      <rect x="5" y="5" width="2" height="2" rx="1"/>
    </svg>`,
    title: "Analytics Dashboard",
    description: "Comprehensive insights and reporting for clinical teams with customizable dashboards and population health metrics.",
    specs: ["Real-time data visualization", "Custom report generation", "Population health insights", "Outcome tracking"],
    metrics: { value: "15+", label: "Report Types" },
    link: "/platform/analytics"
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <rect x="3" y="11" width="18" height="10" rx="2"/>
      <circle cx="12" cy="16" r="1"/>
      <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
    </svg>`,
    title: "Security Framework",
    description: "Enterprise-grade security with end-to-end encryption, compliance monitoring, and zero-trust architecture.",
    specs: ["SOC 2 Type II certified", "HIPAA/GDPR compliance", "AES-256 encryption", "Zero-trust security"],
    metrics: { value: "99.9%", label: "Security Score" },
    link: "/platform/security"
  }
];
---

<section class="hybrid-features section-lg">
  <div class="container">
    <!-- Elegant section header -->
    <div class="section-header">
      <h2 class="section-title">
        Platform <span class="text-gradient">Capabilities</span>
      </h2>
      <p class="section-subtitle">
        Production-ready infrastructure designed specifically for healthcare organizations 
        with enterprise-grade security, compliance, and integration capabilities.
      </p>
    </div>

    <!-- Enhanced feature grid -->
    <div class="features-grid">
      {features.map((feature, index) => (
        <div class="feature-card-elegant" style={`animation-delay: ${index * 0.1}s`}>
          <!-- Card header with icon and metrics -->
          <div class="feature-header">
            <div class="feature-icon-container">
              <div class="feature-icon">
                <Fragment set:html={feature.icon} />
              </div>
              {feature.metrics && (
                <div class="feature-metric">
                  <div class="metric-value">{feature.metrics.value}</div>
                  <div class="metric-label">{feature.metrics.label}</div>
                </div>
              )}
            </div>
            <h3 class="feature-title">{feature.title}</h3>
          </div>
          
          <!-- Feature description -->
          <p class="feature-description">{feature.description}</p>
          
          <!-- Specifications list -->
          {feature.specs && (
            <div class="feature-specs">
              {feature.specs.map((spec) => (
                <div class="spec-item">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="20,6 9,17 4,12"/>
                  </svg>
                  <span>{spec}</span>
                </div>
              ))}
            </div>
          )}
          
          <!-- Card footer with link -->
          {feature.link && (
            <div class="feature-footer">
              <a href={feature.link} class="feature-link">
                Explore feature
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M7 17l10-10M17 7H7"/>
                </svg>
              </a>
            </div>
          )}
        </div>
      ))}
    </div>

    <!-- Enhanced API documentation section -->
    <div class="api-showcase">
      <div class="api-content">
        <div class="api-header">
          <h3 class="api-title">Developer-First API Design</h3>
          <p class="api-subtitle">
            Integrate mental health AI capabilities into your applications with our comprehensive RESTful API
          </p>
        </div>
        
        <div class="api-demo-grid">
          <!-- Request example -->
          <div class="api-demo-card">
            <div class="demo-header">
              <div class="demo-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M12 19l7-7 3 3-7 7-3-3z"/>
                  <path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/>
                  <path d="M2 2l7.5 3.5L18 13"/>
                </svg>
              </div>
              <h4>Request</h4>
              <span class="demo-method">POST</span>
            </div>
            <div class="code-block">
              <pre><code>{`{
  "text": "Patient reports anxiety symptoms",
  "context": "clinical_assessment",
  "patient_id": "px_12345",
  "session_type": "initial_consultation"
}`}</code></pre>
            </div>
          </div>
          
          <!-- Response example -->
          <div class="api-demo-card">
            <div class="demo-header">
              <div class="demo-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <polyline points="22,12 18,12 15,21 9,3 6,12 2,12"/>
                </svg>
              </div>
              <h4>Response</h4>
              <span class="demo-status">200</span>
            </div>
            <div class="code-block">
              <pre><code>{`{
  "analysis": {
    "sentiment": 0.72,
    "risk_level": "moderate", 
    "confidence": 0.94,
    "keywords": ["anxiety", "symptoms"],
    "recommendations": [
      "cognitive_behavioral_therapy",
      "anxiety_management_techniques"
    ]
  },
  "processing_time": "127ms"
}`}</code></pre>
            </div>
          </div>
        </div>
        
        <!-- API actions -->
        <div class="api-actions">
          <a href="/docs/api" class="btn btn-primary btn-lg">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14,2 14,8 20,8"/>
              <line x1="16" y1="13" x2="8" y2="13"/>
              <line x1="16" y1="17" x2="8" y2="17"/>
            </svg>
            View Documentation
          </a>
          <a href="/api/playground" class="btn btn-secondary btn-lg">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
              <circle cx="9" cy="9" r="2"/>
              <path d="M21 15.5c-1-1.4-3-1.4-4 0"/>
              <path d="M3 15.5c1-1.4 3-1.4 4 0"/>
            </svg>
            API Playground
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hybrid-features {
    background: linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-secondary) 100%);
    position: relative;
  }

  /* Enhanced feature grid */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: var(--space-12);
    margin-bottom: var(--space-32);
  }

  .feature-card-elegant {
    background: var(--bg-card);
    backdrop-filter: blur(16px) saturate(180%);
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-3xl);
    padding: var(--space-10);
    transition: all var(--transition-slow);
    position: relative;
    overflow: hidden;
    opacity: 0;
    transform: translateY(20px);
    animation: slideInUp 0.6s ease-out forwards;
  }

  @keyframes slideInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .feature-card-elegant::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--border-accent), transparent);
    opacity: 0;
    transition: opacity var(--transition-normal);
  }

  .feature-card-elegant:hover {
    border-color: var(--border-secondary);
    box-shadow: var(--shadow-2xl);
    transform: translateY(-8px);
  }

  .feature-card-elegant:hover::before {
    opacity: 1;
  }

  .feature-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: var(--space-8);
  }

  .feature-icon-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .feature-icon {
    width: 64px;
    height: 64px;
    background: linear-gradient(135deg, var(--accent), var(--accent-hover));
    border-radius: var(--radius-2xl);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    box-shadow: var(--shadow-lg);
    transition: all var(--transition-normal);
  }

  .feature-card-elegant:hover .feature-icon {
    transform: scale(1.05);
    box-shadow: var(--shadow-xl);
  }

  .feature-metric {
    text-align: center;
  }

  .feature-metric .metric-value {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--text-primary);
    font-family: var(--font-mono);
    line-height: var(--leading-none);
  }

  .feature-metric .metric-label {
    font-size: var(--text-xs);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .feature-title {
    font-size: var(--text-2xl);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--space-2);
    flex: 1;
    line-height: var(--leading-snug);
  }

  .feature-description {
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-8);
  }

  .feature-specs {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-bottom: var(--space-8);
  }

  .spec-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: var(--leading-relaxed);
  }

  .spec-item svg {
    color: var(--accent);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .feature-footer {
    border-top: 1px solid var(--border-primary);
    padding-top: var(--space-6);
  }

  .feature-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--accent);
    text-decoration: none;
    font-size: var(--text-sm);
    font-weight: 600;
    transition: all var(--transition-fast);
  }

  .feature-link:hover {
    color: var(--accent-hover);
    transform: translateX(4px);
  }

  /* Enhanced API showcase */
  .api-showcase {
    background: var(--bg-elevated);
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-3xl);
    padding: var(--space-16);
    backdrop-filter: blur(16px);
    box-shadow: var(--shadow-xl);
  }

  .api-content {
    max-width: 1000px;
    margin: 0 auto;
  }

  .api-header {
    text-align: center;
    margin-bottom: var(--space-12);
  }

  .api-title {
    font-size: var(--text-4xl);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--space-4);
  }

  .api-subtitle {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    max-width: 600px;
    margin: 0 auto;
  }

  .api-demo-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
    margin-bottom: var(--space-12);
  }

  .api-demo-card {
    background: var(--bg-tertiary);
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-2xl);
    overflow: hidden;
  }

  .demo-header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-6);
    background: var(--bg-card);
    border-bottom: 1px solid var(--border-primary);
  }

  .demo-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: var(--accent-muted);
    color: var(--accent);
    border-radius: var(--radius-lg);
  }

  .demo-header h4 {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--text-primary);
    margin: 0;
    flex: 1;
  }

  .demo-method {
    padding: var(--space-1) var(--space-2);
    background: var(--accent-muted);
    color: var(--accent);
    font-size: var(--text-xs);
    font-weight: 600;
    border-radius: var(--radius-md);
    text-transform: uppercase;
  }

  .demo-status {
    padding: var(--space-1) var(--space-2);
    background: #10b981;
    color: white;
    font-size: var(--text-xs);
    font-weight: 600;
    border-radius: var(--radius-md);
  }

  .code-block {
    padding: var(--space-6);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    overflow-x: auto;
  }

  .code-block pre {
    margin: 0;
    color: var(--text-secondary);
  }

  .api-actions {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
  }

  /* Responsive design */
  @media (max-width: 1024px) {
    .features-grid {
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: var(--space-8);
    }

    .api-demo-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .hybrid-features {
      padding: var(--space-20) 0;
    }

    .features-grid {
      grid-template-columns: 1fr;
      gap: var(--space-6);
      margin-bottom: var(--space-20);
    }

    .feature-card-elegant {
      padding: var(--space-6);
    }

    .feature-header {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-4);
    }

    .feature-icon-container {
      flex-direction: row;
      align-items: center;
    }

    .api-showcase {
      padding: var(--space-8);
    }

    .api-title {
      font-size: var(--text-3xl);
    }

    .api-actions {
      flex-direction: column;
      align-items: center;
    }

    .api-actions .btn {
      width: 100%;
      max-width: 280px;
    }
  }
</style>