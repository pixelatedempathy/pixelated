---
/**
 * Reusable Content Section Component
 * Applies unified design system spacing and layout
 */
interface Props {
  class?: string
  diagonal?: boolean
}

const { class: className = '', diagonal = false } = Astro.props
---

<section class={`relative py-16 lg:py-24 ${className}`}>
  {diagonal && (
    <div class="absolute inset-0 bg-gradient-to-r from-emerald-500/10 to-cyan-500/10 transform -skew-y-6"></div>
  )}
  
  <div class="container mx-auto px-6 relative z-10">
    <slot />
  </div>
</section>
